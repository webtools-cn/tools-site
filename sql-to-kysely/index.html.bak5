<script>
function showToast(m){var t=document.getElementById("toast");t.textContent=m;t.classList.add("show");setTimeout(function(){t.classList.remove("show")},3000)}
function copyText(id){var el=document.getElementById(id);if(!el)return;var t=el.textContent||el.innerText;navigator.clipboard.writeText(t).then(function(){showToast("已复制")})["catch"](function(){showToast("复制失败")})}

(function(){
var history=[];
function getIndent(){var s=document.getElementById('indentStyle').value;return s==='tab'?'\t':' '.repeat(parseInt(s));}
function getQuote(){return document.getElementById('singleQuote').checked?"'":'"';}
function parseSelect(sql){
  var indent=getIndent(),q=getQuote();
  var lines=[];
  var fromMatch=sql.match(/FROM\s+(\w+)(?:\s+(?:AS\s+)?(\w+))?/i);
  var mainTable=fromMatch?fromMatch[1]:'table';
  var mainAlias=fromMatch&&fromMatch[2]?fromMatch[2]:mainTable;
  var selectMatch=sql.match(/SELECT\s+(.*?)\s+FROM/i);
  var columns=selectMatch?selectMatch[1].trim():'*';
  var colArr=columns==='*'?[]:columns.split(',').map(function(c){return c.trim();});
  var joins=[];
  var joinRegex=/JOIN\s+(\w+)(?:\s+(?:AS\s+)?(\w+))?\s+ON\s+(.+?)(?=\s+(?:JOIN|WHERE|GROUP|ORDER|LIMIT|$))/gi;
  var jm;
  while((jm=joinRegex.exec(sql))!==null){
    joins.push({table:jm[1],alias:jm[2]||jm[1],on:jm[3].trim()});
  }
  var whereMatch=sql.match(/WHERE\s+(.+?)(?=\s+(?:GROUP|ORDER|LIMIT|$))/i);
  var groupMatch=sql.match(/GROUP\s+BY\s+(.+?)(?=\s+(?:HAVING|ORDER|LIMIT|$))/i);
  var orderMatch=sql.match(/ORDER\s+BY\s+(.+?)(?=\s*(?:LIMIT|$))/i);
  var limitMatch=sql.match(/LIMIT\s+(\d+)/i);
  var offsetMatch=sql.match(/OFFSET\s+(\d+)/i);
  lines.push('const result = await db');
  lines.push(indent+'selectFrom('+q+mainTable+q+(mainAlias!==mainTable?' as '+q+mainAlias+q:'')+')');
  if(colArr.length>0){
    colArr.forEach(function(col,i){
      var parts=col.split(/\s+(?:as|AS)\s+/);
      var colName=parts[0].trim();
      var colAlias=parts[1]?parts[1].trim():null;
      var dotParts=colName.split('.');
      var ref=dotParts.length>1?q+dotParts[0]+q+'.'+q+dotParts[1]+q:q+colName+q;
      var suffix=i<colArr.length-1?',':'';
      if(colAlias){
        lines.push(indent+indent+'.'+ref+(colAlias?' as '+q+colAlias+q:'')+suffix);
      else lines.push(indent+indent+'.'+ref+suffix);
    });
  }else{
    lines.push(indent+indent+'.selectAll()');
  }
  joins.forEach(function(j){
    var onParts=j.on.split(/=/);
    var leftRef=onParts[0]?onParts[0].trim():'';
    var rightRef=onParts[1]?onParts[1].trim():'';
    lines.push(indent+indent+'.join('+q+j.table+q+(j.alias!==j.table?' as '+q+j.alias+q:'')+', '+q+leftRef+q+', '+q+rightRef+q+')');
  });
  if(whereMatch){
    var w=whereMatch[1].trim();
    var conditions=w.split(/\s+AND\s+/i);
    conditions.forEach(function(cond){
      cond=cond.trim();
      var eqMatch=cond.match(/(.+?)\s*=\s*(.+)/);
      if(eqMatch){
        var field=eqMatch[1].trim();
        var val=eqMatch[2].trim();
        if(val.match(/^true$/i))lines.push(indent+indent+'.where('+q+field+q+', '+q+'='+q+', true)');
        else if(val.match(/^false$/i))lines.push(indent+indent+'.where('+q+field+q+', '+q+'='+q+', false)');
        else if(val.match(/^\d+$/))lines.push(indent+indent+'.where('+q+field+q+', '+q+'='+q+', '+val+')');
        else lines.push(indent+indent+'.where('+q+field+q+', '+q+'='+q+', '+q+val.replace(/'/g,q)+q+')');\n      }else{\n        lines.push(indent+indent+'.whereRef('+q+cond+q+')');\n      }\n    });\n  }\n  if(groupMatch){\n    var gCols=groupMatch[1].split(',').map(function(c){return q+c.trim()+q;});\n    lines.push(indent+indent+'.groupBy('+gCols.join(', ')+')');\n  }\n  if(orderMatch){\n    var oCols=orderMatch[1].split(',').map(function(c){\n      c=c.trim();\n      if(c.match(/\s+DESC$/i))return q+c.replace(/\s+DESC$/i,'')+q+' desc';\n      if(c.match(/\s+ASC$/i))return q+c.replace(/\s+ASC$/i,'')+q+' asc';\n      return q+c+q;\n    });\n    lines.push(indent+indent+'.orderBy('+oCols.join(', ')+')');\n  }\n  if(limitMatch)lines.push(indent+indent+'.limit('+limitMatch[1]+')');\n  if(offsetMatch)lines.push(indent+indent+'.offset('+offsetMatch[1]+')');\n  lines.push(indent+'.execute()');\n  return lines.join('\n');\n}\nfunction parseInsert(sql){\n  var indent=getIndent(),q=getQuote();\n  var match=sql.match(/INSERT\s+INTO\s+(\w+)\s*\(([^)]+)\)\s*VALUES\s*\(([^)]+)\)/i);\n  if(!match)return'// 无法解析INSERT语句';\n  var table=match[1];\n  var cols=match[2].split(',').map(function(c){return c.trim();});\n  var vals=match[3].split(',').map(function(v){return v.trim();});\n  var obj='{';\n  cols.forEach(function(col,i){\n    var val=vals[i]||'';\n    var suffix=i<cols.length-1?',':'';\n    if(val.match(/^true$/i))obj+='\n'+indent+indent+q+col+q+': true'+suffix;\n    else if(val.match(/^false$/i))obj+='\n'+indent+indent+q+col+q+': false'+suffix;\n    else if(val.match(/^\d+$/))obj+='\n'+indent+indent+q+col+q+': '+val+suffix;\n    else obj+='\n'+indent+indent+q+col+q+': '+q+val.replace(/'/g,q)+q+suffix;
  });
  obj+='\n'+indent+'}';
  return'const result = await db\n'+indent+'.insertInto('+q+table+q+')\n'+indent+'.values('+obj+')\n'+indent+'.execute()';
}
function parseUpdate(sql){
  var indent=getIndent(),q=getQuote();
  var match=sql.match(/UPDATE\s+(\w+)\s+SET\s+(.+?)(?:\s+WHERE\s+(.+))?$/i);
  if(!match)return'// 无法解析UPDATE语句';
  var table=match[1];
  var setParts=match[2].split(',').map(function(s){return s.trim();});
  var where=match[3];
  var obj='{';
  setParts.forEach(function(sp,i){
    var kv=sp.split('=');
    var col=kv[0].trim();
    var val=kv[1]?kv[1].trim():'';
    var suffix=i<setParts.length-1?',':'';
    if(val.match(/^\d+$/))obj+='\n'+indent+indent+q+col+q+': '+val+suffix;
    else obj+='\n'+indent+indent+q+col+q+': '+q+val.replace(/'/g,q)+q+suffix;\n  });\n  obj+='\n'+indent+'}';\n  var lines='const result = await db\n'+indent+'.updateTable('+q+table+q+')\n'+indent+'.set('+obj+')';\n  if(where){\n    var eqMatch=where.match(/(.+?)\s*=\s*(.+)/);\n    if(eqMatch)lines+='\n'+indent+'.where('+q+eqMatch[1].trim()+q+', '+q+'='+q+', '+q+eqMatch[2].trim().replace(/'/g,q)+q+')';
  }
  lines+='\n'+indent+'.execute()';
  return lines;
}
function parseDelete(sql){
  var indent=getIndent(),q=getQuote();
  var match=sql.match(/DELETE\s+FROM\s+(\w+)(?:\s+WHERE\s+(.+))?$/i);
  if(!match)return'// 无法解析DELETE语句';
  var table=match[1];
  var where=match[2];
  var lines='const result = await db\n'+indent+'.deleteFrom('+q+table+q+')';
  if(where){
    var conditions=where.split(/\s+AND\s+/i);
    conditions.forEach(function(cond){
      cond=cond.trim();
      var eqMatch=cond.match(/(.+?)\s*=\s*(.+)/);
      if(eqMatch)lines+='\n'+indent+'.where('+q+eqMatch[1].trim()+q+', '+q+'='+q+', '+q+eqMatch[2].trim().replace(/'/g,q)+q+')';\n    });\n  }\n  lines+='\n'+indent+'.execute()';\n  return lines;\n}\nwindow.convert=function(){\n  var sql=document.getElementById('sqlInput').value.trim();\n  var errEl=document.getElementById('errorMsg');\n  if(!sql){errEl.style.display='none';document.getElementById('resultSection').style.display='none';return;}\n  var result='';\n  var upperSql=sql.toUpperCase().trim();\n  try{\n    if(upperSql.startsWith('SELECT'))result=parseSelect(sql);\n    else if(upperSql.startsWith('INSERT'))result=parseInsert(sql);\n    else if(upperSql.startsWith('UPDATE'))result=parseUpdate(sql);\n    else if(upperSql.startsWith('DELETE'))result=parseDelete(sql);\n    else{errEl.textContent='不支持的SQL语句类型，目前支持SELECT/INSERT/UPDATE/DELETE';errEl.style.display='block';return;}\n    errEl.style.display='none';\n    document.getElementById('output').value=result;\n    document.getElementById('resultSection').style.display='block';\n    window._lastOutput=result;\n    saveHistory(sql);\n  }catch(e){\n    errEl.textContent='SQL解析错误：'+e.message;errEl.style.display='block';\n  }\n};\nfunction saveHistory(sql){\n  history=history.filter(function(h){return h!==sql;});\n  history.unshift(sql);\n  if(history.length>5)history=history.slice(0,5);\n  try{localStorage.setItem('sql_kysely_history',JSON.stringify(history));}catch(e){}\n  renderHistory();\n}\nfunction renderHistory(){\n  var el=document.getElementById('historyList');\n  if(!history.length){el.innerHTML='';return;}\n  el.innerHTML=history.map(function(h,i){return'<div class="history-item" onclick="restoreHistory('+i+')">'+h.replace(/</g,'&lt;')+'</div>';}).join('');\n}\nwindow.restoreHistory=function(i){\n  document.getElementById('sqlInput').value=history[i];\n  convert();\n};\nwindow.loadExample=function(){\n  document.getElementById('sqlInput').value="SELECT u.id, u.name, u.email, p.title\nFROM users u\nJOIN posts p ON u.id = p.user_id\nWHERE u.active = true\nORDER BY u.name\nLIMIT 10";\n  convert();\n};\nwindow.clearAll=function(){\n  document.getElementById('sqlInput').value='';\n  document.getElementById('resultSection').style.display='none';\n  document.getElementById('errorMsg').style.display='none';\n};\nwindow.copyResult=function(){\n  var t=document.getElementById('output').value;\n  if(navigator.clipboard)navigator.clipboard.writeText(t).then(showMsg);\n};\nwindow.downloadResult=function(){\n  var t=document.getElementById('output').value;\n  var b=new Blob([t],{type:'text/typescript'});\n  var a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='kysely-query.ts';a.click();\n};\nfunction showMsg(){var m=document.createElement('div');m.textContent='✓ 已复制';m.style.cssText='position:fixed;top:20px;right:20px;background:rgba(34,197,94,.2);color:#4ade80;padding:8px 16px;border-radius:8px;font-size:.85rem;z-index:9999;border:1px solid rgba(34,197,94,.3)';document.body.appendChild(m);setTimeout(function(){m.remove();},2000);}\ndocument.addEventListener('keydown',function(e){if(e.ctrlKey&&e.key==='Enter'){convert();e.preventDefault();}if(e.ctrlKey&&e.shiftKey&&e.key==='C'){copyResult();e.preventDefault();}if(e.ctrlKey&&e.shiftKey&&e.key==='X'){clearAll();e.preventDefault();}});\ntry{var saved=localStorage.getItem('sql_kysely_history');if(saved)history=JSON.parse(saved);}catch(e){}\nrenderHistory();\nif(!localStorage.getItem('sql_kysely_done')){loadExample();localStorage.setItem('sql_kysely_done','1');}\n})();\n\n</script>
</body>
</html>