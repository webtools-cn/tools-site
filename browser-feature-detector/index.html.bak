  <p>浏览器特性检测 · 纯前端本地处理 · 数据绝不上传服务器</p>
  <p style="margin-top:8px;color:#475569;font-size:.8rem">问题反馈: dexshuang@google.com</p>
</div>

<script>
const features = [
  // Web API
  {name:'Geolocation',cat:'api',test:()=>'geolocation' in navigator},
  {name:'WebRTC',cat:'api',test:()=>!!(window.RTCPeerConnection||window.webkitRTCPeerConnection)},
  {name:'Service Worker',cat:'api',test:()=>'serviceWorker' in navigator},
  {name:'WebGL',cat:'api',test:()=>!!document.createElement('canvas').getContext('webgl')},
  {name:'WebGL2',cat:'api',test:()=>!!document.createElement('canvas').getContext('webgl2')},
  {name:'WebGPU',cat:'api',test:()=>!!navigator.gpu},
  {name:'Web Audio',cat:'api',test:()=>!!(window.AudioContext||window.webkitAudioContext)},
  {name:'IndexedDB',cat:'api',test:()=>!!window.indexedDB},
  {name:'Notification',cat:'api',test:()=>!!window.Notification},
  {name:'Clipboard API',cat:'api',test:()=>!!navigator.clipboard},
  {name:'Web Speech (Synthesis)',cat:'api',test:()=>'speechSynthesis' in window},
  {name:'Web Speech (Recognition)',cat:'api',test:()=>!!(window.SpeechRecognition||window.webkitSpeechRecognition)},
  {name:'WebAssembly',cat:'api',test:()=>!!window.WebAssembly},
  {name:'WebSocket',cat:'api',test:()=>!!window.WebSocket},
  {name:'Fetch API',cat:'api',test:()=>!!window.fetch},
  {name:'Promise',cat:'api',test:()=>!!window.Promise},
  {name:'IntersectionObserver',cat:'api',test:()=>!!window.IntersectionObserver},
  {name:'ResizeObserver',cat:'api',test:()=>!!window.ResizeObserver},
  {name:'MutationObserver',cat:'api',test:()=>!!window.MutationObserver},
  {name:'PerformanceObserver',cat:'api',test:()=>!!window.PerformanceObserver},
  {name:'Web Animations',cat:'api',test:()=>!!Element.prototype.animate},
  {name:'Fullscreen API',cat:'api',test:()=>!!document.documentElement.requestFullscreen||!!document.documentElement.webkitRequestFullscreen},
  {name:'Screen Orientation',cat:'api',test:()=>!!screen.orientation},
  {name:'Vibration API',cat:'api',test:()=>!!navigator.vibrate},
  {name:'Battery API',cat:'api',test:()=>!!navigator.getBattery},
  {name:'Gamepad API',cat:'api',test:()=>!!navigator.getGamepads},
  {name:'Web Share',cat:'api',test:()=>!!navigator.share},
  {name:'File System Access',cat:'api',test:()=>!!window.showOpenFilePicker},
  {name:'Web Locks',cat:'api',test:()=>!!navigator.locks},
  {name:'Broadcast Channel',cat:'api',test:()=>!!window.BroadcastChannel},
  {name:'SharedWorker',cat:'api',test:()=>!!window.SharedWorker},
  {name:'Web Worker',cat:'api',test:()=>!!window.Worker},
  {name:'Payment Request',cat:'api',test:()=>!!window.PaymentRequest},
  {name:'Credential Management',cat:'api',test:()=>!!navigator.credentials},
  {name:'Web Bluetooth',cat:'api',test:()=>!!navigator.bluetooth},
  {name:'Web USB',cat:'api',test:()=>!!navigator.usb},
  {name:'Web Serial',cat:'api',test:()=>!!navigator.serial},
  {name:'Web NFC',cat:'api',test:()=>!!NDEFReader},
  {name:'Web HID',cat:'api',test:()=>!!navigator.hid},
  {name:'Canvas 2D',cat:'api',test:()=>!!document.createElement('canvas').getContext('2d')},
  {name:'OffscreenCanvas',cat:'api',test:()=>!!window.OffscreenCanvas},
  {name:'MediaRecorder',cat:'api',test:()=>!!window.MediaRecorder},
  {name:'MediaDevices',cat:'api',test:()=>!!navigator.mediaDevices},
  {name:'Picture-in-Picture',cat:'api',test:()=>!!document.pictureInPictureEnabled},
  {name:'Presentation API',cat:'api',test:()=>!!navigator.presentation},
  {name:'Web Crypto',cat:'api',test:()=>!!window.crypto&&!!window.crypto.subtle},
  {name:'URL API',cat:'api',test:()=>!!window.URL},
  {name:'URLSearchParams',cat:'api',test:()=>!!window.URLSearchParams},
  {name:'History API',cat:'api',test:()=>!!window.history&&!!history.pushState},
  {name:'Drag & Drop',cat:'api',test:()=>'draggable' in document.createElement('div')},
  {name:'Web Storage',cat:'api',test:()=>!!window.localStorage},
  {name:'Crypto getRandomValues',cat:'api',test:()=>!!window.crypto&&!!crypto.getRandomValues},
  // CSS
  {name:'CSS Grid',cat:'css',test:()=>CSS.supports('display','grid')},
  {name:'CSS Flexbox',cat:'css',test:()=>CSS.supports('display','flex')},
  {name:'CSS Container Queries',cat:'css',test:()=>CSS.supports('container-type','inline-size')},
  {name:'CSS Subgrid',cat:'css',test:()=>CSS.supports('grid-template-columns','subgrid')},
  {name:'CSS Layers',cat:'css',test:()=>CSS.supports('display','grid')&&typeof CSSLayerBlockRule!=='undefined'},
  {name:'CSS Nesting',cat:'css',test:()=>{try{document.createElement('div').style.cssText='&{color:red}';return true}catch(e){return false}}},
  {name:':has() Selector',cat:'css',test:()=>{try{document.querySelector(':has(*)');return true}catch(e){return false}}},
  {name:'CSS :is()',cat:'css',test:()=>{try{document.querySelector(':is(*)');return true}catch(e){return false}}},
  {name:'CSS :where()',cat:'css',test:()=>{try{document.querySelector(':where(*)');return true}catch(e){return false}}},
  {name:'CSS :not() (complex)',cat:'css',test:()=>{try{document.querySelector(':not(.a .b)');return true}catch(e){return false}}},
  {name:'CSS Variables',cat:'css',test:()=>CSS.supports('color','var(--test)')},
  {name:'CSS calc()',cat:'css',test:()=>CSS.supports('width','calc(1px + 1px)')},
  {name:'CSS min()/max()/clamp()',cat:'css',test:()=>CSS.supports('width','clamp(1px,2px,3px)')},
  {name:'CSS aspect-ratio',cat:'css',test:()=>CSS.supports('aspect-ratio','1/1')},
  {name:'CSS gap (flex)',cat:'css',test:()=>CSS.supports('gap','1px')},
  {name:'CSS backdrop-filter',cat:'css',test:()=>CSS.supports('backdrop-filter','blur(1px)')||CSS.supports('-webkit-backdrop-filter','blur(1px)')},
  {name:'CSS scroll-snap',cat:'css',test:()=>CSS.supports('scroll-snap-type','x mandatory')},
  {name:'CSS overscroll-behavior',cat:'css',test:()=>CSS.supports('overscroll-behavior','contain')},
  {name:'CSS content-visibility',cat:'css',test:()=>CSS.supports('content-visibility','auto')},
  {name:'CSS accent-color',cat:'css',test:()=>CSS.supports('accent-color','red')},
  {name:'CSS color-scheme',cat:'css',test:()=>CSS.supports('color-scheme','dark')},
  {name:'CSS @supports',cat:'css',test:()=>!!CSS.supports},
  {name:'CSS Custom Highlight',cat:'css',test:()=>!!CSS.highlights},
  {name:'CSS View Transitions',cat:'css',test:()=>!!document.startViewTransition},
  {name:'CSS @property',cat:'css',test:()=>typeof CSS.registerProperty==='function'},
  {name:'CSS @layer',cat:'css',test:()=>typeof CSSLayerBlockRule!=='undefined'},
  {name:'CSS @container',cat:'css',test:()=>CSS.supports('container-type','inline-size')},
  {name:'CSS @scope',cat:'css',test:()=>typeof CSSScopeRule!=='undefined'},
  // JavaScript
  {name:'ES Modules',cat:'js',test:()=>{try{return 'noModule' in document.createElement('script')}catch(e){return false}}},
  {name:'SharedArrayBuffer',cat:'js',test:()=>!!window.SharedArrayBuffer},
  {name:'Atomics',cat:'js',test:()=>!!window.Atomics},
  {name:'Top-level Await',cat:'js',test:()=>false},
  {name:'Optional Chaining (?.)',cat:'js',test:()=>{try{let a={b:{c:1}};return a?.b?.c===1}catch(e){return false}}},
  {name:'Nullish Coalescing (??)',cat:'js',test:()=>{try{return (null??'default')==='default'}catch(e){return false}}},
  {name:'BigInt',cat:'js',test:()=>typeof BigInt==='function'},
  {name:'Proxy',cat:'js',test:()=>typeof Proxy==='function'},
  {name:'Symbol',cat:'js',test:()=>typeof Symbol==='function'},
  {name:'WeakRef',cat:'js',test:()=>typeof WeakRef==='function'},
  {name:'FinalizationRegistry',cat:'js',test:()=>typeof FinalizationRegistry==='function'},
  {name:'globalThis',cat:'js',test:()=>!!window.globalThis},
  {name:'structuredClone',cat:'js',test:()=>typeof structuredClone==='function'},
  {name:'Temporal',cat:'js',test:()=>!!window.Temporal},
  {name:'Iterator Helpers',cat:'js',test:()=>Array.prototype[Symbol.iterator]&&typeof Array.prototype[Symbol.iterator]().map==='function'},
  {name:'Array.prototype.at()',cat:'js',test:()=>typeof [].at==='function'},
  {name:'Object.hasOwn()',cat:'js',test:()=>typeof Object.hasOwn==='function'},
  {name:'String.prototype.replaceAll()',cat:'js',test:()=>typeof ''.replaceAll==='function'},
  {name:'Promise.allSettled()',cat:'js',test:()=>!!Promise.allSettled},
  {name:'Promise.any()',cat:'js',test:()=>!!Promise.any},
  {name:'AbortController',cat:'js',test:()=>!!window.AbortController},
  {name:'Intl.Segmenter',cat:'js',test:()=>typeof Intl!=='undefined'&&!!Intl.Segmenter},
  {name:'Intl.ListFormat',cat:'js',test:()=>typeof Intl!=='undefined'&&!!Intl.ListFormat},
  {name:'Intl.RelativeTimeFormat',cat:'js',test:()=>typeof Intl!=='undefined'&&!!Intl.RelativeTimeFormat},
  {name:'Intl.NumberFormat (compact)',cat:'js',test:()=>{try{new Intl.NumberFormat('en',{notation:'compact'});return true}catch(e){return false}}},
  {name:'RegExp Named Groups',cat:'js',test:()=>{try{return '2024'.match(/(?<year>\d{4})/)?.groups?.year==='2024'}catch(e){return false}}},
  {name:'RegExp dotAll',cat:'js',test:()=>{try{return 'a\nb'.test(new RegExp('.','s'))}catch(e){return false}}},
  {name:'RegExp lookbehind',cat:'js',test:()=>{try{return '$100'.match(/(?<=\$)\d+/)?.[0]==='100'}catch(e){return false}}},
  // Media
  {name:'AVIF Support',cat:'media',test:()=>{const c=document.createElement('canvas');c.width=c.height=1;return c.toDataURL('image/avif').indexOf('data:image/avif')===0}},
  {name:'WebP Support',cat:'media',test:()=>{const c=document.createElement('canvas');c.width=c.height=1;return c.toDataURL('image/webp').indexOf('data:image/webp')===0}},
  {name:'WebM Support',cat:'media',test:()=>{const v=document.createElement('video');return v.canPlayType('video/webm')!==''}},
  {name:'HEVC Support',cat:'media',test:()=>{const v=document.createElement('video');return v.canPlayType('video/mp4; codecs="hvc1"')!==''}},
  {name:'Opus Support',cat:'media',test:()=>{const v=document.createElement('video');return v.canPlayType('audio/opus')!==''}},
  {name:'HLS Support',cat:'media',test:()=>{const v=document.createElement('video');return v.canPlayType('application/vnd.apple.mpegurl')!==''}},
  {name:'Media Source Extensions',cat:'media',test:()=>!!window.MediaSource},
  {name:'Encrypted Media Extensions',cat:'media',test:()=>!!navigator.requestMediaKeySystemAccess},
  // Security
  {name:'Secure Context',cat:'security',test:()=>window.isSecureContext},
  {name:'Content Security Policy',cat:'security',test:()=>!!document.querySelector('meta[http-equiv="Content-Security-Policy"]')||!!window.cspViolations},
  {name:'Credential Management',cat:'security',test:()=>!!navigator.credentials},
  {name:'Web Authentication',cat:'security',test:()=>!!window.PublicKeyCredential},
  {name:'Trusted Types',cat:'security',test:()=>!!window.trustedTypes},
  {name:'Permissions API',cat:'security',test:()=>!!navigator.permissions},
  {name:'Cross-Origin Isolated',cat:'security',test:()=>window.crossOriginIsolated===true},
  {name:'SRI Support',cat:'security',test:()=>true},
];

let results = [];
let currentFilter = 'all';

function runTests() {
  results = [];
  features.forEach(f => {
    let supported = false;
    try { supported = f.test(); } catch(e) { supported = false; }
    results.push({name:f.name, cat:f.cat, supported:!!supported});
  });
  renderResults();
  renderBrowserInfo();
  renderSummary();
}

function renderBrowserInfo() {
  const info = [
    {label:'User-Agent',value:navigator.userAgent},
    {label:'平台',value:navigator.platform||'N/A'},
    {label:'语言',value:navigator.language},
    {label:'屏幕分辨率',value:`${screen.width}×${screen.height}`},
    {label:'设备像素比',value:window.devicePixelRatio},
    {label:'颜色深度',value:`${screen.colorDepth}bit`},
    {label:'在线状态',value:navigator.onLine?'在线':'离线'},
    {label:'Cookie启用',value:navigator.cookieEnabled?'是':'否'},
    {label:'触摸支持',value:'ontouchstart' in window?'是':'否'},
    {label:'最大触控点',value:navigator.maxTouchPoints||0},
    {label:'逻辑处理器',value:navigator.hardwareConcurrency||'N/A'},
    {label:'设备内存',value:navigator.deviceMemory?navigator.deviceMemory+'GB':'N/A'},
  ];
  document.getElementById('browserInfo').innerHTML = info.map(i=>
    `<div class="info-item"><div class="info-label">${i.label}</div><div class="info-value">${i.value}</div></div>`
  ).join('');
}

function renderSummary() {
  const total = results.length;
  const supported = results.filter(r=>r.supported).length;
  const unsupported = total - supported;
  document.getElementById('summaryBar').innerHTML = `
    <div class="summary-item"><div class="num">${total}</div><div class="label">总检测项</div></div>
    <div class="summary-item"><div class="num" style="color:#10b981">${supported}</div><div class="label">支持</div></div>
    <div class="summary-item"><div class="num" style="color:#ef4444">${unsupported}</div><div class="label">不支持</div></div>
    <div class="summary-item"><div class="num" style="color:#f59e0b">${Math.round(supported/total*100)}%</div><div class="label">支持率</div></div>
  `;
}

function renderResults() {
  const search = document.getElementById('searchInput').value.toLowerCase();
  const filtered = results.filter(r => {
    if (currentFilter !== 'all' && r.cat !== currentFilter) return false;
    if (search && !r.name.toLowerCase().includes(search)) return false;
    return true;
  });
  document.getElementById('featureList').innerHTML = filtered.map(r =>
    `<div class="feature-item">
      <div><span class="feature-name">${r.name}</span><span class="feature-cat">[${r.cat.toUpperCase()}]</span></div>
      <div class="feature-status ${r.supported?'status-yes':'status-no'}">${r.supported?'✓ 支持':'✗ 不支持'}</div>
    </div>`
  ).join('') || '<div style="color:#64748b;text-align:center;padding:20px">未找到匹配的特性</div>';
}

function exportJSON() {
  const data = {
    timestamp: new Date().toISOString(),
    userAgent: navigator.userAgent,
    summary: {
      total: results.length,
      supported: results.filter(r=>r.supported).length,
      unsupported: results.filter(r=>!r.supported).length
    },
    features: results
  };
  const blob = new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'browser-features-'+Date.now()+'.json';
  a.click();
}

function copyResult() {
  const text = results.map(r=>`${r.supported?'✓':'✗'} ${r.name} [${r.cat}]`).join('\n');
  navigator.clipboard.writeText(text).then(()=>alert('已复制到剪贴板！')).catch(()=>{
    const ta=document.createElement('textarea');ta.value=text;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);alert('已复制！');
  });
}

function rerunTest() { runTests(); }

// Filters
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    currentFilter = btn.dataset.filter;
    renderResults();
  });
});

document.getElementById('searchInput').addEventListener('input', renderResults);

function toggleFaq(el) {
  el.classList.toggle('open');
  el.nextElementSibling.classList.toggle('open');
}

// Keyboard shortcuts
document.addEventListener('keydown', function(e) {
  if(e.ctrlKey && e.key==='Enter') { rerunTest(); e.preventDefault(); }
  if(e.ctrlKey && e.shiftKey && e.key==='C') { copyResult(); e.preventDefault(); }
});

// Auto-run
runTests();
</script>
<div class="footer" style="text-align:center;color:#64748b;font-size:.85rem;margin-top:32px;padding-top:20px;border-top:1px solid rgba(148,163,184,.1)">
<p><a href="/" style="color:#64748b">首页</a> | <a href="/privacy-policy/" style="color:#64748b">隐私政策</a> | <a href="/terms-of-service/" style="color:#64748b">服务条款</a></p>
<p style="margin-top:8px">© 2026 Free ToolBase - 纯前端本地运行·不上传服务器</p>
</div>
</body>
</html>
