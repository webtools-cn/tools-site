</footer>
<script>
const TEMPLATES=[
{name:'所有书名',path:'$.store.book[*].title'},
{name:'第一本书',path:'$.store.book[0]'},
{name:'所有价格',path:'$..price'},
{name:'自行车颜色',path:'$.store.bicycle.color'},
{name:'最后一本书',path:'$.store.book[(@.length-1)]'},
{name:'所有分类',path:'$.store.book[*].category'},
{name:'过滤:价格>10',path:'$.store.book[?(@.price>10)]'},
{name:'过滤:小说类',path:'$.store.book[?(@.category=="fiction")]'},
];
function renderTemplates(){
const g=document.getElementById('templateGrid');
g.innerHTML=TEMPLATES.map((t,i)=>`<button class="template-btn" onclick="useTemplate(${i})"><span class="tpl-name">${t.name}</span><span class="tpl-path">${t.path}</span></button>`).join('');
}
function useTemplate(i){
document.getElementById('pathInput').value=TEMPLATES[i].path;
runQuery();
}
// Simple JSONPath implementation
function queryJsonPath(obj,path){
if(!path.startsWith('$'))return[];
const tokens=tokenize(path.slice(1));
return resolve(obj,tokens,0);
}
function tokenize(path){
const tokens=[];
let i=0;
while(i<path.length){
if(path[i]==='.'&&path[i+1]==='.'){
tokens.push({type:'recurse'});i+=2;
}else if(path[i]==='.'){
i++;
let key='';
while(i<path.length&&path[i]!=='.'&&path[i]!=='['){
key+=path[i];i++;
}
if(key==='*')tokens.push({type:'wildcard'});
else if(key)tokens.push({type:'key',value:key});
}else if(path[i]==='['){
i++;
if(path[i]==='*'){tokens.push({type:'wildcard'});i++;if(path[i]===']')i++;}
else if(path[i]==='?'){
i++;let expr='';
let depth=0;
while(i<path.length&&!(path[i]===')'&&depth===1)){
if(path[i]==='(')depth++;
if(path[i]===')')depth--;
expr+=path[i];i++;
}
i++;
tokens.push({type:'filter',expr:expr});
}else{
let idx='';
while(i<path.length&&path[i]!==']'){idx+=path[i];i++;}
i++;
if(idx.startsWith('@')){
tokens.push({type:'script',expr:idx});
}else if(idx.includes(':')){
const parts=idx.split(':').map(Number);
tokens.push({type:'slice',start:parts[0]||0,end:parts[1],step:parts[2]||1});
}else{
tokens.push({type:'index',value:parseInt(idx)});
}
}
}else{i++;}
}
return tokens;
}
function resolve(obj,tokens,ti){
if(ti>=tokens.length)return[{path:'$',value:obj}];
const token=tokens[ti];
const results=[];
if(token.type==='key'){
if(obj&&typeof obj==='object'&&!Array.isArray(obj)){
if(token.value in obj){
const sub=resolve(obj[token.value],tokens,ti+1);
sub.forEach(s=>results.push({path:s.path,value:s.value}));
}
}
}else if(token.type==='index'){
if(Array.isArray(obj)&&token.value<obj.length){
const sub=resolve(obj[token.value],tokens,ti+1);
sub.forEach(s=>results.push({path:s.path,value:s.value}));
}
}else if(token.type==='wildcard'){
if(Array.isArray(obj)){
obj.forEach((item,i)=>{
const sub=resolve(item,tokens,ti+1);
sub.forEach(s=>results.push({path:s.path,value:s.value}));
});
}else if(obj&&typeof obj==='object'){
Object.keys(obj).forEach(k=>{
const sub=resolve(obj[k],tokens,ti+1);
sub.forEach(s=>results.push({path:s.path,value:s.value}));
});
}
}else if(token.type==='recurse'){
results.push(...resolve(obj,tokens,ti+1));
function recurse(o){
if(Array.isArray(o)){o.forEach(item=>{results.push(...resolve(item,tokens,ti+1));recurse(item);});}
else if(o&&typeof o==='object'){Object.keys(o).forEach(k=>{results.push(...resolve(o[k],tokens,ti+1));recurse(o[k]);});}
}
recurse(obj);
}else if(token.type==='filter'){
if(Array.isArray(obj)){
const expr=token.expr.replace(/@/g,'item');
obj.forEach(item=>{
try{if(new Function('item',`return ${expr}`)(item)){
results.push(...resolve(item,tokens,ti+1));
}}catch(e){}
});
}
}else if(token.type==='slice'){
if(Array.isArray(obj)){
const s=token.start<0?obj.length+token.start:token.start;
const e=token.end!==undefined?(token.end<0?obj.length+token.end:token.end):obj.length;
for(let i=s;i<e;i+=token.step){
results.push(...resolve(obj[i],tokens,ti+1));
}
}
}
return results;
}
function runQuery(){
const jsonStr=document.getElementById('jsonInput').value;
const pathStr=document.getElementById('pathInput').value;
const resultArea=document.getElementById('resultArea');
if(!jsonStr.trim()||!pathStr.trim()){resultArea.innerHTML='<p style="color:#64748b">请输入JSON数据和JSONPath表达式</p>';return;}
try{
const obj=JSON.parse(jsonStr);
const results=queryJsonPath(obj,pathStr);
if(results.length===0){
resultArea.innerHTML='<p style="color:#64748b">未找到匹配的数据</p>';
}else{
let html=`<div class="match-count">匹配数: <strong>${results.length}</strong></div>`;
html+='<div class="result-box">';
results.forEach((r,i)=>{
const val=typeof r.value==='string'?`<span class="str">"${esc(r.value)}"</span>`:
typeof r.value==='number'?`<span class="num">${r.value}</span>`:
typeof r.value==='boolean'?`<span class="bool">${r.value}</span>`:
r.value===null?`<span class="null">null</span>`:
esc(JSON.stringify(r.value,null,2));
html+=`<div style="margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid rgba(148,163,184,.05)"><span style="color:#64748b;font-size:.75rem">[${i}]</span> ${val}</div>`;
});
html+='</div>';
resultArea.innerHTML=html;
}
}catch(e){
resultArea.innerHTML=`<div class="error-msg">${e.message.includes('JSON')?'JSON解析错误: ':'查询错误: '}${esc(e.message)}</div>`;
}
}
function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function toggleFaq(el){el.classList.toggle('open');el.nextElementSibling.classList.toggle('open')}
renderTemplates();runQuery();
</script>
</body>
</html>