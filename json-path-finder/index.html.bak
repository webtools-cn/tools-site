  "mainEntity": [
    {
      "@type": "Question",
      "name": "什么是JSONPath？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "JSONPath是用于查询JSON数据的表达式语言，类似于XPath对XML的作用。它使用点号和方括号语法来定位JSON中的特定节点，如$.store.book[0].title。"
      }
    },
    {
      "@type": "Question",
      "name": "JSONPath常用语法有哪些？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "$表示根节点，.表示子节点，[]表示数组索引或条件，*表示通配符，..表示递归下降，[?()]表示过滤表达式。"
      }
    },
    {
