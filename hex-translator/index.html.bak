<script>
function convert(){
var input=document.getElementById('inputArea').value;
var mode=document.getElementById('mode').value;
var sep=document.getElementById('separator').value;
var errEl=document.getElementById('errorMsg');
var resPanel=document.getElementById('resultPanel');
var output=document.getElementById('outputArea');
if(!input){errEl.style.display='none';resPanel.style.display='none';return;}
errEl.style.display='none';resPanel.style.display='block';
try{
var result='';
if(mode==='text2hex'){
var hexArr=[];
for(var i=0;i<input.length;i++){
var code=input.charCodeAt(i);
if(code>255)hexArr.push(('0000'+code.toString(16)).slice(-4));
else hexArr.push(('0'+code.toString(16)).slice(-2));
}
if(sep==='space')result=hexArr.join(' ');
else if(sep==='comma')result=hexArr.join(',');
else if(sep==='0x')result=hexArr.map(function(h){return'0x'+h;}).join(' ');
else result=hexArr.join('');
}else if(mode==='hex2text'){
var hexStr=input.replace(/0x/gi,'').replace(/[\s,]/g,'');
if(!/^[0-9a-fA-F]+$/.test(hexStr)){errEl.textContent='无效的十六进制输入';errEl.style.display='block';resPanel.style.display='none';return;}
var chars=[];
for(var i=0;i<hexStr.length;i+=2){
var byte=parseInt(hexStr.substr(i,2),16);
if(byte>0||i+2<=hexStr.length)chars.push(String.fromCharCode(byte));
}
result=chars.join('');
}else if(mode==='hex2dec'){
var hexStr=input.replace(/0x/gi,'').replace(/[\s,]/g,'');
if(!/^[0-9a-fA-F]+$/.test(hexStr)){errEl.textContent='无效的十六进制输入';errEl.style.display='block';resPanel.style.display='none';return;}
var nums=hexStr.match(/.{1,2}/g)||[];
result=nums.map(function(h){return parseInt(h,16);}).join(sep==='comma'?',':sep==='0x'?h+' ':' ');
}else if(mode==='dec2hex'){
var nums=input.split(/[\s,]+/).filter(Boolean);
result=nums.map(function(n){
var v=parseInt(n,10);
if(isNaN(v))return'[invalid]';
return('0'+v.toString(16)).slice(-2).toUpperCase();
}).join(sep==='space'?' ':sep==='comma'?',':sep==='0x'?' 0x':'');
}
output.value=result;
}catch(e){errEl.textContent='转换错误: '+e.message;errEl.style.display='block';}
}

function loadExample(){
var mode=document.getElementById('mode').value;
if(mode==='text2hex')document.getElementById('inputArea').value='Hello World';
else if(mode==='hex2text')document.getElementById('inputArea').value='48 65 6C 6C 6F 20 57 6F 72 6C 64';
else if(mode==='hex2dec')document.getElementById('inputArea').value='FF 0A 1F';
else document.getElementById('inputArea').value='255 10 31';
convert();
}

function clearInput(){document.getElementById('inputArea').value='';document.getElementById('errorMsg').style.display='none';document.getElementById('resultPanel').style.display='none';}
function copyResult(){var t=document.getElementById('outputArea').value;if(t)navigator.clipboard.writeText(t).catch(function(){});}
function swapIO(){var i=document.getElementById('inputArea');var o=document.getElementById('outputArea');var tmp=i.value;i.value=o.value;o.value=tmp;convert();}
function downloadResult(){var t='十六进制转换结果\n'+'='.repeat(30)+'\n\n输入: '+document.getElementById('inputArea').value+'\n输出: '+document.getElementById('outputArea').value;var blob=new Blob([t],{type:'text/plain;charset=utf-8'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='hex-conversion.txt';a.click();}
document.addEventListener('keydown',function(e){if(e.ctrlKey&&e.key==='Enter'){convert();e.preventDefault();}if(e.ctrlKey&&e.shiftKey&&e.key==='C'){copyResult();e.preventDefault();}});
window.addEventListener('load',function(){loadExample();});
</script>
