  <div class="ad-slot" style="margin-top:24px"><ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-5998441792679372" data-ad-slot="XXXXXXX" data-ad-format="horizontal" data-full-width-responsive="true"></ins></div>
  <div class="seo-content">
    <h2>JSON Pointerи·Ҝеҫ„жөҸи§ҲеҷЁиғҪеҒҡд»Җд№Ҳпјҹ</h2>
    <p>JSON Pointerи·Ҝеҫ„жөҸи§ҲеҷЁжҳҜдёҖж¬ҫе…Қиҙ№еңЁзәҝејҖеҸ‘иҖ…е·Ҙе…·пјҢиҫ“е…ҘJSONж•°жҚ®еҗҺиҮӘеҠЁйҒҚеҺҶз”ҹжҲҗжүҖжңүRFC 6901ж ҮеҮҶзҡ„JSON Pointerи·Ҝеҫ„пјҢжҳҫзӨәжҜҸдёӘи·Ҝеҫ„еҜ№еә”зҡ„еҖје’Ңзұ»еһӢгҖӮж”ҜжҢҒи·Ҝеҫ„жҗңзҙўгҖҒзұ»еһӢзӯӣйҖүгҖҒеҖјжҸҗеҸ–гҖҒй”®еҗҚиҪ¬д№үзӯүеҠҹиғҪгҖӮйҖӮз”ЁдәҺAPIејҖеҸ‘и°ғиҜ•гҖҒJSON Patchзј–еҶҷгҖҒJSON Schemaи·Ҝеҫ„еј•з”ЁзӯүеңәжҷҜгҖӮжүҖжңүеӨ„зҗҶеңЁжөҸи§ҲеҷЁжң¬ең°е®ҢжҲҗпјҢж•°жҚ®з»қдёҚдёҠдј жңҚеҠЎеҷЁгҖӮ</p>
    <h2>ж ёеҝғеҠҹиғҪ</h2>
    <ul>
      <li><strong>иҮӘеҠЁи·Ҝеҫ„з”ҹжҲҗ</strong>пјҡйҖ’еҪ’йҒҚеҺҶJSONпјҢз”ҹжҲҗжүҖжңүRFC 6901ж ҮеҮҶPointerи·Ҝеҫ„</li>
      <li><strong>зұ»еһӢзӯӣйҖү</strong>пјҡжҢүstring/number/boolean/object/array/nullзӯӣйҖүи·Ҝеҫ„</li>
      <li><strong>и·Ҝеҫ„жҗңзҙў</strong>пјҡе®һж—¶жҗңзҙўи·Ҝеҫ„жҲ–еҖјеҶ…е®№</li>
      <li><strong>еҖјжҸҗеҸ–</strong>пјҡзӮ№еҮ»и·Ҝеҫ„жҹҘзңӢе®Ңж•ҙеҖјпјҢдёҖй”®еӨҚеҲ¶</li>
      <li><strong>иҪ¬д№үе·Ҙе…·</strong>пјҡй”®еҗҚиҮӘеҠЁиҪ¬д№үпјҲ~вҶ’~0пјҢ/вҶ’~1пјү</li>
    </ul>
    <h2>дҪҝз”Ёж•ҷзЁӢ</h2>
    <p>1. еңЁиҫ“е…ҘжЎҶзІҳиҙҙJSONж•°жҚ®пјҢжҲ–зӮ№еҮ»"еҠ иҪҪзӨәдҫӢ"гҖӮ</p>
    <p>2. зӮ№еҮ»"жөҸи§Ҳи·Ҝеҫ„"иҮӘеҠЁз”ҹжҲҗжүҖжңүPointerи·Ҝеҫ„еҲ—иЎЁгҖӮ</p>
    <p>3. дҪҝз”ЁжҗңзҙўжЎҶе’Ңзұ»еһӢзӯӣйҖүеҝ«йҖҹе®ҡдҪҚзӣ®ж Үи·Ҝеҫ„гҖӮ</p>
    <p>4. зӮ№еҮ»д»»ж„Ҹи·Ҝеҫ„жҹҘзңӢиҜҰз»ҶеҖје№¶еӨҚеҲ¶гҖӮ</p>
    <h2>еә”з”ЁеңәжҷҜ</h2>
    <h3>еңәжҷҜ1пјҡзј–еҶҷJSON Patch</h3>
    <p>ејҖеҸ‘иҖ…зј–еҶҷJSON Patchж—¶пјҢз”ЁжӯӨе·Ҙе…·еҝ«йҖҹжҹҘжүҫзӣ®ж Үеӯ—ж®өзҡ„Pointerи·Ҝеҫ„пјҢйҒҝе…ҚжүӢеҠЁжӢјжҺҘеҮәй”ҷгҖӮ</p>
    <h3>еңәжҷҜ2пјҡJSON Schemaеј•з”Ё</h3>
    <p>зј–еҶҷJSON Schemaзҡ„$refеј•з”Ёж—¶пјҢйңҖиҰҒзІҫзЎ®зҡ„Pointerи·Ҝеҫ„жҢҮеҗ‘еӯҗSchemaе®ҡд№үгҖӮ</p>
    <h3>еңәжҷҜ3пјҡAPIи°ғиҜ•</h3>
    <p>и°ғиҜ•REST APIиҝ”еӣһзҡ„еӨҚжқӮJSONж—¶пјҢеҝ«йҖҹе®ҡдҪҚеөҢеҘ—еӯ—ж®өзҡ„и·Ҝеҫ„е’ҢеҖјгҖӮ</p>
    <h2>жү©еұ•зҹҘиҜҶ</h2>
    <p>JSON PointerпјҲRFC 6901пјүжҳҜIETFе®ҡд№үзҡ„JSONж–ҮжЎЈеҜ»еқҖж ҮеҮҶпјҢз”Ёз©әеӯ—з¬ҰдёІ""иЎЁзӨәж•ҙдёӘж–ҮжЎЈпјҢз”Ё/еҲҶйҡ”зҡ„и·Ҝеҫ„еј•з”ЁеӯҗеҖјгҖӮзү№ж®Ҡеӯ—з¬Ұ~е’Ң/еңЁй”®еҗҚдёӯйңҖиҪ¬д№үпјҡ~еҸҳдёә~0пјҢ/еҸҳдёә~1гҖӮJSON PointerжҳҜJSON PatchпјҲRFC 6902пјүе’ҢJSON Schemaзҡ„ж ёеҝғдҫқиө–пјҢз”ЁдәҺе®ҡдҪҚж“ҚдҪңзӣ®ж ҮгҖӮдёҺJSONPathзӣёжҜ”пјҢPointerжӣҙз®ҖеҚ•дҪҶеҸӘиғҪеј•з”ЁеҚ•дёӘзЎ®е®ҡдҪҚзҪ®пјҢдёҚж”ҜжҢҒиҝҮж»Өе’ҢйҖҡй…Қз¬ҰгҖӮ</p>
  </div>
  <h2>вқ“ еёёи§Ғй—®йўҳ</h2>
  <div class="faq-item"><h3>д»Җд№ҲжҳҜJSON Pointerпјҹ</h3><p>RFC 6901е®ҡд№үзҡ„JSONж–ҮжЎЈеҜ»еқҖж ҮеҮҶпјҢз”Ё/еҲҶйҡ”и·Ҝеҫ„еј•з”ЁеҖјпјҢеҰӮ/user/nameгҖӮ</p></div>
  <div class="faq-item"><h3>зү№ж®Ҡеӯ—з¬ҰеҰӮдҪ•иҪ¬д№үпјҹ</h3><p>~иҪ¬д№үдёә~0пјҢ/иҪ¬д№үдёә~1гҖӮдҫӢеҰӮй”®еҗҚa/b~cеҸҳдёә/a~1b~0cгҖӮ</p></div>
  <div class="faq-item"><h3>е’ҢJSONPathзҡ„еҢәеҲ«пјҹ</h3><p>JSON PointerжҳҜRFCж ҮеҮҶпјҢзІҫзЎ®еј•з”ЁеҚ•дёӘеҖјгҖӮJSONPathж”ҜжҢҒиҝҮж»ӨйҖҡй…Қз¬ҰпјҢдҪҶйқһж ҮеҮҶгҖӮ</p></div>
  <div class="faq-item"><h3>з©әеӯ—з¬ҰдёІPointerд»ЈиЎЁд»Җд№Ҳпјҹ</h3><p>з©әеӯ—з¬ҰдёІ""д»ЈиЎЁж•ҙдёӘJSONж–ҮжЎЈзҡ„ж №гҖӮ</p></div>
  <div class="faq-item"><h3>ж•°з»„еҰӮдҪ•еј•з”Ёпјҹ</h3><p>ж•°з»„з”Ёж•°еӯ—зҙўеј•пјҢеҰӮ/items/0иЎЁзӨәз¬¬дёҖдёӘе…ғзҙ пјҢ/-иЎЁзӨәжң«е°ҫиҝҪеҠ дҪҚзҪ®гҖӮ</p></div>
  <div class="faq-item"><h3>ж•°жҚ®дјҡдёҠдј еҲ°жңҚеҠЎеҷЁеҗ—пјҹ</h3><p>дёҚдјҡгҖӮжүҖжңүеӨ„зҗҶеңЁжөҸи§ҲеҷЁжң¬ең°е®ҢжҲҗгҖӮ</p></div>
  <div class="ad-slot" style="margin-top:24px"><ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-5998441792679372" data-ad-slot="XXXXXXX" data-ad-format="horizontal" data-full-width-responsive="true"></ins></div>
</div>
<div class="footer container">
  <div style="margin-bottom:12px"><a href="../index.html">йҰ–йЎө</a><a href="../index.html">е…ЁйғЁе·Ҙе…·</a><a href="mailto:dexshuang@google.com">иҒ”зі»жҲ‘д»¬</a>
    <a href="https://github.com/webtools-cn/tools-site" target="_blank" rel="noopener">GitHub</a><a href="../privacy/">йҡҗз§Ғж”ҝзӯ–</a><a href="../terms/">жңҚеҠЎжқЎж¬ҫ</a><a href="../about/">е…ідәҺжҲ‘д»¬</a><a href="../en/json-pointer-explorer/">EN</a></div>
  <p>JSON Pointerи·Ҝеҫ„жөҸи§ҲеҷЁ В· зәҜеүҚз«Ҝжң¬ең°еӨ„зҗҶ В· ж•°жҚ®з»қдёҚдёҠдј жңҚеҠЎеҷЁ</p>
  <p style="margin-top:8px;color:#475569;font-size:.8rem">й—®йўҳеҸҚйҰҲ: dexshuang@google.com</p>
</div>
<script>
(function(){
var allPointers=[];
var currentFilter='all';
window.loadExample=function(){
  document.getElementById('jsonInput').value=JSON.stringify({"user":{"name":"еј дёү","age":28,"address":{"city":"еҢ—дә¬","district":"жө·ж·Җ"}},"skills":["JavaScript","Python","Go"],"active":true,"metadata":null},null,2);
  explorePointers();
};
window.explorePointers=function(){
  var errEl=document.getElementById('inputError');
  errEl.style.display='none';
  var raw=document.getElementById('jsonInput').value.trim();
  if(!raw){errEl.textContent='иҜ·иҫ“е…ҘJSONж•°жҚ®';errEl.style.display='block';return;}
  var data;
  try{data=JSON.parse(raw);}catch(e){errEl.textContent='JSONиҜӯжі•й”ҷиҜҜ: '+e.message;errEl.style.display='block';return;}
  allPointers=[];
  traverse(data,'');
  renderPointers();
  var typeCounts={};
  allPointers.forEach(function(p){typeCounts[p.type]=(typeCounts[p.type]||0)+1;});
  var statsText='жҖ»и·Ҝеҫ„: '+allPointers.length;
  Object.keys(typeCounts).forEach(function(t){statsText+=' | '+t+': '+typeCounts[t];});
  document.getElementById('stats').textContent=statsText;
};
function traverse(obj,path){
  var type=getType(obj);
  allPointers.push({path:path,value:obj,type:type});
  if(type==='object'){
    Object.keys(obj).forEach(function(k){
      var escaped=String(k).replace(/~/g,'~0').replace(/\//g,'~1');
      traverse(obj[k],path+'/'+escaped);
    });
  }else if(type==='array'){
    obj.forEach(function(item,i){traverse(item,path+'/'+i);});
  }
}
function getType(v){
  if(v===null)return 'null';
  if(Array.isArray(v))return 'array';
  return typeof v;
}
function renderPointers(){
  var listEl=document.getElementById('pointerList');
  listEl.innerHTML='';
  var search=document.getElementById('searchBox').value.toLowerCase();
  var filtered=allPointers.filter(function(p){
    if(currentFilter!=='all'&&p.type!==currentFilter)return false;
    if(search){
      var valStr=typeof p.value==='object'?JSON.stringify(p.value):String(p.value);
      return p.path.toLowerCase().indexOf(search)!==-1||valStr.toLowerCase().indexOf(search)!==-1;
    }
    return true;
  });
  filtered.forEach(function(p,i){
    var div=document.createElement('div');
    div.className='pointer-item';
    var valPreview='';
    if(p.type==='object')valPreview='{...} ('+Object.keys(p.value).length+'й”®)';
    else if(p.type==='array')valPreview='[...] ('+p.value.length+'йЎ№)';
    else valPreview=String(p.value).substring(0,50);
    div.innerHTML='<div><span class="path">'+escapeHtml(p.path||'""(ж №)')+'</span><span class="value-type" style="margin-left:8px">['+p.type+']</span></div><div class="value-preview">'+escapeHtml(valPreview)+'</div>';
    div.onclick=function(){showDetail(p);};
    listEl.appendChild(div);
  });
  if(filtered.length===0)listEl.innerHTML='<p style="color:#64748b;text-align:center;padding:20px">ж— еҢ№й…Қз»“жһң</p>';
}
window.setFilter=function(type,btn){
  currentFilter=type;
  document.querySelectorAll('.filter-btn').forEach(function(b){b.classList.remove('active');});
  btn.classList.add('active');
  renderPointers();
};
window.filterPointers=function(){renderPointers();};
function showDetail(p){
  var panel=document.getElementById('detailPanel');
  panel.style.display='block';
  var content=document.getElementById('detailContent');
  var valStr=p.type==='object'||p.type==='array'?JSON.stringify(p.value,null,2):String(p.value);
  content.innerHTML='<p style="color:#94a3b8;font-size:.85rem;margin-bottom:4px">и·Ҝеҫ„:</p><div class="code-block">'+escapeHtml(p.path||'""(ж №)')+'</div><p style="color:#94a3b8;font-size:.85rem;margin:12px 0 4px">зұ»еһӢ: '+p.type+'</p><p style="color:#94a3b8;font-size:.85rem;margin-bottom:4px">еҖј:</p><div class="code-block">'+escapeHtml(valStr)+'</div>';
  window._detailValue=valStr;
}
window.copyDetailValue=function(){
  if(window._detailValue&&navigator.clipboard)navigator.clipboard.writeText(window._detailValue).then(showMsg);
};
window.copyAllPointers=function(){
  if(!allPointers.length)return;
  var text=allPointers.map(function(p){return p.path;}).join('\n');
  if(navigator.clipboard)navigator.clipboard.writeText(text).then(showMsg);
};
window.downloadPointers=function(){
  if(!allPointers.length)return;
  var text=allPointers.map(function(p){
    var val=p.type==='object'||p.type==='array'?JSON.stringify(p.value):String(p.value);
    return p.path+'\t'+p.type+'\t'+val;
  }).join('\n');
  var b=new Blob([text],{type:'text/plain'});
  var a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='json-pointers.tsv';a.click();
};
window.updateEscape=function(){
  var input=document.getElementById('escapeInput').value;
  var el=document.getElementById('escapeResult');
  if(!input){el.textContent='иҪ¬д№үз»“жһңе°ҶжҳҫзӨәеңЁиҝҷйҮҢ';return;}
  var escaped='/'+String(input).replace(/~/g,'~0').replace(/\//g,'~1');
  el.textContent='еҺҹе§Ӣй”®еҗҚ: '+input+'\nиҪ¬д№үPointer: '+escaped;
};
window.clearAll=function(){
  document.getElementById('jsonInput').value='';
  document.getElementById('pointerList').innerHTML='';
  document.getElementById('stats').textContent='';
  document.getElementById('inputError').style.display='none';
  document.getElementById('detailPanel').style.display='none';
  document.getElementById('searchBox').value='';
};
function escapeHtml(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function showMsg(){var m=document.createElement('div');m.textContent='вң“ е·ІеӨҚеҲ¶';m.style.cssText='position:fixed;top:20px;right:20px;background:rgba(34,197,94,.2);color:#4ade80;padding:8px 16px;border-radius:8px;font-size:.85rem;z-index:9999;border:1px solid rgba(34,197,94,.3)';document.body.appendChild(m);setTimeout(function(){m.remove();},2000);}
document.addEventListener('keydown',function(e){if(e.ctrlKey&&e.key==='Enter'){explorePointers();e.preventDefault();}});
loadExample();
})();
</script>
