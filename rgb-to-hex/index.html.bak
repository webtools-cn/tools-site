<script>
let rhMode_='rgb2hex';
function rhMode(m){
  rhMode_=m;
  document.querySelectorAll('.rh-mode-tab').forEach((t,i)=>{
    t.classList.toggle('active',(m==='rgb2hex'&&i===0)||(m==='hex2rgb'&&i===1));
  });
  document.getElementById('rhRgb2hex').style.display=m==='rgb2hex'?'':'none';
  document.getElementById('rhHex2rgb').style.display=m==='hex2rgb'?'':'none';
  rhCalc();
}
function rhToggleAlpha(){
  document.getElementById('rhAlphaField').style.display=document.getElementById('rhAlpha').checked?'':'none';
  rhCalc();
}
function rhCalc(){
  const preview=document.getElementById('rhPreview');
  const result=document.getElementById('rhResult');
  const rgbVal=document.getElementById('rhRgbVal');
  const hslVal=document.getElementById('rhHslVal');
  const isEn=document.querySelector('html').lang==='en';
  if(rhMode_==='rgb2hex'){
    let r=Math.max(0,Math.min(255,parseInt(document.getElementById('rhR').value)||0));
    let g=Math.max(0,Math.min(255,parseInt(document.getElementById('rhG').value)||0));
    let b=Math.max(0,Math.min(255,parseInt(document.getElementById('rhB').value)||0));
    const hasAlpha=document.getElementById('rhAlpha').checked;
    let a=hasAlpha?Math.max(0,Math.min(1,parseFloat(document.getElementById('rhA').value)||0)):1;
    const toHex=(n)=>Math.round(n).toString(16).padStart(2,'0').toUpperCase();
    let hex='#'+toHex(r)+toHex(g)+toHex(b);
    let rgba='rgb('+r+','+g+','+b+')';
    if(hasAlpha){
      hex+=toHex(Math.round(a*255));
      rgba='rgba('+r+','+g+','+b+','+a.toFixed(2)+')';
    }
    result.textContent=hex;
    rgbVal.textContent=rgba;
    preview.style.background=rgba;
    // Calculate HSL
    const rn=r/255,gn=g/255,bn=b/255;
    const max=Math.max(rn,gn,bn),min=Math.min(rn,gn,bn);
    let h=0,s=0,l=(max+min)/2;
    if(max!==min){
      const d=max-min;
      s=l>0.5?d/(2-max-min):d/(max+min);
      if(max===rn)h=((gn-bn)/d+(gn<bn?6:0))/6;
      else if(max===gn)h=((bn-rn)/d+2)/6;
      else h=((rn-gn)/d+4)/6;
    }
    hslVal.textContent='hsl('+Math.round(h*360)+','+Math.round(s*100)+'%,'+Math.round(l*100)+'%)';
  }else{
    let hex=document.getElementById('rhHex').value.trim();
    if(!hex.startsWith('#'))hex='#'+hex;
    // Parse hex
    const clean=hex.replace('#','');
    let r,g,b,a=1;
    if(clean.length===3){
      r=parseInt(clean[0]+clean[0],16);
      g=parseInt(clean[1]+clean[1],16);
      b=parseInt(clean[2]+clean[2],16);
    }else if(clean.length===6){
      r=parseInt(clean.substr(0,2),16);
      g=parseInt(clean.substr(2,2),16);
      b=parseInt(clean.substr(4,2),16);
    }else if(clean.length===8){
      r=parseInt(clean.substr(0,2),16);
      g=parseInt(clean.substr(2,2),16);
      b=parseInt(clean.substr(4,2),16);
      a=parseInt(clean.substr(6,2),16)/255;
    }else{
      result.textContent=isEn?'Invalid hex':'无效Hex码';
      rgbVal.textContent='';
      hslVal.textContent='';
      preview.style.background='#1e293b';
      return;
    }
    if(isNaN(r)||isNaN(g)||isNaN(b)){result.textContent='Error';preview.style.background='#1e293b';return;}
    result.textContent=hex.toUpperCase();
    let rgba='rgb('+r+','+g+','+b+')';
    if(clean.length===8)rgba='rgba('+r+','+g+','+b+','+a.toFixed(2)+')';
    rgbVal.textContent=rgba;
    preview.style.background=rgba;
    // HSL calc
    const rn=r/255,gn=g/255,bn=b/255;
    const max=Math.max(rn,gn,bn),min=Math.min(rn,gn,bn);
    let h=0,s=0,l=(max+min)/2;
    if(max!==min){
      const d=max-min;
      s=l>0.5?d/(2-max-min):d/(max+min);
      if(max===rn)h=((gn-bn)/d+(gn<bn?6:0))/6;
      else if(max===gn)h=((bn-rn)/d+2)/6;
      else h=((rn-gn)/d+4)/6;
    }
    hslVal.textContent='hsl('+Math.round(h*360)+','+Math.round(s*100)+'%,'+Math.round(l*100)+'%)';
  }
}
const rhInputs=['rhR','rhG','rhB','rhA','rhHex'];
rhInputs.forEach(id=>{
  const el=document.getElementById(id);
  if(el) el.addEventListener('input',rhCalc);
});
document.addEventListener('DOMContentLoaded',rhCalc);
</script>
