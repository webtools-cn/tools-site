<div class="ad-slot">广告位预留（顶部）</div>

<div class="tool-section" id="input">
<h2>Markdown表格转CSV工具</h2>

<div style="margin-bottom:12px">
<label style="font-size:.85rem;color:#94a3b8;display:block;margin-bottom:6px">输入Markdown表格：</label>
<textarea id="mdInput" placeholder="| Name | Age | City |\n|---|---|---|\n| Alice | 30 | New York |" style="width:100%;height:200px;background:#0f172a;border:1px solid rgba(148,163,184,.2);border-radius:8px;padding:12px;color:#e2e8f0;font-size:.85rem;resize:vertical;outline:none;font-family:monospace;white-space:pre;overflow:auto">| Name | Age | City |\n|------|-----|------|\n| Alice | 30 | New York |\n| Bob | 25 | London |\n| Charlie | 35 | Tokyo |</textarea>
</div>
<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px">
<select id="outputFormat" style="background:#0f172a;border:1px solid rgba(148,163,184,.2);border-radius:6px;padding:8px 12px;color:#e2e8f0;font-size:.85rem;outline:none">
<option value="csv">CSV</option>
<option value="tsv">TSV</option>
<option value="json">JSON</option>
</select>
</div>
<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px">
<button id="convertBtn" style="padding:10px 24px;border:none;border-radius:6px;font-size:.9rem;cursor:pointer;background:rgba(6,182,212,.2);color:#22d3ee;border:1px solid rgba(6,182,212,.3)">🔄 转换</button>
<button id="clearBtn" style="padding:10px 24px;border:none;border-radius:6px;font-size:.9rem;cursor:pointer;background:rgba(148,163,184,.1);color:#94a3b8;border:1px solid rgba(148,163,184,.2)">清除</button>
<button id="sampleBtn" style="padding:10px 24px;border:none;border-radius:6px;font-size:.9rem;cursor:pointer;background:rgba(148,163,184,.1);color:#94a3b8;border:1px solid rgba(148,163,184,.2)">📋 加载示例</button>
</div>
<div id="result" style="display:none">
<label style="font-size:.85rem;color:#94a3b8;display:block;margin-bottom:6px">转换结果：</label>
<div style="position:relative">
<pre id="output" style="width:100%;min-height:120px;background:#0f172a;border:1px solid rgba(6,182,212,.3);border-radius:8px;padding:16px;color:#e2e8f0;font-size:.85rem;font-family:monospace;white-space:pre-wrap;overflow:auto;line-height:1.5"></pre>
<div style="position:absolute;top:8px;right:8px;display:flex;gap:4px">
<button id="copyBtn" style="padding:6px 12px;border:none;border-radius:4px;font-size:.75rem;cursor:pointer;background:rgba(148,163,184,.1);color:#94a3b8;border:1px solid rgba(148,163,184,.2)">📋 复制</button>
<button id="downloadBtn" style="padding:6px 12px;border:none;border-radius:4px;font-size:.75rem;cursor:pointer;background:rgba(148,163,184,.1);color:#94a3b8;border:1px solid rgba(148,163,184,.2)">⬇️ 下载</button>
</div>
</div>
<div style="margin-top:8px;padding:12px;background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:8px">
<div style="font-size:.85rem;color:#22c55e;display:flex;gap:16px;flex-wrap:wrap">
<span>📊 行数: <strong id="rowCount">0</strong></span>
<span>📋 列数: <strong id="colCount">0</strong></span>
</div>
</div>
</div>
<div id="errorMsg" style="display:none;margin-top:12px;padding:12px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);border-radius:8px;color:#ef4444;font-size:.85rem"></div>
<script>
(function(){
var inp=document.getElementById("mdInput"),btn=document.getElementById("convertBtn"),clr=document.getElementById("clearBtn"),smp=document.getElementById("sampleBtn"),res=document.getElementById("result"),out=document.getElementById("output"),cpy=document.getElementById("copyBtn"),dwn=document.getElementById("downloadBtn"),err=document.getElementById("errorMsg"),rc=document.getElementById("rowCount"),cc=document.getElementById("colCount"),fmt=document.getElementById("outputFormat");
function parseMD(md){
var lines=md.split("\n").map(function(l){return l.trim()}).filter(function(l){return l});
if(lines.length<2)return null;
var start=0;for(;start<lines.length;start++){if(lines[start].includes("|"))break}
if(start>=lines.length)return null;
var tbl=[];var i=start;
for(;i<lines.length;i++){var l=lines[i];if(!l.includes("|"))break;var cells=l.split("|").map(function(c){return c.trim()}).filter(function(c){return c});if(cells.length>0)tbl.push(cells)}
if(tbl.length<2)return null;return tbl;
}
function quote(c,sep){var s=String(c);if(s.includes(sep)||s.includes('"')||s.includes("\n")){return '"'+s.replace(/"/g,'""')+'"'}return s;}
function process(){
var md=inp.value.trim();if(!md){showToast("请输入Markdown表格");return}
var tbl=parseMD(md);if(!tbl||tbl.length<2){err.style.display="block";err.textContent="错误：无法解析Markdown表格";res.style.display="none";return}
err.style.display="none";
var f=fmt.value;
var result;
if(f==="json"){var h=tbl[1];var r=tbl.slice(2);result=JSON.stringify(r.map(function(row){var obj={};h.forEach(function(k,idx){obj[k]=row[idx]||""});return obj}),null,2)}
else{var sep=f==="tsv"?"\t":",";result=tbl.slice(1).map(function(row){return row.map(function(c){return quote(c,sep)}).join(sep)}).join("\n")}
out.textContent=result;rc.textContent=tbl.length-1;cc.textContent=tbl[1]?tbl[1].length:0;res.style.display="block";
}
btn.addEventListener("click",process);
clr.addEventListener("click",function(){inp.value="";res.style.display="none";err.style.display="none"});
smp.addEventListener("click",function(){inp.value="| Product | Price | Quantity | Total |\n|---------|-------|----------|-------|\n| Laptop | $999 | 2 | $1998 |\n| Mouse | $25 | 5 | $125 |"});
cpy.addEventListener("click",function(){navigator.clipboard.writeText(out.textContent).then(function(){cpy.textContent="\u2705 \u5df2\u590d\u5236";setTimeout(function(){cpy.textContent="\ud83d\udccb \u590d\u5236"},2000)})});
dwn.addEventListener("click",function(){var ext=fmt.value==="json"?"json":"csv";var b=new Blob([out.textContent],{type:"text/"+ext+";charset=utf-8"});var u=URL.createObjectURL(b);var a=document.createElement("a");a.href=u;a.download="table."+ext;a.click();URL.revokeObjectURL(u)});
})();
</script>
</div>

