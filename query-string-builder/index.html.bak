<script>
(function(){
var _params=[];
var _baseUrl='';
function parseInput(){
  var input=document.getElementById('urlInput').value.trim();
  if(!input){_params=[];_baseUrl='';renderParams();return;}
  var queryStr='';
  if(input.indexOf('?')!==-1){
    var parts=input.split('?');
    _baseUrl=parts[0];
    queryStr=parts.slice(1).join('?');
    if(queryStr.indexOf('#')!==-1)queryStr=queryStr.split('#')[0];
  }else if(input.indexOf('=')!==-1){
    _baseUrl='';queryStr=input;
  }else{_baseUrl=input;_params=[];renderParams();return;}
  _params=[];
  if(queryStr){
    queryStr.split('&').forEach(function(pair){
      var eqIdx=pair.indexOf('=');
      if(eqIdx===-1){_params.push({key:decodeURIComponent(pair.replace(/\+/g,' ')),value:''});}
      else{_params.push({key:decodeURIComponent(pair.substring(0,eqIdx).replace(/\+/g,' ')),value:decodeURIComponent(pair.substring(eqIdx+1).replace(/\+/g,' '))});}
    });
  }
  renderParams();
}
function renderParams(){
  var html='';
  _params.forEach(function(p,i){
    html+='<div class="param-item">';
    html+='<input value="'+esc(p.key)+'" placeholder="键名" oninput="updateKey('+i+',this.value)">';
    html+='<span class="eq">=</span>';
    html+='<input value="'+esc(p.value)+'" placeholder="值" oninput="updateValue('+i+',this.value)">';
    html+='<button class="del-btn" onclick="delParam('+i+')">✕</button>';
    html+='</div>';
  });
  if(!_params.length)html='<p style="color:#64748b;font-size:.85rem;text-align:center;padding:12px">暂无参数，点击"添加参数"或粘贴URL</p>';
  document.getElementById('paramList').innerHTML=html;
  buildOutput();
}
function esc(s){return String(s).replace(/"/g,'&quot;').replace(/</g,'&lt;');}
function buildOutput(){
  var mode=document.getElementById('encodeMode').value;
  var qs='';
  _params.forEach(function(p,i){
    if(!p.key&&!p.value)return;
    var k=p.key,v=p.value;
    if(mode==='encode'){k=encodeURIComponent(k);v=encodeURIComponent(v);}
    else if(mode==='encodeComponent'){k=encodeURI(k);v=encodeURI(v);}
    qs+=(i?'&':'')+k+'='+v;
  });
  var fullUrl=qs?(_baseUrl||'https://example.com/path')+'?'+qs:(_baseUrl||'');
  document.getElementById('fullUrl').textContent=fullUrl;
  document.getElementById('queryString').textContent=qs?'?'+qs:'(无参数)';
  document.getElementById('outputSection').style.display='block';
}
window.updateKey=function(i,v){_params[i].key=v;buildOutput();};
window.updateValue=function(i,v){_params[i].value=v;buildOutput();};
window.addParam=function(){_params.push({key:'',value:''});renderParams();};
window.delParam=function(i){_params.splice(i,1);renderParams();};
window.loadExample=function(){
  document.getElementById('urlInput').value='https://api.example.com/search?q=hello+world&page=2&sort=relevance&lang=zh-CN';
  parseInput();
};
window.clearAll=function(){
  document.getElementById('urlInput').value='';
  _params=[];_baseUrl='';renderParams();
  document.getElementById('outputSection').style.display='none';
};
window.importBulk=function(){
  var text=prompt('粘贴参数列表（每行一个 key=value）：');
  if(!text)return;
  text.split('\n').forEach(function(line){
    line=line.trim();if(!line)return;
    var eqIdx=line.indexOf('=');
    if(eqIdx===-1){_params.push({key:line,value:''});}
    else{_params.push({key:line.substring(0,eqIdx).trim(),value:line.substring(eqIdx+1).trim()});}
  });
  renderParams();
};
window.copyFullUrl=function(){var t=document.getElementById('fullUrl').textContent;if(navigator.clipboard)navigator.clipboard.writeText(t).then(showMsg);};
window.copyQueryString=function(){var t=document.getElementById('queryString').textContent;if(navigator.clipboard)navigator.clipboard.writeText(t).then(showMsg);};
function showMsg(){var m=document.createElement('div');m.textContent='✓ 已复制';m.style.cssText='position:fixed;top:20px;right:20px;background:rgba(34,197,94,.2);color:#4ade80;padding:8px 16px;border-radius:8px;font-size:.85rem;z-index:9999;border:1px solid rgba(34,197,94,.3)';document.body.appendChild(m);setTimeout(function(){m.remove();},2000);}
document.addEventListener('keydown',function(e){if(e.ctrlKey&&e.key==='Enter'){buildOutput();e.preventDefault();}if(e.ctrlKey&&e.shiftKey&&e.key==='C'){copyFullUrl();e.preventDefault();}});
})();
</script>
