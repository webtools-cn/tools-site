  <div class="main-grid">
    <div>
      <div class="input-section">
        <h2>📥 URL/查询字符串输入</h2>
        <textarea id="urlInput" placeholder="粘贴完整URL或查询字符串&#10;如：https://example.com/api?name=hello&page=1&#10;或：name=hello&page=1" oninput="parseInput()"></textarea>
        <div class="param-row" style="margin-top:8px">
