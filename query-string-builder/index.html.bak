          <button class="btn btn-primary btn-sm" onclick="addParam()">+ 添加参数</button>
          <button class="btn btn-secondary btn-sm" onclick="importBulk()">📋 批量导入</button>
        </div>
      </div>
      <div class="result-section" id="outputSection" style="display:none">
        <h2>📄 构建结果</h2>
        <div class="result-label">完整URL</div>
        <div class="output-box" id="fullUrl"></div>
        <div class="result-label" style="margin-top:8px">查询字符串</div>
