font-size:.85rem;cursor:pointer;transition:all .2s}.btn-primary{background:rgba(6,182,212,.2);color:#22d3ee;border:1px solid rgba(6,182,212,.3)}.btn-primary:hover{background:rgba(6,182,212,.3)}.btn-secondary{background:rgba(148,163,184,.1);color:#94a3b8;border:1px solid rgba(148,163,184,.15)}.btn-secondary:hover{background:rgba(148,163,184,.2)}.btn-success{background:rgba(16,185,129,.2);color:#34d399;border:1px solid rgba(16,185,129,.3)}.btn-success:hover{background:rgba(16,185,129,.3)}.btn-danger{background:rgba(239,68,68,.2);color:#f87171;border:1px solid rgba(239,68,68,.3)}.btn-danger:hover{background:rgba(239,68,68,.3)}.btn-sm{padding:4px 10px;font-size:.75rem}.result-section{background:#1e293b;border-radius:12px;padding:20px;margin-bottom:16px;border:1px solid rgba(148,163,184,.1)}.result-section h2{font-size:1.1rem;color:#f1f5f9;margin-bottom:12px}.param-list{display:grid;gap:8px;margin-bottom:12px}.param-item{display:flex;gap:8px;align-items:center;background:#0f172a;padding:8px 12px;border-radius:8px;border:1px solid rgba(148,163,184,.1)}.param-item input{flex:1;padding:6px 8px;background:transparent;color:#e2e8f0;border:1px solid rgba(148,163,184,.15);border-radius:4px;font-size:.85rem;font-family:monospace}.param-item input:focus{border-color:rgba(6,182,212,.5);outline:none}.param-item .eq{color:#64748b;font-size:.9rem}.param-item .del-btn{padding:4px 8px;border:1px solid rgba(239,68,68,.2);border-radius:4px;background:transparent;color:#f87171;font-size:.75rem;cursor:pointer}.param-item .del-btn:hover{background:rgba(239,68,68,.2)}.output-box{background:#0f172a;border-radius:8px;padding:12px;border:1px solid rgba(148,163,184,.1);font-family:monospace;font-size:.85rem;word-break:break-all;color:#22d3ee;margin-bottom:8px}.main-grid{display:grid;grid-template-columns:1fr 300px;gap:20px}@media(max-width:768px){.main-grid{grid-template-columns:1fr}}.ad-slot{margin:0 auto;text-align:center;max-width:960px}.ad-slot:not(:has(ins[frame])){display:none}.ad-slot:empty{display:none}.ad-slot ins{display:block}.ad-slot.ad-sidebar{max-width:300px}.ad-sidebar-wrap{display:flex;flex-direction:column;gap:0}.seo-content{margin-top:24px;padding:20px 0;border-top:1px solid rgba(148,163,184,.1)}.seo-content h2{font-size:1.2rem;color:#f1f5f9;margin:20px 0 10px}.seo-content h3{font-size:1rem;color:#e2e8f0;margin:16px 0 8px}.seo-content p{color:#94a3b8;margin-bottom:10px;line-height:1.8}.seo-content ul{color:#94a3b8;padding-left:20px;margin-bottom:10px}.seo-content li{margin-bottom:4px}.faq-item{background:#1e293b;border-radius:8px;padding:14px 18px;margin-bottom:8px;border:1px solid rgba(148,163,184,.1)}.faq-item h3{font-size:.95rem;color:#e2e8f9;margin-bottom:6px}.faq-item p{color:#94a3b8;font-size:.85rem;line-height:1.6}.footer{border-top:1px solid rgba(148,163,184,.1);padding:20px 0;text-align:center;margin-top:24px}.footer a{color:#64748b;margin:0 8px;font-size:.85rem}.footer a:hover{color:#22d3ee}.footer p{color:#64748b;font-size:.85rem}
