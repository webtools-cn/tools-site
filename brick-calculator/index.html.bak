<script>
const BC_BRICKS = {
  standard:{l:240,h:53,d:115,unit:'mm',name_zh:'标准砖',name_en:'Standard'},
  solid:{l:240,h:53,d:115,unit:'mm',name_zh:'实心砖',name_en:'Solid'},
  hollow:{l:390,h:190,d:190,unit:'mm',name_zh:'空心砖',name_en:'Hollow'},
  perforated:{l:240,h:90,d:115,unit:'mm',name_zh:'多孔砖',name_en:'Perforated'}
};
function bcCalc(){
  const len=parseFloat(document.getElementById('bcLen').value)||0;
  const hgt=parseFloat(document.getElementById('bcHgt').value)||0;
  const thick=parseFloat(document.getElementById('bcThick').value)||0.24;
  const type=document.getElementById('bcType').value;
  const mortarMm=parseFloat(document.getElementById('bcMortar').value)||10;
  const brick=BC_BRICKS[type];
  const wallVol=len*hgt*thick;
  const bL=(brick.l/1000), bH=(brick.h/1000), bD=(brick.d/1000);
  const mM=mortarMm/1000;
  const brickWithMortar=(bL+mM)*(bH+mM)*(bD+mM);
  const bricksPerM3=brickWithMortar>0?1/brickWithMortar:0;
  const brickCount=bricksPerM3>0?Math.ceil(wallVol*bricksPerM3):0;
  const brickVolSingle=bL*bH*bD;
  const brickVol=brickCount*brickVolSingle;
  const mortarVol=Math.max(0,wallVol-brickVol);
  const buyRec=Math.ceil(brickCount*1.05);
  const area=len*hgt;
  const perM2=area>0?Math.round(brickCount/area):0;
  const isEn=document.querySelector('html').lang==='en';
  document.getElementById('bcBrickCount').textContent=brickCount.toLocaleString();
  document.getElementById('bcWallVol').textContent=wallVol.toFixed(2);
  document.getElementById('bcBrickVol').textContent=brickVol.toFixed(2);
  document.getElementById('bcMortarVol').textContent=mortarVol.toFixed(2);
  document.getElementById('bcPerM2').textContent=perM2;
  document.getElementById('bcBuyRec').textContent=buyRec.toLocaleString();
  document.getElementById('bcCostEst').textContent='——';
}
['bcLen','bcHgt','bcThick','bcType','bcMortar'].forEach(id=>{
  const el=document.getElementById(id);
  if(el) el.addEventListener('input',bcCalc);
  if(el) el.addEventListener('change',bcCalc);
});
document.addEventListener('DOMContentLoaded',bcCalc);
</script>
