      }
    },
    {
      "@type": "Question",
      "name": "支持哪些正则标志？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "支持JavaScript正则标志：g（全局匹配）、i（忽略大小写）、m（多行模式）、s（dotAll模式）、u（Unicode模式）。"
      }
    },
    {
      "@type": "Question",
      "name": "数据会上传到服务器吗？",
