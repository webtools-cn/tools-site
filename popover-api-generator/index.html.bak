<h2>⚙️ 配置Popover</h2>
<div class="form-group"><label>Popover模式</label><select id="popover-mode" onchange="updateCode()"><option value="auto">auto（自动关闭，点击外部/Esc关闭）</option><option value="manual">manual（手动控制，需调用hidePopover()）</option></select></div>
<div class="form-group"><label>触发按钮文本</label><input type="text" id="btn-text" value="显示弹出层" oninput="updateCode()"></div>
<div class="form-group"><label>弹出层内容</label><input type="text" id="popover-content" value="这是Popover弹出层的内容" oninput="updateCode()"></div>
<div class="form-group"><label>弹出层标题</label><input type="text" id="popover-title" value="提示" oninput="updateCode()"></div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
<div class="form-group"><label>背景色</label><div class="color-input"><input type="color" id="bg-color" value="#1e293b" onchange="updateCode()"><input type="text" id="bg-color-text" value="#1e293b" oninput="syncColor('bg');updateCode()"></div></div>
<div class="form-group"><label>边框色</label><div class="color-input"><input type="color" id="border-color" value="#06b6d4" onchange="updateCode()"><input type="text" id="border-color-text" value="#06b6d4" oninput="syncColor('border');updateCode()"></div></div>
</div>
<div class="form-group"><label>动画效果</label><select id="animation" onchange="updateCode()"><option value="none">无动画</option><option value="fade">淡入淡出</option><option value="scale">缩放</option><option value="slide">滑入</option></select></div>
<div class="btn-group">
<button class="btn btn-primary" onclick="copyCode()">📋 复制代码</button>
<button class="btn btn-secondary" onclick="resetForm()">🔄 重置</button>
</div>
