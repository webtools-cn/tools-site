<script>
function syncColor(type){const color=document.getElementById(type+'-color-text').value;document.getElementById(type+'-color').value=color;}
function updateCode(){
  const mode=document.getElementById('popover-mode').value;
  const btnText=document.getElementById('btn-text').value||'显示弹出层';
  const content=document.getElementById('popover-content').value||'内容';
  const title=document.getElementById('popover-title').value||'';
  const bgColor=document.getElementById('bg-color').value;
  const borderColor=document.getElementById('border-color').value;
  const anim=document.getElementById('animation').value;
  let animCSS='';
  if(anim==='fade')animCSS='[popover]{opacity:0;transition:opacity .3s}\n[popover]:popover-open{opacity:1}';
  else if(anim==='scale')animCSS='[popover]{opacity:0;transform:scale(.9);transition:all .3s}\n[popover]:popover-open{opacity:1;transform:scale(1)}';
  else if(anim==='slide')animCSS='[popover]{opacity:0;transform:translateY(-10px);transition:all .3s}\n[popover]:popover-open{opacity:1;transform:translateY(0)}';
  const popoverId='my-popover';
  const html=`\u003cbutton popovertarget="${popoverId}"\u003e${btnText}\u003c/button\u003e\n\n\u003cdiv id="${popoverId}" popover="${mode}"\u003e\n  ${title?'\u003ch3\u003e'+title+'\u003c/h3\u003e\n  ':''}${content}\n\u003c/div\u003e`;
  const css=`#${popoverId} {\n  background: ${bgColor};\n  color: #e2e8f0;\n  border: 1px solid ${borderColor};\n  border-radius: 8px;\n  padding: 16px;\n  margin: auto;\n  max-width: 300px;\n}${animCSS?'\n\n'+animCSS:''}`;
  const code=`\u003c!-- HTML --\u003e\n${html}\n\n\u003c!-- CSS --\u003e\n\u003cstyle\u003e\n${css}\n\u003c/style\u003e`;
  document.getElementById('code-text').textContent=code;
  // Preview
  const preview=document.getElementById('preview-area');
  preview.innerHTML=`\u003cbutton popovertarget="preview-popover" class="demo-btn"\u003e${btnText}\u003c/button\u003e\n\u003cdiv id="preview-popover" popover="${mode}" style="background:${bgColor};color:#e2e8f0;border:1px solid ${borderColor};border-radius:8px;padding:16px;margin:auto;max-width:280px;${anim==='fade'?'opacity:1;':anim==='scale'?'opacity:1;transform:scale(1);':anim==='slide'?'opacity:1;transform:translateY(0);':''}"\u003e${title?'\u003ch3 style="margin:0 0 8px;color:#06b6d4;font-size:1rem"\u003e'+title+'\u003c/h3\u003e':''}${content}\u003c/div\u003e`;
}
function copyCode(){const text=document.getElementById('code-text').textContent;navigator.clipboard.writeText(text).then(()=>{const t=document.getElementById('copy-toast');t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000);});}
function resetForm(){document.getElementById('popover-mode').value='auto';document.getElementById('btn-text').value='显示弹出层';document.getElementById('popover-content').value='这是Popover弹出层的内容';document.getElementById('popover-title').value='提示';document.getElementById('bg-color').value='#1e293b';document.getElementById('bg-color-text').value='#1e293b';document.getElementById('border-color').value='#06b6d4';document.getElementById('border-color-text').value='#06b6d4';document.getElementById('animation').value='none';updateCode();}
function toggleFaq(el){el.parentElement.classList.toggle('open');}
updateCode();
</script>
