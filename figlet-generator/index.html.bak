};
FONTS.shadow=FONTS.standard;
FONTS.block=FONTS.banner;
FONTS.banner3=FONTS.banner;
FONTS.speed=FONTS.mini;
FONTS.small=FONTS.mini;
FONTS.thin=FONTS.mini;

function generate(){
var text=document.getElementById('textInput').value;
var fontName=document.getElementById('fontSelect').value;
var resPanel=document.getElementById('resultPanel');
var output=document.getElementById('asciiOutput');
if(!text){resPanel.style.display='none';return;}
resPanel.style.display='block';
var font=FONTS[fontName]||FONTS.standard;
var height=6;
var lines=[];
for(var row=0;row<height;row++)lines.push('');
for(var i=0;i<text.length;i++){
var ch=text[i].toUpperCase();
var charData=font[ch];
if(!charData)charData=font[' ']||['   ','   ','   ','   ','   ','   '];
for(var row=0;row<Math.min(charData.length,height);row++){
lines[row]+=(charData[row]||'')+' ';
}
}
output.textContent=lines.join('\n');
}

function loadExample(){document.getElementById('textInput').value='HELLO';generate();}
function clearInput(){document.getElementById('textInput').value='';document.getElementById('resultPanel').style.display='none';}
function copyResult(){var t=document.getElementById('asciiOutput').textContent;if(t)navigator.clipboard.writeText(t).catch(function(){});}
function downloadResult(){var t=document.getElementById('asciiOutput').textContent;var blob=new Blob([t],{type:'text/plain;charset=utf-8'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='ascii-art.txt';a.click();}
document.addEventListener('keydown',function(e){if(e.ctrlKey&&e.key==='Enter'){generate();e.preventDefault();}if(e.ctrlKey&&e.shiftKey&&e.key==='C'){copyResult();e.preventDefault();}});
window.addEventListener('load',function(){loadExample();});
</script>
