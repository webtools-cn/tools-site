    {
      "@type": "Question",
      "name": "生成的ASCII文字可以商用吗？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "可以。ASCII艺术文字本身不受版权保护，Figlet字体也是开源的。生成的文字可自由用于代码注释、文档、终端界面等。"
      }
    },
    {
      "@type": "Question",
      "name": "为什么有些字符显示不正确？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Figlet字体主要支持英文字母、数字和常见标点。中文字符、emoji等不在ASCII范围内，无法用ASCII字符表示。请输入英文内容获得最佳效果。"
      }
    }
  ]
}</script>
