.status-bar{display:flex;align-items:center;gap:8px;padding:10px 12px;background:#0f172a;border-radius:8px;font-size:.85rem;color:#94a3b8;margin-bottom:12px;border:1px solid rgba(148,163,184,.08)}
.status-bar .spinner{width:16px;height:16px;border:2px solid rgba(6,182,212,.3);border-top-color:#22d3ee;border-radius:50%;animation:spin .8s linear infinite;display:none}
@keyframes spin{to{transform:rotate(360deg)}
