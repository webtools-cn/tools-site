input[type=file]{display:none}
textarea{width:100%;padding:10px 12px;background:#0f172a;color:#e2e8f0;border:1px solid rgba(148,163,184,.2);border-radius:8px;font-size:.9rem;font-family:monospace;resize:vertical;min-height:200px;margin-bottom:12px}
textarea:focus{outline:none;border-color:rgba(6,182,212,.5)}
