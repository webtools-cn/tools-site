<div class="input-section">
<h2>搜索表情符号</h2>
<input type="search" id="emojiSearch" placeholder="输入关键词搜索，如：开心、食物、动物、爱心..." oninput="searchEmojis()">
<div class="row">
<div class="field"><label>分类</label><select id="emojiCategory" onchange="searchEmojis()">
<option value="all">全部分类</option>
<option value="smile">笑脸与情感</option>
<option value="people">人物</option>
<option value="animal">动物与自然</option>
<option value="food">食物与饮料</option>
<option value="travel">旅行与地点</option>
<option value="activity">活动与娱乐</option>
<option value="object">物品与符号</option>
<option value="symbol">符号与标志</option>
</select></div>
<div class="field"><label>大小</label><select id="emojiSize" onchange="searchEmojis()">
<option value="32">小</option>
<option value="40" selected>中</option>
<option value="48">大</option>
</select></div>
</div>
