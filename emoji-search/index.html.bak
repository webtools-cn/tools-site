const CATEGORIES = {
    "all": (e) => true,
    "smile": (e) => ["face","smile","laugh","happy","cry","angry","shock","sleep","love","tongue","wink"].some(k => e[3].includes(k) || e[2].toLowerCase().includes(k)),
    "people": (e) => ["person","man","woman","baby","boy","girl","family","hand","finger","arm","leg","foot","body","dance","run","walk","people","facepalm","shrug"].some(k => e[3].includes(k) || e[2].toLowerCase().includes(k)),
    "animal": (e) => ["dog","cat","rabbit","bear","bird","fish","whale","dolphin","insect","turtle","snake","frog","lion","tiger","monkey","fox","panda","koala","eagle","owl","shark","butterfly","bee"].some(k => e[3].includes(k)),
    "food": (e) => ["food","fruit","vegetable","drink","coffee","tea","cake","bread","meat","rice","noodle","sushi","pizza","burger","dessert","sweet","candy","icecream"].some(k => e[3].includes(k) || e[2].toLowerCase().includes(k)),
    "travel": (e) => ["house","building","city","mountain","beach","ocean","sea","tree","flower","sun","moon","star","cloud","rain","snow","airplane","car","bus","train","ship","bike","rocket","tower","castle"].some(k => e[3].includes(k)),
    "activity": (e) => ["sport","game","music","ball","dance","art","movie","theater","party","travel","exercise","gym","swim","medal","trophy","video","puzzle"].some(k => e[3].includes(k)),
    "object": (e) => ["phone","computer","laptop","camera","book","pen","paper","money","clock","calendar","key","lock","light","tool","clothing","gift","toy","cook","chair","bed"].some(k => e[3].includes(k)),
    "symbol": (e) => ["flag","heart","cross","star","button","symbol","sign","number","color","circle","square","japanese","warning","prohibit","recycle","danger","peace"].some(k => e[3].includes(k) || e[2].toLowerCase().includes(k))
};

let allEmojis = EMOJIS;

function searchEmojis() {
    const query = document.getElementById("emojiSearch").value.toLowerCase().trim();
    const cat = document.getElementById("emojiCategory").value;
    const size = document.getElementById("emojiSize").value;
    
    let filtered = allEmojis;
    if (cat !== "all" && CATEGORIES[cat]) {
        filtered = filtered.filter(e => CATEGORIES[cat](e));
    }
    if (query) {
        filtered = filtered.filter(e => 
            e[1].includes(query) || 
            e[2].toLowerCase().includes(query) || 
            e[3].includes(query) ||
            e[4].includes(query)
        );
    }
    
    document.getElementById("emojiCount").textContent = `(${filtered.length} 个)`;
    const grid = document.getElementById("emojiGrid");
    if (filtered.length === 0) {
        grid.innerHTML = '<p style="color:#64748b;padding:20px;text-align:center">未找到匹配的表情符号</p>';
        return;
    }
    grid.innerHTML = filtered.map(e => 
        `<span class="emoji-item" onclick="copyEmoji('${e[0]}','${e[1]}')" title="${e[1]} (${e[2]})">${e[0]}</span>`
    ).join("");
    
    // add style for emoji items
    if (!document.getElementById("emojiStyle")) {
        const s = document.createElement("style");
        s.id = "emojiStyle";
        s.textContent = `.emoji-item{font-size:${size}px;padding:6px;cursor:pointer;border-radius:6px;transition:all .2s;width:auto;text-align:center;line-height:1.2}.emoji-item:hover{background:rgba(6,182,212,.15);transform:scale(1.2);z-index:2}`;
        document.head.appendChild(s);
    } else {
        document.getElementById("emojiStyle").textContent = `.emoji-item{font-size:${size}px;padding:6px;cursor:pointer;border-radius:6px;transition:all .2s;width:auto;text-align:center;line-height:1.2}.emoji-item:hover{background:rgba(6,182,212,.15);transform:scale(1.2);z-index:2}`;
    }
}

function copyEmoji(emoji, name) {
    navigator.clipboard.writeText(emoji).then(() => {
        const preview = document.getElementById("emojiPreview");
        preview.style.display = "block";
        preview.innerHTML = `<div style="font-size:48px;margin-bottom:8px">${emoji}</div><p style="color:#22d3ee">✅ 已复制 "${emoji} ${name}"</p><p style="color:#64748b;font-size:.85rem">已复制到剪贴板，粘贴使用</p>`;
        setTimeout(() => { preview.style.display = "none"; }, 2000);
    }).catch(() => {
        const ta = document.createElement("textarea");
        ta.value = emoji;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand("copy");
        document.body.removeChild(ta);
    });
}

searchEmojis();
