  </div>
  <p>在线图片配色提取器 · 纯前端本地处理 · 数据绝不上传服务器</p>
  <p style="margin-top:4px">支持HEX、RGB格式 · 一键复制配色代码 · 支持CSS/JSON导出</p>
  <p style="margin-top:8px;color:#475569;font-size:.8rem">问题反馈: dexshuang@google.com</p>
</div>

<div class="toast" id="toast"></div>

<script>
const uploadZone = document.getElementById('uploadZone');
const fileInput = document.getElementById('fileInput');
const previewSection = document.getElementById('previewSection');
const previewImg = document.getElementById('previewImg');
const paletteSection = document.getElementById('paletteSection');
const colorList = document.getElementById('colorList');
const colorBar = document.getElementById('colorBar');
const toast = document.getElementById('toast');
let currentColors = [];

function showToast(msg) {
  toast.textContent = msg;
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 2000);
}

function rgbToHex(r, g, b) {
  return '#' + [r, g, b].map(x => x.toString(16).padStart(2, '0').toUpperCase()).join('');
}

function getLuminance(r, g, b) {
  return (0.299 * r + 0.587 * g + 0.114 * b) / 255;
}

function extractColors(image) {
  const canvas = document.createElement('canvas');
  const ctx = canvas.getContext('2d');
  const maxDim = 200;
  let w = image.width, h = image.height;
  if (w > h) { h = Math.round(h * maxDim / w); w = maxDim; }
  else { w = Math.round(w * maxDim / h); h = maxDim; }
  canvas.width = w;
  canvas.height = h;
  ctx.drawImage(image, 0, 0, w, h);
  const imageData = ctx.getImageData(0, 0, w, h).data;
  const colorCounts = {};
  const step = 4;
  for (let i = 0; i < imageData.length; i += step * 4) {
    const r = Math.round(imageData[i] / 51) * 51;
    const g = Math.round(imageData[i + 1] / 51) * 51;
    const b = Math.round(imageData[i + 2] / 51) * 51;
    if (r > 250 && g > 250 && b > 250) continue;
    const key = r + ',' + g + ',' + b;
    colorCounts[key] = (colorCounts[key] || 0) + 1;
  }
  const totalPixels = Object.values(colorCounts).reduce((a, b) => a + b, 0);
  const sorted = Object.entries(colorCounts).sort((a, b) => b[1] - a[1]);
  const clusters = [];
  const used = new Set();
  for (const [key, count] of sorted) {
    if (used.has(key)) continue;
    const [r, g, b] = key.split(',').map(Number);
    let clusterR = r * count, clusterG = g * count, clusterB = b * count, clusterCount = count;
    used.add(key);
    for (const [k2, c2] of sorted) {
      if (used.has(k2)) continue;
      const [r2, g2, b2] = k2.split(',').map(Number);
      const dist = Math.sqrt((r - r2) ** 2 + (g - g2) ** 2 + (b - b2) ** 2);
      if (dist < 100) {
        clusterR += r2 * c2; clusterG += g2 * c2; clusterB += b2 * c2; clusterCount += c2;
        used.add(k2);
      }
    }
    clusters.push({
      r: Math.round(clusterR / clusterCount),
      g: Math.round(clusterG / clusterCount),
      b: Math.round(clusterB / clusterCount),
      count: clusterCount
    });
  }
  clusters.sort((a, b) => b.count - a.count);
  return clusters.slice(0, 8).map(c => ({
    ...c,
    hex: rgbToHex(c.r, c.g, c.b),
    percent: ((c.count / totalPixels) * 100).toFixed(1)
  }));
}

function renderColors(colors) {
  currentColors = colors;
  colorBar.innerHTML = '';
  colorList.innerHTML = '';
  colors.forEach((c, i) => {
    const seg = document.createElement('div');
    seg.className = 'color-bar-seg';
    seg.style.background = c.hex;
    seg.style.flex = c.percent;
    colorBar.appendChild(seg);
    const card = document.createElement('div');
    card.className = 'color-card';
    card.innerHTML = `
      <div class="color-swatch" style="background:${c.hex}"></div>
      <div class="color-info">
        <div class="color-hex">${c.hex}</div>
        <div class="color-rgb">rgb(${c.r}, ${c.g}, ${c.b})</div>
      </div>
      <div class="color-percent">${c.percent}%</div>
    `;
    card.addEventListener('click', () => {
      if (navigator.clipboard) {
        navigator.clipboard.writeText(c.hex).then(() => showToast('已复制 ' + c.hex));
      } else {
        const ta = document.createElement('textarea'); ta.value = c.hex; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta); showToast('已复制 ' + c.hex);
      }
    });
    colorList.appendChild(card);
  });
  paletteSection.classList.add('active');
}

function processFile(file) {
  if (!file || !file.type.startsWith('image/')) { showToast('请选择图片文件'); return; }
  const reader = new FileReader();
  reader.onload = (e) => {
    const img = new Image();
    img.onload = () => {
      previewImg.src = img.src;
      previewSection.classList.add('active');
      const colors = extractColors(img);
      renderColors(colors);
    };
    img.onerror = () => showToast('图片加载失败');
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

uploadZone.addEventListener('click', () => fileInput.click());
uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.classList.add('dragover'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
uploadZone.addEventListener('drop', (e) => { e.preventDefault(); uploadZone.classList.remove('dragover'); const f = e.dataTransfer.files[0]; if (f) processFile(f); });
fileInput.addEventListener('change', (e) => { const f = e.target.files[0]; if (f) processFile(f); });

function copyAllColors() {
  if (!currentColors.length) return;
  const text = currentColors.map(c => c.hex + '  rgb(' + c.r + ',' + c.g + ',' + c.b + ')  ' + c.percent + '%').join('\n');
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(() => showToast('已复制全部配色'));
  } else {
    const ta = document.createElement('textarea'); ta.value = text; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta); showToast('已复制全部配色');
  }
}

function downloadCSS() {
  if (!currentColors.length) return;
  let css = ':root {\n';
  currentColors.forEach((c, i) => { css += '  --color-' + (i + 1) + ': ' + c.hex + '; /* rgb(' + c.r + ',' + c.g + ',' + c.b + ') */\n'; });
  css += '}\n';
  const blob = new Blob([css], { type: 'text/css' });
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'palette.css'; a.click(); URL.revokeObjectURL(a.href);
  showToast('CSS文件已下载');
}

function downloadJSON() {
  if (!currentColors.length) return;
  const data = {
    tool: 'Image Color Palette Extractor',
    generatedAt: new Date().toISOString(),
    colors: currentColors.map((c, i) => ({ name: 'Color ' + (i + 1), hex: c.hex, rgb: { r: c.r, g: c.g, b: c.b }, percent: c.percent + '%' }))
  };
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'palette.json'; a.click(); URL.revokeObjectURL(a.href);
  showToast('JSON文件已下载');
}
</script>

<!-- 反馈收集 -->
<div id="feedback-widget" style="position:fixed;bottom:20px;right:20px;z-index:1000">
<button id="feedback-toggle" onclick="toggleFeedback()" style="width:48px;height:48px;border-radius:50%;background:rgba(6,182,212,.2);border:2px solid rgba(6,182,212,.5);color:#22d3ee;font-size:1.2rem;cursor:pointer;box-shadow:0 4px 12px rgba(0,0,0,.3);transition:all .2s" onmouseover="this.style.background='rgba(6,182,212,.4)'" onmouseout="this.style.background='rgba(6,182,212,.2)'">💬</button>
<div id="feedback-panel" style="display:none;position:absolute;bottom:56px;right:0;width:320px;background:#1e293b;border:1px solid rgba(6,182,212,.3);border-radius:12px;padding:16px;box-shadow:0 8px 24px rgba(0,0,0,.4)">
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
<span style="color:#f1f5f9;font-size:.95rem;font-weight:600">📝 反馈建议</span>
<button onclick="toggleFeedback()" style="background:none;border:none;color:#64748b;font-size:1.2rem;cursor:pointer">✕</button>
</div>
<select id="feedback-type" style="width:100%;background:#0f172a;border:1px solid rgba(148,163,184,.2);border-radius:6px;padding:8px 10px;color:#e2e8f0;font-size:.85rem;margin-bottom:8px;outline:none">
<option value="feedback">💡 功能建议</option>
<option value="bug">🐛 问题反馈</option>
<option value="other">💬 其他</option>
</select>
<textarea id="feedback-text" placeholder="请描述您的建议或遇到的问题..." style="width:100%;height:100px;background:#0f172a;border:1px solid rgba(148,163,184,.2);border-radius:6px;padding:10px;color:#e2e8f0;font-size:.85rem;resize:vertical;outline:none;font-family:inherit" maxlength="1000"></textarea>
<div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px">
<span id="feedback-count" style="color:#475569;font-size:.75rem">0/1000</span>
<button onclick="submitFeedback()" style="background:rgba(6,182,212,.2);color:#22d3ee;border:1px solid rgba(6,182,212,.3);border-radius:6px;padding:6px 16px;font-size:.85rem;cursor:pointer;transition:all .2s" onmouseover="this.style.background='rgba(6,182,212,.4)'" onmouseout="this.style.background='rgba(6,182,212,.2)'">提交</button>
</div>
<div id="feedback-success" style="display:none;margin-top:8px;padding:8px;background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.3);border-radius:6px;color:#22c55e;font-size:.8rem;text-align:center">✅ 感谢反馈！已提交到GitHub Issues</div>
</div>
</div>
<script>
function toggleFeedback(){const p=document.getElementById('feedback-panel');p.style.display=p.style.display==='none'?'block':'none';}
document.getElementById('feedback-text').addEventListener('input',function(){document.getElementById('feedback-count').textContent=this.value.length+'/1000';});
function submitFeedback(){
const type=document.getElementById('feedback-type').value;
const text=document.getElementById('feedback-text').value.trim();
if(!text){var ft=document.getElementById('feedback-text');if(ft){ft.style.borderColor='#ef4444';setTimeout(function(){ft.style.borderColor=''},2000)};return;}
const typeLabel={feedback:'💡 功能建议',bug:'🐛 问题反馈',other:'💬 其他'}[type];
const title=encodeURIComponent(typeLabel+' - '+window.location.pathname);
const body=encodeURIComponent('**页面**: '+window.location.href+'\n**类型**: '+typeLabel+'\n\n'+text);
window.open('https://github.com/webtools-cn/tools-site/issues/new?title='+title+'&body='+body,'_blank');
document.getElementById('feedback-success').style.display='block';
setTimeout(()=>{document.getElementById('feedback-success').style.display='none';toggleFeedback();document.getElementById('feedback-text').value='';document.getElementById('feedback-count').textContent='0/1000';},3000);
}
</script>
