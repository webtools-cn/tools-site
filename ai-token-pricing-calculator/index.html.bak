*{margin:0;padding:0;box-sizing:border-box}
body{background:#0f172a;color:#e2e8f0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;line-height:1.6}
.container{max-width:1200px;margin:0 auto;padding:0 16px}
header{padding:20px 0;border-bottom:1px solid rgba(148,163,184,.1)}
header h1{font-size:1.5rem;color:#e2e8f0;margin-bottom:4px}
.lang-switch{float:right;font-size:.85rem;color:#06b6d4;text-decoration:none}
.lang-switch:hover{color:#22d3ee}
