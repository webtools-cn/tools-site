.main-grid{display:grid;grid-template-columns:1fr 300px;gap:20px;margin-top:20px}
@media(max-width:768px){.main-grid{grid-template-columns:1fr}}
.panel{background:#1e293b;border-radius:12px;padding:20px;border:1px solid rgba(148,163,184,.1)}
.panel h2{font-size:1.1rem;color:#e2e8f0;margin-bottom:12px}
.ad-slot{margin:16px auto;text-align:center;max-width:960px;min-height:90px}
.ad-slot:empty{display:none}
.ad-slot ins{display:block}
.ad-slot.ad-sidebar{min-height:250px;max-width:300px}
.btn{display:inline-block;padding:8px 20px;border-radius:8px;border:none;cursor:pointer;font-size:.9rem;font-weight:500;transition:all .2s}
.btn-primary{background:#06b6d4;color:#fff}
.btn-primary:hover{background:#22d3ee}
.btn-secondary{background:rgba(148,163,184,.15);color:#e2e8f0}
.btn-secondary:hover{background:rgba(148,163,184,.25)}
.btn-sm{padding:5px 14px;font-size:.8rem}
.input-group{margin-bottom:12px}
.input-group label{display:block;font-size:.85rem;color:#94a3b8;margin-bottom:4px}
.input-group input{width:100%;padding:8px 12px;border-radius:8px;border:1px solid rgba(148,163,184,.2);background:rgba(148,163,184,.05);color:#e2e8f0;font-size:.9rem}
.input-group input:focus{outline:none;border-color:#06b6d4}
.input-row{display:flex;gap:12px;margin-bottom:12px}
.input-row .input-group{flex:1;margin-bottom:0}
.model-checks{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:6px;margin-bottom:12px}
.model-check{display:flex;align-items:center;gap:6px;padding:6px 10px;border-radius:6px;background:rgba(148,163,184,.05);border:1px solid rgba(148,163,184,.1);cursor:pointer;font-size:.8rem;color:#e2e8f0;transition:all .2s}
.model-check:hover{background:rgba(148,163,184,.1)}
.model-check.selected{background:rgba(6,182,212,.1);border-color:#06b6d4}
.model-check input{accent-color:#06b6d4}
.model-check .price-hint{font-size:.7rem;color:#64748b;margin-left:auto}
.compare-table{width:100%;border-collapse:collapse;margin-top:12px}
.compare-table th,.compare-table td{padding:10px 8px;text-align:left;border-bottom:1px solid rgba(148,163,184,.1);font-size:.85rem}
.compare-table th{color:#06b6d4;font-weight:600;background:rgba(6,182,212,.05)}
.compare-table .cheapest{color:#10b981;font-weight:700}
.compare-table .expensive{color:#ef4444}
.cost-bar{height:8px;border-radius:4px;background:rgba(148,163,184,.1);overflow:hidden;margin-top:4px}
.cost-bar-fill{height:100%;border-radius:4px;transition:width .5s}
.seo-content{margin-top:32px;padding:24px 0;border-top:1px solid rgba(148,163,184,.1)}
.seo-content h2{font-size:1.2rem;color:#e2e8f0;margin-bottom:12px;margin-top:24px}
.seo-content h2:first-child{margin-top:0}
