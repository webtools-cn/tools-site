<a href="/">首页</a><a href="/tools/">全部工具</a><a href="/contact/">联系我们</a><a href="/privacy-policy/">隐私政策</a><a href="/terms-of-service/">服务条款</a><a href="/about/">关于我们</a><a href="/en/ai-token-pricing-calculator/">EN</a>
</footer>
<script>
const MODELS=[
{id:'gpt4o',name:'GPT-4o',inputPrice:2.5,outputPrice:10},
{id:'gpt4o-mini',name:'GPT-4o Mini',inputPrice:0.15,outputPrice:0.6},
{id:'gpt41',name:'GPT-4.1',inputPrice:2,outputPrice:8},
{id:'gpt41-mini',name:'GPT-4.1 Mini',inputPrice:0.4,outputPrice:1.6},
{id:'gpt41-nano',name:'GPT-4.1 Nano',inputPrice:0.1,outputPrice:0.4},
{id:'claude-sonnet',name:'Claude 3.5 Sonnet',inputPrice:3,outputPrice:15},
{id:'claude-haiku',name:'Claude 3.5 Haiku',inputPrice:0.8,outputPrice:4},
{id:'gemini-flash',name:'Gemini 2.0 Flash',inputPrice:0.1,outputPrice:0.4},
{id:'gemini-pro',name:'Gemini 2.5 Pro',inputPrice:1.25,outputPrice:10},
{id:'deepseek-v3',name:'DeepSeek V3',inputPrice:0.27,outputPrice:1.1},
{id:'deepseek-r1',name:'DeepSeek R1',inputPrice:0.55,outputPrice:2.19},
{id:'llama4-maverick',name:'Llama 4 Maverick',inputPrice:0.2,outputPrice:0.8},
{id:'mistral-large',name:'Mistral Large',inputPrice:2,outputPrice:6},
{id:'mistral-small',name:'Mistral Small',inputPrice:0.2,outputPrice:0.6},
];
// prices in USD per 1M tokens
let selected=new Set(MODELS.map(m=>m.id));
function renderChecks(){const c=document.getElementById('modelChecks');c.innerHTML='';
MODELS.forEach(m=>{const sel=selected.has(m.id);c.innerHTML+=`<label class="model-check${sel?' selected':''}"><input type="checkbox" ${sel?'checked':''} onchange="toggleModel('${m.id}',this.checked)">${m.name}<span class="price-hint">$${m.inputPrice}/$${m.outputPrice}</span></label>`})}
function toggleModel(id,checked){if(checked)selected.add(id);else selected.delete(id);renderChecks();calc()}
function calc(){const it=parseInt(document.getElementById('inputTokens').value)||0;const ot=parseInt(document.getElementById('outputTokens').value)||0;const dc=parseInt(document.getElementById('dailyCalls').value)||0;const md=parseInt(document.getElementById('monthlyDays').value)||30;
const results=[];MODELS.forEach(m=>{if(!selected.has(m.id))return;const ic=it*m.inputPrice/1e6;const oc=ot*m.outputPrice/1e6;const perCall=ic+oc;const daily=perCall*dc;const monthly=daily*md;results.push({...m,inputCost:ic,outputCost:oc,perCall,daily,monthly})});
results.sort((a,b)=>a.monthly-b.monthly);const maxMonthly=results.length?results[results.length-1].monthly:1;
const ra=document.getElementById('resultArea');if(!results.length){ra.innerHTML='<p style="color:#64748b">请选择至少一个模型</p>';return}
let h='<table class="compare-table"><thead><tr><th>模型</th><th>单次费用</th><th>日费用</th><th>月费用</th><th>占比</th></tr></thead><tbody>';
results.forEach((r,i)=>{const cls=i===0?'cheapest':'';const pct=maxMonthly>0?Math.round(r.monthly/maxMonthly*100):0;
const barColor=i===0?'#10b981':pct>70?'#ef4444':pct>40?'#f59e0b':'#06b6d4';
h+=`<tr><td class="${cls}">${r.name}${i===0?' 🏷️最便宜':''}</td><td class="${cls}">$${r.perCall.toFixed(4)}</td><td>$${r.daily.toFixed(2)}</td><td class="${cls}">$${r.monthly.toFixed(2)}</td><td><div class="cost-bar"><div class="cost-bar-fill" style="width:${pct}%;background:${barColor}"></div></div></td></tr>`});
h+='</tbody></table>';ra.innerHTML=h}
function toggleFaq(el){el.classList.toggle('open');el.nextElementSibling.classList.toggle('open')}
renderChecks();calc();
</script>
</body>
</html>
