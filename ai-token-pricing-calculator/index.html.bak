<script type="application/ld+json">{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "name": "AI Token价格计算器常见问题",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "什么是AI Token？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Token是大语言模型处理文本的基本单位。一个Token大约对应0.75个英文单词或0.5个中文字。输入Token是发送给模型的文本，输出Token是模型生成的回复。大多数模型对输入和输出分别定价，输出Token通常更贵。"
      }
    },
    {
      "@type": "Question",
      "name": "价格数据是否最新？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "本工具的价格数据定期更新，但API价格可能随时变动。建议在使用前到各模型官方页面确认最新价格。页面底部标注了价格数据的最后更新日期。"
      }
    },
    {
      "@type": "Question",
      "name": "如何估算Token数量？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "英文文本大约1个单词=1.3个Token，中文文本大约1个字=2个Token。代码和特殊字符会占用更多Token。建议使用各平台提供的Token计算器获取精确数值。"
      }
    },
    {
      "@type": "Question",
      "name": "为什么输出Token比输入Token贵？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "生成输出Token需要模型进行推理计算，计算量远大于处理输入Token。输出阶段的计算成本通常比输入阶段高3-5倍，因此API提供商对输出Token定价更高。"
      }
    },
    {
      "@type": "Question",
      "name": "数据会上传到服务器吗？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "不会。所有计算都在浏览器本地完成，不会上传任何数据。"
      }
    }
  ]
}</script>
