<script>
(function(){
function capitalize(s){if(!s)return'AutoStruct';return s.charAt(0).toUpperCase()+s.slice(1);}
function toSnakeCase(s){return s.replace(/([A-Z])/g,'_$1').toLowerCase().replace(/^_/,'');}
function toCamelCase(s){var parts=s.split(/[-_\s]+/);return parts.map(function(p,i){return i===0?p.toLowerCase():p.charAt(0).toUpperCase()+p.slice(1).toLowerCase();}).join('');}
function toPascalCase(s){var parts=s.split(/[-_\s]+/);return parts.map(function(p){return p.charAt(0).toUpperCase()+p.slice(1).toLowerCase();}).join('');}

function getRustType(val,fieldName,useOption,useInt){
  if(val===null||val===undefined) return useOption?'Option<String>':'String';
  if(typeof val==='string') return useOption?'Option<String>':'String';
  if(typeof val==='boolean') return useOption?'Option<bool>':'bool';
  if(typeof val==='number'){
    if(useInt&&Number.isInteger(val)) return useOption?'Option<i32>':'i32';
    return useOption?'Option<f64>':'f64';
  }
  if(Array.isArray(val)){
    if(val.length===0) return 'Vec<serde_json::Value>';
    var elemType=getRustType(val[0],fieldName,false,useInt).replace('Option<','').replace('>','');
    return 'Vec<'+elemType+'>';
  }
  if(typeof val==='object') return toPascalCase(fieldName);
  return 'serde_json::Value';
}

function jsonToRust(obj,name,useSerde,useOption,useInt,vis,depth){
  depth=depth||0;
  var structs=[];
  var fields=[];
  var serdeAttrs=[];

  for(var key in obj){
    if(!obj.hasOwnProperty(key))continue;
    var val=obj[key];
    var fieldName=toSnakeCase(toCamelCase(key));
    var rustType=getRustType(val,key,useOption,useInt);
    var needsRename=key!==fieldName;

    if(typeof val==='object'&&val!==null&&!Array.isArray(val)){
      var nestedName=toPascalCase(key);
      var nested=jsonToRust(val,nestedName,useSerde,useOption,useInt,vis,depth+1);
      structs=structs.concat(nested);
      if(useOption&&val===null) rustType='Option<'+nestedName+'>';
      else rustType=nestedName;
    }
    if(Array.isArray(val)&&val.length>0&&typeof val[0]==='object'&&val[0]!==null){
      var itemCls=toPascalCase(key)+'Item';
      var nested=jsonToRust(val[0],itemCls,useSerde,useOption,useInt,vis,depth+1);
      structs=structs.concat(nested);
      rustType='Vec<'+itemCls+'>';
    }

    var serdeLine='';
    if(useSerde&&needsRename){
      serdeLine='\t#[serde(rename = "'+key+'")]\n';
    }
    if(useSerde&&useOption&&rustType.indexOf('Option')===0){
      serdeLine+='\t#[serde(default)]\n';
    }
    fields.push(serdeLine+'\t'+vis+' '+fieldName+': '+rustType+',');
  }

  var derive='#[derive(Debug, Clone';
  if(useSerde) derive+=', Serialize, Deserialize';
  derive+=')]';

  var structCode=derive+'\n'+vis+' struct '+name+' {\n'+fields.join('\n')+'\n}';
  structs.unshift(structCode);
  return structs;
}

window.convert=function(){
  var input=document.getElementById('jsonInput').value.trim();
  var errorEl=document.getElementById('jsonError');
  if(!input){errorEl.style.display='none';document.getElementById('resultSection').style.display='none';return;}
  var obj;
  try{obj=JSON.parse(input);}catch(e){errorEl.textContent='❌ JSON解析失败: '+e.message;errorEl.style.display='block';document.getElementById('resultSection').style.display='none';return;}
  errorEl.style.display='none';
  var name=document.getElementById('structName').value.trim()||'AutoStruct';
  var useSerde=document.getElementById('useSerde').checked;
  var useOption=document.getElementById('useOption').checked;
  var useInt=document.getElementById('useInt').checked;
  var vis=document.getElementById('visibility').value;
  var structs=jsonToRust(obj,name,useSerde,useOption,useInt,vis,0);
  var code='use serde::{Serialize, Deserialize};\n\n'+structs.join('\n\n')+'\n';
  document.getElementById('rustOutput').value=code;
  document.getElementById('resultSection').style.display='block';
};

window.loadExample=function(){
  document.getElementById('jsonInput').value=JSON.stringify({"id":1,"name":"张三","email":"zhangsan@example.com","age":25,"is_active":true,"score":98.5,"address":{"province":"北京市","city":"北京","street":"朝阳区建国路88号"},"tags":["rust","backend","systems"],"projects":[{"name":"app-v2","status":"active","stars":128}],"avatar_url":null},null,2);
  document.getElementById('structName').value='User';
  convert();
};

window.formatJSON=function(){var input=document.getElementById('jsonInput').value.trim();if(!input)return;try{var obj=JSON.parse(input);document.getElementById('jsonInput').value=JSON.stringify(obj,null,2);document.getElementById('jsonError').style.display='none';}catch(e){document.getElementById('jsonError').textContent='❌ JSON格式化失败: '+e.message;document.getElementById('jsonError').style.display='block';}};

window.clearAll=function(){document.getElementById('jsonInput').value='';document.getElementById('rustOutput').value='';document.getElementById('jsonError').style.display='none';document.getElementById('resultSection').style.display='none';};
window.copyResult=function(){var text=document.getElementById('rustOutput').value;if(navigator.clipboard)navigator.clipboard.writeText(text).then(showCopyMsg);};
window.downloadResult=function(){var text=document.getElementById('rustOutput').value;var blob=new Blob([text],{type:'text/plain'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='model.rs';a.click();};

function showCopyMsg(){var msg=document.createElement('div');msg.textContent='✓ 已复制到剪贴板';msg.style.cssText='position:fixed;top:20px;right:20px;background:rgba(34,197,94,.2);color:#4ade80;padding:8px 16px;border-radius:8px;font-size:.85rem;z-index:9999;border:1px solid rgba(34,197,94,.3)';document.body.appendChild(msg);setTimeout(function(){msg.remove();},2000);}

document.getElementById('jsonInput').addEventListener('input',function(){clearTimeout(window._debounce);window._debounce=setTimeout(function(){var v=document.getElementById('jsonInput').value.trim();if(v.length>2){try{JSON.parse(v);convert();}catch(e){}}},500);});

var ta=document.getElementById('jsonInput');
ta.addEventListener('dragover',function(e){e.preventDefault();this.style.borderColor='rgba(6,182,212,.5)';});
ta.addEventListener('dragleave',function(e){this.style.borderColor='';});
ta.addEventListener('drop',function(e){e.preventDefault();this.style.borderColor='';var file=e.dataTransfer.files[0];if(file){var reader=new FileReader();reader.onload=function(ev){ta.value=ev.target.result;convert();};reader.readAsText(file);}});

document.addEventListener('keydown',function(e){if(e.ctrlKey&&e.key==='Enter'){convert();e.preventDefault();}if(e.ctrlKey&&e.shiftKey&&e.key==='C'){copyResult();e.preventDefault();}});

loadExample();
})();
</script>
