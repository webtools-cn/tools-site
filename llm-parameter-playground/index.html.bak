<script>
function updateParam() {
  const temp = parseFloat(document.getElementById('temperature').value);
  const topp = parseFloat(document.getElementById('top-p').value);
  const topk = parseInt(document.getElementById('top-k').value);
  const freq = parseFloat(document.getElementById('freq-penalty').value);
  const pres = parseFloat(document.getElementById('pres-penalty').value);
  const maxtok = parseInt(document.getElementById('max-tokens').value);
  document.getElementById('temp-val').textContent = temp.toFixed(2);
  document.getElementById('topp-val').textContent = topp.toFixed(2);
  document.getElementById('topk-val').textContent = topk === 0 ? '0 (禁用)' : topk;
  document.getElementById('freq-val').textContent = freq.toFixed(2);
  document.getElementById('pres-val').textContent = pres.toFixed(2);
  document.getElementById('maxtok-val').textContent = maxtok;
  drawDistribution(temp, topp);
}

function applyPreset(name) {
  const presets = {
    code: {temp:0.1, topp:0.9, topk:0, freq:0, pres:0, maxtok:2048},
    creative: {temp:0.8, topp:0.92, topk:0, freq:0.3, pres:0.2, maxtok:4096},
    brainstorm: {temp:1.2, topp:0.95, topk:0, freq:0.5, pres:0.5, maxtok:2048},
    factual: {temp:0, topp:1.0, topk:0, freq:0, pres:0, maxtok:1024},
    chat: {temp:0.7, topp:0.9, topk:0, freq:0.3, pres:0.1, maxtok:2048},
    analysis: {temp:0.2, topp:0.85, topk:0, freq:0.1, pres:0, maxtok:4096}
  };
  const p = presets[name];
  if (!p) return;
  document.getElementById('temperature').value = p.temp;
  document.getElementById('top-p').value = p.topp;
  document.getElementById('top-k').value = p.topk;
  document.getElementById('freq-penalty').value = p.freq;
  document.getElementById('pres-penalty').value = p.pres;
  document.getElementById('max-tokens').value = p.maxtok;
  updateParam();
  showToast('已应用预设: ' + name);
}

function resetParams() {
  applyPreset('chat');
}

function drawDistribution(temp, topp) {
  const canvas = document.getElementById('dist-canvas');
  const ctx = canvas.getContext('2d');
  const W = canvas.width = canvas.parentElement.clientWidth - 2;
  const H = canvas.height = 280;
  ctx.clearRect(0, 0, W, H);

  const tokens = ['AI','the','is','a','and','of','to','in','for','on','with','as','by','at','an','be','or','not','this','that'];
  const rawProbs = [0.15, 0.12, 0.10, 0.08, 0.07, 0.06, 0.05, 0.04, 0.04, 0.03, 0.03, 0.03, 0.02, 0.02, 0.02, 0.02, 0.02, 0.02, 0.02, 0.02];

  const t = Math.max(temp, 0.01);
  const logits = rawProbs.map(p => Math.log(Math.max(p, 1e-10)));
  const scaledLogits = logits.map(l => l / t);
  const maxLogit = Math.max(...scaledLogits);
  const expLogits = scaledLogits.map(l => Math.exp(l - maxLogit));
  const sumExp = expLogits.reduce((a, b) => a + b, 0);
  const temperedProbs = expLogits.map(e => e / sumExp);

  let cumProb = 0;
  const toppIdx = temperedProbs.findIndex((p, i) => {
    cumProb += p;
    return cumProb >= topp;
  });

  const barW = (W - 60) / tokens.length;
  const maxProb = Math.max(...temperedProbs);
  const barMaxH = H - 60;

  ctx.fillStyle = '#64748b';
  ctx.font = '11px sans-serif';
  ctx.textAlign = 'center';

  for (let i = 0; i < tokens.length; i++) {
    const x = 40 + i * barW;
    const h = (temperedProbs[i] / maxProb) * barMaxH;
    const y = H - 30 - h;

    if (i <= toppIdx) {
      const grad = ctx.createLinearGradient(x, y, x, H - 30);
      grad.addColorStop(0, 'rgba(6,182,212,0.8)');
      grad.addColorStop(1, 'rgba(6,182,212,0.2)');
      ctx.fillStyle = grad;
    } else {
      ctx.fillStyle = 'rgba(100,116,139,0.3)';
    }
    ctx.fillRect(x + 2, y, barW - 4, h);

    ctx.fillStyle = i <= toppIdx ? '#22d3ee' : '#475569';
    ctx.fillText(tokens[i], x + barW / 2, H - 14);

    if (temperedProbs[i] > 0.01) {
      ctx.fillStyle = i <= toppIdx ? '#e2e8f0' : '#475569';
      ctx.font = '9px sans-serif';
      ctx.fillText((temperedProbs[i] * 100).toFixed(1) + '%', x + barW / 2, y - 4);
      ctx.font = '11px sans-serif';
    }
  }

  if (toppIdx >= 0 && toppIdx < tokens.length - 1) {
    const cutoffX = 40 + (toppIdx + 1) * barW;
    ctx.strokeStyle = 'rgba(239,68,68,0.6)';
    ctx.setLineDash([4, 4]);
    ctx.beginPath();
    ctx.moveTo(cutoffX, 10);
    ctx.lineTo(cutoffX, H - 30);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = '#f87171';
    ctx.font = '10px sans-serif';
    ctx.fillText('Top-P截止', cutoffX + 30, 20);
  }

  ctx.fillStyle = '#94a3b8';
  ctx.font = '11px sans-serif';
  ctx.textAlign = 'left';
  ctx.fillText('T=' + temp.toFixed(2) + '  Top-P=' + topp.toFixed(2), 10, 16);
}

function generateConfig() {
  const temp = parseFloat(document.getElementById('temperature').value);
  const topp = parseFloat(document.getElementById('top-p').value);
  const topk = parseInt(document.getElementById('top-k').value);
  const freq = parseFloat(document.getElementById('freq-penalty').value);
  const pres = parseFloat(document.getElementById('pres-penalty').value);
  const maxtok = parseInt(document.getElementById('max-tokens').value);

  const config = {
    model: "gpt-4",
    temperature: temp,
    top_p: topp,
    max_tokens: maxtok,
    frequency_penalty: freq,
    presence_penalty: pres
  };
  if (topk > 0) config.top_k = topk;

  const output = `// OpenAI API 调用示例
const response = await openai.chat.completions.create(${JSON.stringify(config, null, 2).replace('"model"', 'model').replace('"temperature"', 'temperature').replace('"top_p"', 'top_p').replace('"max_tokens"', 'max_tokens').replace('"frequency_penalty"', 'frequency_penalty').replace('"presence_penalty"', 'presence_penalty').replace('"top_k"', 'top_k')});

// Python 示例
# response = client.chat.completions.create(
${Object.entries(config).map(([k,v]) => `#   ${k}=${typeof v==='string'?`"${v}"`:v},`).join('\n')}
# )`;

  document.getElementById('config-section').style.display = 'block';
  document.getElementById('config-output').textContent = JSON.stringify(config, null, 2);
}

function copyConfig() {
  const text = document.getElementById('config-output')?.textContent;
  if (text) navigator.clipboard.writeText(text).then(() => showToast('已复制配置'));
}

function showToast(msg){const t=document.getElementById('toast')||(()=>{const d=document.createElement('div');d.id='toast';d.className='toast';document.body.appendChild(d);return d;})();t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000);}

window.addEventListener('load', () => { updateParam(); });
window.addEventListener('resize', () => { updateParam(); });
document.addEventListener('keydown', function(e) { if(e.ctrlKey && e.key==='Enter') { generateConfig(); e.preventDefault(); } });
</script>
