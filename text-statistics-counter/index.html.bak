<script>
(function(){
var sampleText='欢迎使用文本统计计数器！\n\n这是一个免费的在线文本统计工具。\n它可以实时统计字符数、字数、句数、段落数等多项指标。\n\n支持中文和英文混合文本统计。\n所有数据在浏览器本地处理，不会上传到服务器。\n\n试试看：在文本框中输入或粘贴任意文字，统计数据会立即更新。';
document.getElementById('app').innerHTML=
'<div class="card">'+
'  <h2>✏️ 输入文本</h2>'+
'  <textarea id="textInput">'+sampleText.replace(/</g,'&lt;').replace(/>/g,'&gt;')+'</textarea>'+
'  <div class="stat-grid" id="statGrid"></div>'+
'</div>';
function update(){
  var t=document.getElementById('textInput').value;
  var charsWith=t.length;
  var charsWithout=t.replace(/\\s/g,'').length;
  var words=t.trim()?t.trim().split(/[\\s，。！？、；：""''（）【】《》\u3000,.!?;:()]+/).filter(function(w){return w.length>0;}).length:0;
  var sentences=t.split(/[。！？.!?]+/).filter(function(s){return s.trim().length>0;}).length;
  var paragraphs=t.split(/\\n\\s*\\n/).filter(function(p){return p.trim().length>0;}).length;
  if(paragraphs===0&&t.trim().length>0) paragraphs=1;
  var lines=t.split(/\\n/).filter(function(l){return true;}).length;
  var nonChinese=t.replace(/[\\u4e00-\\u9fff\\u3400-\\u4dbf]/g,'').length;
  var digits=(t.match(/\\d/g)||[]).length;
  var stats=[
    {num:charsWith,label:'字符数(含空格)'},
    {num:charsWithout,label:'字符数(不含空格)'},
    {num:words,label:'字数'},
    {num:sentences,label:'句数'},
    {num:paragraphs,label:'段落数'},
    {num:lines,label:'行数'},
    {num:nonChinese,label:'非中文字符'},
    {num:digits,label:'数字数'}
  ];
  var html='';
  stats.forEach(function(s){
    html+='<div class="stat-item"><div class="num">'+s.num+'</div><div class="label">'+s.label+'</div></div>';
  });
  document.getElementById('statGrid').innerHTML=html;
}
document.getElementById('textInput').addEventListener('input',update);
update();
})();
</script>
