<div class="toast" id="toast"></div>

<script>
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000)}

function updatePlaceholder(){
  const mode=document.getElementById('mode-select').value;
  document.getElementById('code-input').placeholder=mode==='schema'?'粘贴GraphQL Schema (SDL)...':'粘贴GraphQL查询或变更...';
}

function formatGraphQL(code){
  let formatted='';let level=0;const indent='  ';
  const lines=code.replace(/\{/g,' {\n').replace(/\}/g,'\n}\n').replace(/,/g,',\n').split('\n');
  lines.forEach(line=>{
    const trimmed=line.trim();if(!trimmed)return;
    if(trimmed==='{'||trimmed.endsWith('{')){formatted+=indent.repeat(level)+trimmed+'\n';level++;return}
    if(trimmed==='}'){level=Math.max(0,level-1);formatted+=indent.repeat(level)+trimmed+'\n';return}
    formatted+=indent.repeat(level)+trimmed+'\n';
  });
  return formatted.trim();
}

function formatCode(){
  const code=document.getElementById('code-input').value;
  if(!code){showToast('请输入GraphQL代码');return}
  const result=formatGraphQL(code);
  document.getElementById('code-output').value=result;
  showToast('格式化完成');
}

function parseSchema(){
  const code=document.getElementById('code-input').value;
  if(!code){showToast('请输入Schema代码');return}
  const types=[];
  const typeRegex=/\b(type|input|enum|interface|union|scalar)\s+(\w+)(?:\s+implements\s+[\w&\s]+)?\s*\{([^}]*)\}/g;
  let match;
  while((match=typeRegex.exec(code))!==null){
    const kind=match[1];
    const name=match[2];
    const body=match[3];
    const fields=body.split('\n').map(l=>l.trim()).filter(l=>l&&!l.startsWith('#'));
    types.push({kind,name,fields});
  }
  const queryRegex=/\b(type\s+Query\s*\{[^}]*\})/g;
  const mutationRegex=/\b(type\s+Mutation\s*\{[^}]*\})/g;
  if(!types.length){
    document.getElementById('schema-result').innerHTML='<p style="color:#ef4444;font-size:.85rem">未检测到有效的GraphQL Schema类型定义</p>';
    return;
  }
  let html='';
  types.forEach(t=>{
    html+=`<div class="type-card"><h4>${t.kind} ${t.name}</h4><ul class="field-list">`;
    t.fields.forEach(f=>{
      const parts=f.split(':');
      const fieldName=parts[0].trim();
      const fieldType=parts.slice(1).join(':').trim();
      html+=`<li><span>${fieldName}</span>${fieldType?': '+fieldType:''}</li>`;
    });
    html+='</ul></div>';
  });
  document.getElementById('schema-result').innerHTML=html;
  showToast(`解析完成: ${types.length}个类型`);
}

function copyResult(){
  const code=document.getElementById('code-output').value;
  if(!code){showToast('没有内容可复制');return}
  navigator.clipboard.writeText(code).then(()=>showToast('已复制到剪贴板'));
}

function downloadResult(){
  const code=document.getElementById('code-output').value;
  if(!code){showToast('没有内容可下载');return}
  const blob=new Blob([code],{type:'text/plain'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='schema.graphql';a.click();
  URL.revokeObjectURL(a.href);showToast('文件已下载');
}

function loadExample(){
  document.getElementById('mode-select').value='schema';
  document.getElementById('code-input').value=`type Query {
  user(id: ID!): User
  users(limit: Int, offset: Int): [User!]!
  post(id: ID!): Post
  posts(filter: PostFilter): [Post!]!
}

type Mutation {
  createUser(input: CreateUserInput!): User!
  updateUser(id: ID!, input: UpdateUserInput!): User!
  deleteUser(id: ID!): Boolean!
  createPost(input: CreatePostInput!): Post!
}

type User {
  id: ID!
  name: String!
  email: String!
  avatar: String
  posts: [Post!]!
  createdAt: String!
}

type Post {
  id: ID!
  title: String!
  content: String!
  author: User!
  tags: [String!]!
  createdAt: String!
}

input CreateUserInput {
  name: String!
  email: String!
  avatar: String
}

input UpdateUserInput {
  name: String
  email: String
  avatar: String
}

input CreatePostInput {
  title: String!
  content: String!
  tags: [String!]
}

input PostFilter {
  authorId: ID
  tag: String
}`;
  showToast('示例已加载');
}

function clearAll(){
  document.getElementById('code-input').value='';
  document.getElementById('code-output').value='';
  document.getElementById('schema-result').innerHTML='<p style="color:#64748b;font-size:.85rem">输入Schema后点击"解析Schema"查看类型结构</p>';
}

document.addEventListener('keydown',function(e){
  if(e.ctrlKey&&e.key==='Enter'){formatCode();e.preventDefault()}
  if(e.ctrlKey&&e.shiftKey&&e.key==='C'){copyResult();e.preventDefault()}
});
</script>
</body>
</html>