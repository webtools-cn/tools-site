<script type="application/ld+json">{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "name": "什么是GraphQL?",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "什么是GraphQL?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GraphQL是Facebook开发的API查询语言，允许客户端精确指定需要的数据，避免过度获取或不足获取。与REST不同，GraphQL使用单一端点，通过类型系统定义数据结构，支持嵌套查询和实时订阅。"
      }
    },
    {
      "@type": "Question",
      "name": "GraphQL和REST有什么区别?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "主要区别：1)GraphQL单一端点vs REST多端点；2)GraphQL客户端指定数据vs REST服务端固定返回；3)GraphQL强类型系统vs REST无类型约束；4)GraphQL避免过度获取vs REST常返回多余数据；5)GraphQL支持嵌套查询vs REST需多次请求。"
      }
    },
    {
      "@type": "Question",
      "name": "什么是GraphQL Schema?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Schema是GraphQL的类型系统定义，描述API支持的所有数据类型、查询和变更操作。它使用Schema Definition Language(SDL)编写，包含Query(查询)、Mutation(变更)和Subscription(订阅)三种根类型。"
      }
    },
    {
      "@type": "Question",
      "name": "如何格式化GraphQL查询?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "本工具自动将GraphQL查询按照标准格式化：统一缩进2空格、每个字段独占一行、规范花括号位置、整理参数和指令。也可手动调整缩进方式。"
      }
    },
    {
      "@type": "Question",
      "name": "数据会上传到服务器吗?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "不会。所有GraphQL解析和格式化都在浏览器本地完成，您的Schema和查询不会发送到任何服务器。"
      }
    }
  ]
}</script>
