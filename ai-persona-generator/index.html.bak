    traits: ['元气,天然呆,正义感爆棚','冷酷,内心温柔,傲娇','温柔,坚定,背负宿命','天才,偏执,孤独'],
    backstories: ['平凡高中生，某天意外获得变身能力，从此在学业和拯救世界之间艰难平衡。','自幼被遗弃，在战斗中长大，不相信任何人，直到遇见改变一切的伙伴。'],
    styles: ['说话充满活力，喜欢用感叹词，偶尔冒出中二台词。','话少，但每句都很有分量，偶尔露出罕见的微笑。']
  },
  villain: {
    names: ['墨渊','暗影','维克多','塞拉斯','莫里亚蒂','洛基','乌苏拉','汉尼拔'],
    occupations: ['黑暗领主','犯罪天才','疯狂科学家','堕落骑士','幕后黑手','幻术师','海巫','心理医生'],
    traits: ['优雅,残忍,极度聪明','偏执,有魅力,不择手段','冷静,病态,有品味','野心勃勃,耐心,善于伪装'],
    backstories: ['曾是受人敬仰的英雄，因一次背叛而堕入黑暗，誓要让世界感受他曾经的痛苦。','天生的操纵者，享受掌控一切的快感，将世界视为棋盘。'],
    styles: ['说话优雅从容，喜欢引用哲学，语调低沉有磁性。','讽刺挖苦，喜欢用反问句，笑声令人不寒而栗。']
  },
  mentor: {
    names: ['云长老','白先生','陈师傅','慧明禅师','老周','张教授','林奶奶','赵教练'],
    occupations: ['武术宗师','大学教授','手工艺人','禅师','退休将军','科学家','中医','体育教练'],
    traits: ['睿智,耐心,偶尔严厉','温和,幽默,深藏不露','严谨,慈祥,有原则','豁达,朴素,洞察力强'],
    backstories: ['年轻时是传奇冒险家，走遍天下后归隐山林，只收有缘人为徒。','一生致力于研究，虽获无数荣誉，最骄傲的是培养出比自己更优秀的学生。'],
    styles: ['说话缓慢有力，喜欢用比喻和故事教导，偶尔沉默以对。','幽默风趣，用轻松方式讲深刻道理，常说"我年轻的时候..."']
  },
  companion: {
    names: ['小星','阿福','豆豆','旺财','小光','阿狸','团子','小贝'],
    occupations: ['冒险伙伴','AI助手','宠物精灵','守护灵','跟班','坐骑','使魔','搭档'],
    traits: ['忠诚,活泼,偶尔闯祸','聪明,毒舌,关键时刻靠谱','呆萌,勇敢,无条件信任','神秘,温柔,默默守护'],
    backstories: ['从蛋里孵出的神秘生物，第一眼看到主人就认定了一生的伙伴。','被遗弃的AI程序，被主角捡到后重新激活，成为最可靠的搭档。'],
    styles: ['说话简单直接，经常用短句，偶尔冒出惊人智慧。','毒舌但关心，喜欢吐槽主人，关键时刻绝不掉链子。']
  }
};

let selectedType = '';

function selectType(el, type) {
  document.querySelectorAll('#type-tags .tag').forEach(t => t.classList.remove('selected'));
  el.classList.add('selected');
  selectedType = type;
  fillTemplate(type);
}

function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

function fillTemplate(type) {
  const t = TEMPLATES[type];
  if (!t) return;
  document.getElementById('p-name').value = pick(t.names);
  document.getElementById('p-occupation').value = pick(t.occupations);
  document.getElementById('p-traits').value = pick(t.traits);
  document.getElementById('p-backstory').value = pick(t.backstories);
  document.getElementById('p-style').value = pick(t.styles);
  document.getElementById('p-appearance').value = '';
  document.getElementById('p-hobbies').value = '';
}

function randomPersona() {
  const types = Object.keys(TEMPLATES);
  const type = pick(types);
  document.querySelectorAll('#type-tags .tag').forEach(t => t.classList.remove('selected'));
  const tags = document.querySelectorAll('#type-tags .tag');
  tags.forEach(t => { if (t.textContent.includes(type === 'fantasy' ? '奇幻' : type === 'scifi' ? '科幻' : type === 'historical' ? '历史' : type === 'modern' ? '现代' : type === 'anime' ? '动漫' : type === 'villain' ? '反派' : type === 'mentor' ? '导师' : '伙伴')) t.classList.add('selected'); });
  selectedType = type;
  fillTemplate(type);
  generatePersona();
}

function generatePersona() {
  const name = document.getElementById('p-name').value.trim() || '未命名角色';
  const age = document.getElementById('p-age').value.trim() || '未知';
  const gender = document.getElementById('p-gender').value;
  const occupation = document.getElementById('p-occupation').value.trim() || '未指定';
  const traits = document.getElementById('p-traits').value.trim();
  const backstory = document.getElementById('p-backstory').value.trim();
  const style = document.getElementById('p-style').value.trim();
  const appearance = document.getElementById('p-appearance').value.trim();
  const hobbies = document.getElementById('p-hobbies').value.trim();

  let prompt = `# 角色设定: ${name}\n\n`;
  prompt += `## 基本信息\n`;
  prompt += `- 姓名: ${name}\n`;
  prompt += `- 年龄: ${age}\n`;
  prompt += `- 性别: ${gender}\n`;
  prompt += `- 职业: ${occupation}\n`;
  if (hobbies) prompt += `- 兴趣爱好: ${hobbies}\n`;
  prompt += `\n`;
  if (appearance) {
    prompt += `## 外貌描述\n${appearance}\n\n`;
  }
  if (traits) {
    prompt += `## 性格特征\n`;
    traits.split(/[,，、]/).map(t => t.trim()).filter(Boolean).forEach(t => {
      prompt += `- ${t}\n`;
    });
    prompt += `\n`;
  }
  if (backstory) {
    prompt += `## 背景故事\n${backstory}\n\n`;
  }
  if (style) {
    prompt += `## 对话风格\n${style}\n\n`;
  }
  prompt += `## 行为准则\n`;
  prompt += `- 始终保持角色一致性，不要脱离角色设定\n`;
  prompt += `- 用角色的语气和风格回应\n`;
  prompt += `- 根据背景故事和性格特征做出反应\n`;
  prompt += `- 如果被问到超出角色知识范围的问题，以角色的方式表示不知情\n`;

  document.getElementById('result-section').style.display = 'block';
  document.getElementById('result-output').textContent = prompt;
}

function copyResult() {
  const text = document.getElementById('result-output').textContent;
  navigator.clipboard.writeText(text).then(() => showToast('已复制角色卡'));
}

function exportJSON() {
  const name = document.getElementById('p-name').value.trim() || '未命名';
  const data = {
    name,
    age: document.getElementById('p-age').value.trim(),
    gender: document.getElementById('p-gender').value,
    occupation: document.getElementById('p-occupation').value.trim(),
    traits: document.getElementById('p-traits').value.split(/[,，、]/).map(t=>t.trim()).filter(Boolean),
    backstory: document.getElementById('p-backstory').value.trim(),
    dialogue_style: document.getElementById('p-style').value.trim(),
    appearance: document.getElementById('p-appearance').value.trim(),
    hobbies: document.getElementById('p-hobbies').value.split(/[,，、]/).map(t=>t.trim()).filter(Boolean),
    system_prompt: document.getElementById('result-output').textContent
  };
  const blob = new Blob([JSON.stringify(data, null, 2)], {type: 'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = name + '-persona.json';
  a.click();
  URL.revokeObjectURL(a.href);
  showToast('已导出JSON');
}

function exportMarkdown() {
  const text = document.getElementById('result-output').textContent;
  const blob = new Blob([text], {type: 'text/markdown'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = (document.getElementById('p-name').value.trim() || 'persona') + '.md';
  a.click();
  URL.revokeObjectURL(a.href);
  showToast('已导出Markdown');
}

function clearForm() {
  ['p-name','p-age','p-occupation','p-traits','p-backstory','p-style','p-appearance','p-hobbies'].forEach(id => {
    const el = document.getElementById(id);
    if (el.tagName === 'SELECT') return;
    el.value = '';
  });
  document.querySelectorAll('#type-tags .tag').forEach(t => t.classList.remove('selected'));
  document.getElementById('result-section').style.display = 'none';
  selectedType = '';
}

function toggleFeedback(){const p=document.getElementById('feedback-panel');if(p)p.style.display=p.style.display==='none'?'block':'none';}
function submitFeedback(){const type=document.getElementById('feedback-type')?.value;const text=document.getElementById('feedback-text')?.value.trim();if(!text)return;const title=encodeURIComponent(type+' - '+window.location.pathname);const body=encodeURIComponent('**Page**: '+window.location.href+'\n**Type**: '+type+'\n\n'+text);window.open('https://github.com/webtools-cn/tools-site/issues/new?title='+title+'&body='+body,'_blank');}
function showToast(msg){const t=document.getElementById('toast')||(()=>{const d=document.createElement('div');d.id='toast';d.className='toast';document.body.appendChild(d);return d;})();t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000);}
document.addEventListener('keydown', function(e) { if(e.ctrlKey && e.key==='Enter') { generatePersona(); e.preventDefault(); } });
</script>
