.input-row input:focus{outline:none;border-color:#06b6d4}
.input-row input[type="number"]{width:80px;flex:none;text-align:center}
.matrix-table{width:100%;border-collapse:collapse;margin-top:12px}
.matrix-table th,.matrix-table td{padding:10px 8px;text-align:center;border:1px solid rgba(148,163,184,.1);font-size:.85rem}
