.result-bar{display:flex;align-items:center;gap:12px;margin-bottom:10px;padding:10px 14px;border-radius:8px;background:rgba(148,163,184,.05);border:1px solid rgba(148,163,184,.08)}
.result-bar .rank{font-size:1.2rem;font-weight:700;color:#06b6d4;min-width:30px}
