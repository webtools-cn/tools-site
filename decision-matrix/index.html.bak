.matrix-table th:first-child,.matrix-table td:first-child{text-align:left;color:#e2e8f0;font-weight:500}
.matrix-table td input{width:50px;padding:4px 6px;border-radius:4px;border:1px solid rgba(148,163,184,.2);background:rgba(148,163,184,.05);color:#e2e8f0;text-align:center;font-size:.85rem}
.matrix-table td input:focus{outline:none;border-color:#06b6d4}
.matrix-table .weight-cell{color:#f59e0b;font-weight:600}
.matrix-table .score-cell{font-weight:700;font-size:1rem}
.score-best{color:#10b981}
.score-good{color:#06b6d4}
