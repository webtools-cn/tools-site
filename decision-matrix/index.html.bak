<script>
let options=[];
let criteria=[];
function addOption(){const n=document.getElementById('optionInput').value.trim();if(!n)return;if(options.includes(n)){document.getElementById('optionInput').value='';return}options.push(n);document.getElementById('optionInput').value='';render()}
function addCriteria(){const n=document.getElementById('criteriaInput').value.trim();const w=parseInt(document.getElementById('weightInput').value)||10;if(!n)return;if(criteria.find(c=>c.name===n)){document.getElementById('criteriaInput').value='';return}criteria.push({name:n,weight:w});document.getElementById('criteriaInput').value='';document.getElementById('weightInput').value='10';render()}
function removeOption(i){options.splice(i,1);render()}
function removeCriteria(i){criteria.splice(i,1);render()}
function render(){const ta=document.getElementById('tagsArea');let h='';options.forEach((o,i)=>{h+=`<span class="tag tag-option">${o} <a href="#" onclick="removeOption(${i});return false" style="color:#10b981;text-decoration:none;margin-left:4px">×</a></span>`});criteria.forEach((c,i)=>{h+=`<span class="tag tag-criteria">${c.name}(${c.weight}%) <a href="#" onclick="removeCriteria(${i});return false" style="color:#06b6d4;text-decoration:none;margin-left:4px">×</a></span>`});ta.innerHTML=h;
const tw=criteria.reduce((s,c)=>s+c.weight,0);const ww=document.getElementById('weightWarning');if(tw!==100&&criteria.length>0){ww.style.display='block';ww.textContent=`⚠️ 权重总和为${tw}%，建议调整为100%`}else{ww.style.display='none'}
const ma=document.getElementById('matrixArea');if(!options.length||!criteria.length){ma.innerHTML='<p style="color:#64748b;font-size:.9rem">请添加选项和评估标准</p>';document.getElementById('resultArea').innerHTML='<p style="color:#64748b;font-size:.9rem">添加选项和标准后，评分即可查看结果</p>';return}
let t='<table class="matrix-table"><thead><tr><th>标准\\选项</th>';options.forEach(o=>{t+=`<th>${o}</th>`});t+='</tr></thead><tbody>';
criteria.forEach((c,ci)=>{t+=`<tr><td>${c.name} <span class="weight-cell">(${c.weight}%)</span></td>`;options.forEach((_,oi)=>{const v=getScore(oi,ci);t+=`<td><input type="number" min="1" max="5" value="${v||3}" onchange="setScore(${oi},${ci},this.value)" onfocus="this.select()"></td>`});t+='</tr>'});t+='</tbody></table>';ma.innerHTML=t;calcResult()}
function getScore(oi,ci){const k=`s_${oi}_${ci}`;return window._scores&&window._scores[k]?window._scores[k]:3}
function setScore(oi,ci,v){if(!window._scores)window._scores={};v=Math.max(1,Math.min(5,parseInt(v)||3));window._scores[`s_${oi}_${ci}`]=v;calcResult()}
function calcResult(){const tw=criteria.reduce((s,c)=>s+c.weight,0)||1;const results=options.map((o,oi)=>{let total=0;criteria.forEach((c,ci)=>{const sc=getScore(oi,ci);total+=sc*(c.weight/tw)});return{name:o,total:Math.round(total*100)/100}});results.sort((a,b)=>b.total-a.total);const max=results[0]?results[0].total:5;const ra=document.getElementById('resultArea');let h='';results.forEach((r,i)=>{const pct=max>0?Math.round((r.total/max)*100):0;const cls=r.total>=4?'score-best':r.total>=3?'score-good':'score-low';const color=r.total>=4?'#10b981':r.total>=3?'#06b6d4':'#ef4444';h+=`<div class="result-bar"><span class="rank">#${i+1}</span><span class="name">${r.name}</span><div class="bar-wrap"><div class="bar-fill" style="width:${pct}%;background:${color}"></div></div><span class="total ${cls}">${r.total.toFixed(2)}</span></div>`});ra.innerHTML=h}
function exportResult(){const tw=criteria.reduce((s,c)=>s+c.weight,0)||1;const data={options,criteria,weights:criteria.map(c=>c.weight),scores:{},results:[]};options.forEach((o,oi)=>{criteria.forEach((c,ci)=>{data.scores[`${o}_${c.name}`]=getScore(oi,ci)});let total=0;criteria.forEach((c,ci)=>{total+=getScore(oi,ci)*(c.weight/tw)});data.results.push({name:o,total:Math.round(total*100)/100})});data.results.sort((a,b)=>b.total-a.total);const blob=new Blob([JSON.stringify(data,null,2)],{type:'application/json'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='decision-matrix-result.json';a.click()}
function copyResult(){const tw=criteria.reduce((s,c)=>s+c.weight,0)||1;let txt='决策矩阵结果\n'+'='.repeat(30)+'\n';options.forEach((o,oi)=>{let total=0;criteria.forEach((c,ci)=>{total+=getScore(oi,ci)*(c.weight/tw)});txt+=`${o}: ${total.toFixed(2)}分\n`});navigator.clipboard.writeText(txt).then(()=>alert('已复制到剪贴板'))}
function resetAll(){options=[];criteria=[];window._scores={};render()}
function toggleFaq(el){el.classList.toggle('open');el.nextElementSibling.classList.toggle('open')}
window._scores={};
</script>
</body>
</html>
