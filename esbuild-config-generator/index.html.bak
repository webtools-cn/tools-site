.checkbox-group label{display:flex;align-items:center;gap:6px;font-size:.95rem;cursor:pointer}
.checkbox-group input[type="checkbox"]{width:18px;height:18px;accent-color:var(--accent)}
.code-output{position:relative}
.code-output pre{background:#0c1222;border:1px solid var(--border);border-radius:8px;padding:16px;overflow-x:auto;font-size:13px;line-height:1.5;color:#e2e8f0;max-height:600px;overflow-y:auto}
.code-output .copy-btn{position:absolute;top:8px;right:8px;padding:6px 12px;font-size:12px}
.section-title{font-size:.9rem;color:var(--text-secondary);text-transform:uppercase;letter-spacing:1px;margin:20px 0 12px;padding-bottom:4px;border-bottom:1px solid var(--border)}
.ad-slot{margin:0 auto;text-align:center;max-width:960px}.ad-slot:not(:has(ins[frame])){display:none}.ad-slot:empty{display:none}.ad-slot ins{display:block}.ad-slot.ad-sidebar{max-width:300px}
.faq-item{margin-bottom:16px}
