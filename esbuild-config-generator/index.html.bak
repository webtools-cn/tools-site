        <a href="../en/esbuild-config-generator/">EN</a>
      </div>
      <p>esbuild配置生成器 · 纯前端本地处理 · 数据绝不上传服务器</p>
      <p style="margin-top:8px;color:#475569;font-size:.8rem">问题反馈: dexshuang@google.com</p>
    </div>
</div>

<script>
// Toggle JSX config visibility
document.getElementById('jsx').addEventListener('change', function() {
    document.getElementById('jsxConfig').style.display = this.checked ? 'block' : 'none';
});
document.getElementById('defineEnv').addEventListener('change', function() {
    document.getElementById('envConfig').style.display = this.checked ? 'block' : 'none';
});

function generate() {
    const entryPoint = document.getElementById('entryPoint').value.trim();
    const outdir = document.getElementById('outdir').value.trim();
    const format = document.getElementById('format').value;
    const platform = document.getElementById('platform').value;
    const target = document.getElementById('target').value;
    const scriptType = document.getElementById('scriptType').value;
    const bundle = document.getElementById('bundle').checked;
    const minify = document.getElementById('minify').checked;
    const sourcemap = document.getElementById('sourcemap').checked;
    const treeShaking = document.getElementById('treeShaking').checked;
    const splitting = document.getElementById('splitting').checked;
    const jsx = document.getElementById('jsx').checked;
    const defineEnv = document.getElementById('defineEnv').checked;
    const metafile = document.getElementById('metafile').checked;
    const jsxMode = document.getElementById('jsxMode').value;
    const jsxFactory = document.getElementById('jsxFactory').value.trim();
    const jsxFragment = document.getElementById('jsxFragment').value.trim();
    const jsxImportSource = document.getElementById('jsxImportSource').value.trim();
    const envVars = document.getElementById('envVars').value.trim();
    const external = document.getElementById('external').value.trim();
    const aliasRules = document.getElementById('aliasRules').value.trim();
    const pluginEnv = document.getElementById('pluginEnv').checked;
    const pluginHtml = document.getElementById('pluginHtml').checked;
    const pluginSvg = document.getElementById('pluginSvg').checked;
    const pluginInlineWorker = document.getElementById('pluginInlineWorker').checked;

    let code = `import esbuild from 'esbuild';\n\n`;
    let plugins = [];
    let pluginImports = [];

    if (pluginEnv) {
        pluginImports.push(`import envPlugin from 'esbuild-plugin-env';`);
        plugins.push('envPlugin()');
    }
    if (pluginHtml) {
        pluginImports.push(`import htmlPlugin from 'esbuild-plugin-html';`);
        plugins.push('htmlPlugin()');
    }
    if (pluginSvg) {
        pluginImports.push(`import svgPlugin from 'esbuild-plugin-svg';`);
        plugins.push('svgPlugin()');
    }
    if (pluginInlineWorker) {
        pluginImports.push(`import inlineWorkerPlugin from 'esbuild-plugin-inline-worker';`);
        plugins.push('inlineWorkerPlugin()');
    }

    if (pluginImports.length > 0) {
        code = pluginImports.join('\n') + '\n' + code;
    }

    code += `esbuild.build({\n`;
    code += `  entryPoints: ['${entryPoint}'],\n`;
    code += `  outdir: '${outdir}',\n`;
    code += `  format: '${format}',\n`;
    code += `  platform: '${platform}',\n`;
    code += `  target: ['${target}'],\n`;

    if (bundle) code += `  bundle: true,\n`;
    if (minify) code += `  minify: true,\n`;
    if (sourcemap) code += `  sourcemap: true,\n`;
    if (!treeShaking) code += `  treeShaking: false,\n`;
    else code += `  treeShaking: true,\n`;
    if (splitting && format === 'esm') code += `  splitting: true,\n`;
    if (metafile) code += `  metafile: true,\n`;

    // JSX
    if (jsx) {
        code += `  jsx: '${jsxMode}',\n`;
        if (jsxFactory && jsxFactory !== 'React.createElement') code += `  jsxFactory: '${jsxFactory}',\n`;
        if (jsxFragment && jsxFragment !== 'React.Fragment') code += `  jsxFragment: '${jsxFragment}',\n`;
        if (jsxImportSource && jsxImportSource !== 'react') code += `  jsxImportSource: '${jsxImportSource}',\n`;
    }

    // Define (env vars)
    if (defineEnv && envVars) {
        const defines = {};
        envVars.split('\n').filter(l => l.trim()).forEach(line => {
            const [key, val] = line.split('=').map(s => s.trim());
            if (key) defines[`process.env.${key}`] = JSON.stringify(val || '');
        });
        if (Object.keys(defines).length > 0) {
            code += `  define: ${JSON.stringify(defines, null, 4).replace(/\n/g, '\n  ')},\n`;
        }
    }

    // External
    if (external) {
        const exts = external.split('\n').filter(l => l.trim()).map(l => l.trim());
        if (exts.length > 0) code += `  external: ${JSON.stringify(exts)},\n`;
    }

    // Alias
    if (aliasRules) {
        const aliases = {};
        aliasRules.split('\n').filter(l => l.trim()).forEach(line => {
            const [alias, path] = line.split('=').map(s => s.trim());
            if (alias && path) aliases[alias] = path;
        });
        if (Object.keys(aliases).length > 0) {
            code += `  alias: ${JSON.stringify(aliases, null, 4).replace(/\n/g, '\n  ')},\n`;
        }
    }

    // Plugins
    if (plugins.length > 0) {
        code += `  plugins: [\n    ${plugins.join(',\n    ')}\n  ],\n`;
    }

    // Log level
    code += `  logLevel: 'info',\n`;

    code += `}).then(() => {\n  console.log('✅ Build completed!');\n}).catch((err) => {\n  console.error('❌ Build failed:', err);\n  process.exit(1);\n});\n`;

    document.getElementById('codeOutput').textContent = code;
    document.getElementById('outputCard').style.display = 'block';

    // Install command
    let pkgs = ['esbuild'];
    if (pluginEnv) pkgs.push('esbuild-plugin-env');
    if (pluginHtml) pkgs.push('esbuild-plugin-html');
    if (pluginSvg) pkgs.push('esbuild-plugin-svg');
    if (pluginInlineWorker) pkgs.push('esbuild-plugin-inline-worker');
    const installCmd = 'npm install -D ' + pkgs.join(' ');
    document.getElementById('installOutput').textContent = installCmd;
    document.getElementById('installCard').style.display = 'block';

    window._lastCode = code;
    window._lastInstall = installCmd;
}

function copyCode() {
    const text = window._lastCode || document.getElementById('codeOutput').textContent;
    navigator.clipboard.writeText(text).then(() => {
        const btn = event.target;
        const orig = btn.textContent;
        btn.textContent = '✅ 已复制';
        setTimeout(() => btn.textContent = orig, 1500);
    });
}

function resetForm() {
    document.getElementById('entryPoint').value = 'src/index.ts';
    document.getElementById('outdir').value = 'dist';
    document.getElementById('format').value = 'esm';
    document.getElementById('platform').value = 'browser';
    document.getElementById('target').value = 'esnext';
    document.getElementById('scriptType').value = 'js';
    document.getElementById('bundle').checked = true;
    document.getElementById('minify').checked = false;
    document.getElementById('sourcemap').checked = false;
    document.getElementById('treeShaking').checked = true;
    document.getElementById('splitting').checked = false;
    document.getElementById('jsx').checked = false;
    document.getElementById('defineEnv').checked = false;
    document.getElementById('metafile').checked = false;
    document.getElementById('jsxConfig').style.display = 'none';
    document.getElementById('envConfig').style.display = 'none';
    document.getElementById('jsxMode').value = 'automatic';
    document.getElementById('jsxFactory').value = 'React.createElement';
    document.getElementById('jsxFragment').value = 'React.Fragment';
    document.getElementById('jsxImportSource').value = 'react';
    document.getElementById('envVars').value = 'NODE_ENV=production';
    document.getElementById('external').value = 'react\nreact-dom';
    document.getElementById('aliasRules').value = '@=src\n@components=src/components';
    document.getElementById('pluginEnv').checked = false;
    document.getElementById('pluginHtml').checked = false;
    document.getElementById('pluginSvg').checked = false;
    document.getElementById('pluginInlineWorker').checked = false;
    document.getElementById('outputCard').style.display = 'none';
    document.getElementById('installCard').style.display = 'none';
}

generate();
</script>
