:root{--bg:#0f172a;--card-bg:#1e293b;--text:#e2e8f0;--text-secondary:#94a3b8;--text-weak:#64748b;--accent:#06b6d4;--accent-hover:#22d3ee;--success:#10b981;--danger:#ef4444;--warning:#f59e0b;--border:rgba(148,163,184,.1);--radius:12px}
