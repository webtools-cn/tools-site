    <div class="reference">
      <strong style="color:#f1f5f9">常用HTML实体参考：</strong>
      <table>
        <tr><td>&lt; (小于号)</td><td>&amp;lt;</td></tr>
        <tr><td>&gt; (大于号)</td><td>&amp;gt;</td></tr>
        <tr><td>&amp; (和号)</td><td>&amp;amp;</td></tr>
        <tr><td>&quot; (双引号)</td><td>&amp;quot;</td></tr>
        <tr><td>&#39; (单引号)</td><td>&amp;#39;</td></tr>
      </table>
    </div>
