<script>
let chunks = [];

function estimateTokens(text) {
  const cn = (text.match(/[\u4e00-\u9fff]/g) || []).length;
  const en = text.length - cn;
  return Math.ceil(cn * 1.5 + en * 0.25);
}

function loadExample() {
  document.getElementById('input-text').value = `人工智能（Artificial Intelligence，简称AI）是计算机科学的一个分支，致力于创建能够执行通常需要人类智能的任务的系统。这些任务包括学习、推理、问题解决、感知和语言理解等。

AI的发展历程可以追溯到20世纪50年代。1956年，达特茅斯会议标志着人工智能作为一门学科的诞生。早期的研究集中在符号推理和专家系统上，但受限于计算能力和数据量，进展缓慢。

深度学习的突破发生在2012年，AlexNet在ImageNet竞赛中大幅领先传统方法，标志着深度学习时代的到来。此后，卷积神经网络（CNN）、循环神经网络（RNN）和Transformer架构相继出现，推动了计算机视觉、自然语言处理等领域的快速发展。

2017年，Google提出的Transformer架构彻底改变了自然语言处理领域。基于Transformer的BERT、GPT系列模型不断刷新各项NLP任务的记录。2022年底，ChatGPT的发布更是将大语言模型（LLM）推向了公众视野，引发了全球范围内的AI热潮。

RAG（检索增强生成）是一种结合信息检索和文本生成的技术架构。它通过将外部知识库中的相关文档检索出来，作为上下文提供给语言模型，从而增强生成内容的准确性和可靠性。RAG系统的核心组件包括：文档分块器、向量嵌入模型、向量数据库、检索器和生成模型。

文本分块是RAG系统中最关键的预处理步骤之一。合理的分块策略能够确保检索到的内容既包含足够的信息，又不会引入过多噪声。常见的分块策略包括固定大小分块、句子分块、段落分块和递归分块等。选择合适的分块策略需要考虑文档类型、嵌入模型限制和应用场景等因素。`;
  chunkText();
}

function updateStrategyUI() {
  const strategy = document.getElementById('chunk-strategy').value;
  const sizeSlider = document.getElementById('chunk-size');
  const overlapSlider = document.getElementById('overlap-size');
  if (strategy === 'sentence') {
    sizeSlider.value = 256; document.getElementById('chunk-size-val').textContent = '256';
    overlapSlider.value = 32; document.getElementById('overlap-size-val').textContent = '32';
  } else if (strategy === 'paragraph') {
    sizeSlider.value = 1024; document.getElementById('chunk-size-val').textContent = '1024';
    overlapSlider.value = 128; document.getElementById('overlap-size-val').textContent = '128';
  } else if (strategy === 'recursive') {
    sizeSlider.value = 512; document.getElementById('chunk-size-val').textContent = '512';
    overlapSlider.value = 64; document.getElementById('overlap-size-val').textContent = '64';
  }
}

function chunkText() {
  const text = document.getElementById('input-text').value;
  if (!text.trim()) { showToast('请先输入文本'); return; }
  const strategy = document.getElementById('chunk-strategy').value;
  const unit = document.getElementById('chunk-unit').value;
  const chunkSize = parseInt(document.getElementById('chunk-size').value);
  const overlapSize = parseInt(document.getElementById('overlap-size').value);
  const trimWs = document.getElementById('trim-whitespace').checked;
  const keepSep = document.getElementById('keep-separator').checked;

  if (unit === 'token') {
    chunks = chunkByTokens(text, strategy, chunkSize, overlapSize, trimWs);
  } else {
    switch(strategy) {
    case 'fixed': chunks = chunkFixed(text, chunkSize, overlapSize, trimWs); break;
    case 'sentence': chunks = chunkBySentence(text, chunkSize, overlapSize, trimWs); break;
    case 'paragraph': chunks = chunkByParagraph(text, chunkSize, overlapSize, trimWs); break;
    case 'recursive': chunks = chunkRecursive(text, chunkSize, overlapSize, trimWs); break;
  }
  }

  displayChunks();
}

function chunkFixed(text, size, overlap, trim) {
  const result = [];
  let start = 0;
  while (start < text.length) {
    let end = Math.min(start + size, text.length);
    let chunk = text.substring(start, end);
    if (trim) chunk = chunk.trim();
    if (chunk) result.push({ id: result.length + 1, text: chunk, start, end: Math.min(start + size, text.length), chars: chunk.length, tokens: estimateTokens(chunk) });
    start += size - overlap;
    if (start >= text.length) break;
    if (start < 0) start = 0;
  }
  return result;
}

function chunkBySentence(text, maxSize, overlap, trim) {
  const sentences = text.split(/(?<=[。！？.!?])\s*/);
  const result = [];
  let current = '';
  let start = 0;
  for (const s of sentences) {
    if ((current + s).length > maxSize && current) {
      let chunk = trim ? current.trim() : current;
      if (chunk) result.push({ id: result.length + 1, text: chunk, start, end: start + chunk.length, chars: chunk.length, tokens: estimateTokens(chunk) });
      const overlapText = current.slice(-overlap);
      current = overlapText + s;
      start += current.length - s.length - overlapText.length;
    } else {
      current += s;
    }
  }
  if (current) {
    let chunk = trim ? current.trim() : current;
    if (chunk) result.push({ id: result.length + 1, text: chunk, start, end: start + chunk.length, chars: chunk.length, tokens: estimateTokens(chunk) });
  }
  return result;
}

function chunkByParagraph(text, maxSize, overlap, trim) {
  const paragraphs = text.split(/\n\s*\n/);
  const result = [];
  let current = '';
  let start = 0;
  for (const p of paragraphs) {
    if ((current + '\n\n' + p).length > maxSize && current) {
      let chunk = trim ? current.trim() : current;
      if (chunk) result.push({ id: result.length + 1, text: chunk, start, end: start + chunk.length, chars: chunk.length, tokens: estimateTokens(chunk) });
      const overlapText = current.slice(-overlap);
      current = overlapText + '\n\n' + p;
      start += current.length - p.length - 2 - overlapText.length;
    } else {
      current = current ? current + '\n\n' + p : p;
    }
  }
  if (current) {
    let chunk = trim ? current.trim() : current;
    if (chunk) result.push({ id: result.length + 1, text: chunk, start, end: start + chunk.length, chars: chunk.length, tokens: estimateTokens(chunk) });
  }
  return result;
}

function chunkRecursive(text, maxSize, overlap, trim) {
  const separators = ['\n\n', '\n', '。', '！', '？', '. ', '! ', '? ', '；', ';', '，', ',', ' ', ''];
  function splitRecursive(text, sepIdx) {
    if (text.length <= maxSize || sepIdx >= separators.length) return [text];
    const sep = separators[sepIdx];
    const parts = text.split(sep);
    const result = [];
    let current = '';
    for (let i = 0; i < parts.length; i++) {
      const part = i === 0 ? parts[i] : sep + parts[i];
      if ((current + part).length > maxSize && current) {
        result.push(current);
        current = part.slice(-overlap) + (sepIdx < separators.length - 1 ? '' : '');
        if (current.length > maxSize) {
          const subChunks = splitRecursive(current, sepIdx + 1);
          result.push(...subChunks.slice(0, -1));
          current = subChunks[subChunks.length - 1] || '';
        }
      } else {
        current += part;
      }
    }
    if (current) result.push(current);
    return result;
  }
  const rawChunks = splitRecursive(text, 0);
  return rawChunks.filter(c => trim ? c.trim() : c).map((c, i) => {
    const chunk = trim ? c.trim() : c;
    return { id: i + 1, text: chunk, start: 0, end: chunk.length, chars: chunk.length, tokens: estimateTokens(chunk) };
  });
}

function chunkByTokens(text, strategy, maxTokens, overlapTokens, trim) {
  const charSize = Math.ceil(maxTokens * 3);
  const charOverlap = Math.ceil(overlapTokens * 3);
  let rawChunks;
  switch (strategy) {
    case 'fixed': rawChunks = chunkFixed(text, charSize, charOverlap, trim); break;
    case 'sentence': rawChunks = chunkBySentence(text, charSize, charOverlap, trim); break;
    case 'paragraph': rawChunks = chunkByParagraph(text, charSize, charOverlap, trim); break;
    case 'recursive': rawChunks = chunkRecursive(text, charSize, charOverlap, trim); break;
    default: rawChunks = chunkFixed(text, charSize, charOverlap, trim);
  }
  return rawChunks.filter(c => c.tokens <= maxTokens || c.tokens === estimateTokens(c.text));
}

function displayChunks() {
  if (!chunks.length) { showToast('未生成分块'); return; }
  document.getElementById('stats-section').style.display = 'block';
  document.getElementById('chunks-section').style.display = 'block';
  const totalChars = chunks.reduce((s, c) => s + c.chars, 0);
  const totalTokens = chunks.reduce((s, c) => s + c.tokens, 0);
  const avgChars = Math.round(totalChars / chunks.length);
  const overlapChars = chunks.length > 1 ? (chunks.length - 1) * parseInt(document.getElementById('overlap-size').value) : 0;
  document.getElementById('stat-chunks').textContent = chunks.length;
  document.getElementById('stat-total').textContent = totalChars.toLocaleString();
  document.getElementById('stat-avg').textContent = avgChars;
  document.getElementById('stat-tokens').textContent = totalTokens.toLocaleString();
  document.getElementById('stat-overlap').textContent = overlapChars;

  const output = document.getElementById('chunks-output');
  output.innerHTML = chunks.map(c => `
    <div class="chunk-card">
      <div class="chunk-header">
        <span class="chunk-id">Chunk #${c.id}</span>
        <span class="chunk-meta">${c.chars} 字符 · ~${c.tokens} Token</span>
      </div>
      <div class="chunk-text">${escapeHtml(c.text.substring(0, 500))}${c.text.length > 500 ? '...' : ''}</div>
      <div style="margin-top:8px;display:flex;gap:6px">
        <button class="btn btn-secondary" style="padding:4px 10px;font-size:.75rem" onclick="copyChunk(${c.id-1})">📋 复制</button>
      </div>
    </div>
  `).join('');
}

function escapeHtml(text) {
  return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function copyChunk(idx) {
  if (chunks[idx]) {
    navigator.clipboard.writeText(chunks[idx].text).then(() => showToast('已复制分块 #' + chunks[idx].id));
  }
}

function copyAllChunks() {
  if (!chunks.length) { showToast('请先分块'); return; }
  const text = chunks.map(c => `[Chunk #${c.id}]\n${c.text}`).join('\n\n---\n\n');
  navigator.clipboard.writeText(text).then(() => showToast('已复制全部分块'));
}

function exportChunks() {
  if (!chunks.length) { showToast('请先分块'); return; }
  const data = JSON.stringify({ strategy: document.getElementById('chunk-strategy').value, chunkSize: document.getElementById('chunk-size').value, overlap: document.getElementById('overlap-size').value, totalChunks: chunks.length, chunks }, null, 2);
  const blob = new Blob([data], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'chunks.json';
  a.click();
  URL.revokeObjectURL(a.href);
  showToast('已导出JSON文件');
}

function clearAll() {
  document.getElementById('input-text').value = '';
  document.getElementById('stats-section').style.display = 'none';
  document.getElementById('chunks-section').style.display = 'none';
  chunks = [];
}

function toggleFeedback(){const p=document.getElementById('feedback-panel');p.style.display=p.style.display==='none'?'block':'none';}
document.getElementById('feedback-text')?.addEventListener('input',function(){document.getElementById('feedback-count').textContent=this.value.length+'/1000';});
function submitFeedback(){
const type=document.getElementById('feedback-type').value;
const text=document.getElementById('feedback-text').value.trim();
if(!text){return;}
const title=encodeURIComponent(type+' - '+window.location.pathname);
const body=encodeURIComponent('**Page**: '+window.location.href+'\n**Type**: '+type+'\n\n'+text);
window.open('https://github.com/webtools-cn/tools-site/issues/new?title='+title+'&body='+body,'_blank');
}

function showToast(msg){const t=document.getElementById('toast')||(()=>{const d=document.createElement('div');d.id='toast';d.className='toast';document.body.appendChild(d);return d;})();t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000);}

document.addEventListener('keydown', function(e) {
  if(e.ctrlKey && e.key==='Enter') { chunkText(); e.preventDefault(); }
  if(e.ctrlKey && e.shiftKey && e.key==='C') { copyAllChunks(); e.preventDefault(); }
});
</script>
<link rel="stylesheet" href="https://free-toolbase.com/related-tools.css">
<div id="related-tools-section" class="related-tools-section"><div class="related-tools-loading">Loading related tools...</div></div>
