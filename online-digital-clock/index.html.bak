ckground:transparent}.mode-tab.active{background:#0f172a;color:#22d3ee}.mode-tab:hover:not(.active){color:#e2e8f0}@media(max-width:640px){.clock-time{font-size:3rem}.clock-seconds{font-size:1.2rem}.sw-display{font-size:2rem}}</style>
