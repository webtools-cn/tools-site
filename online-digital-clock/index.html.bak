<script>
let is24h = true;
let showDate = true;
let showSec = true;
let swRunning = false;
let swStart = 0;
let swElapsed = 0;
let swInterval = null;

function switchMode(mode){
  document.querySelectorAll('.mode-tab').forEach((t,i)=>{
    t.classList.toggle('active',(mode==='clock'&&i===0)||(mode==='stopwatch'&&i===1));
  });
  document.getElementById('clockMode').style.display = mode==='clock'?'':'none';
  document.getElementById('stopwatchMode').style.display = mode==='stopwatch'?'':'none';
  document.getElementById('stopwatchMode').className = mode==='stopwatch'?'stopwatch-section show':'stopwatch-section';
}

function updateFormat(){
  is24h = document.querySelector('input[name="format"]:checked').value === '24';
}

function updateSettings(){
  showDate = document.getElementById('showDate').checked;
  showSec = document.getElementById('showSeconds').checked;
}

function pad(n){return ('0'+n).slice(-2)}

function updateClock(){
  const now = new Date();
  let h = now.getHours();
  const m = now.getMinutes();
  const s = now.getSeconds();
  let ampm = '';
  if(!is24h){
    ampm = h >= 12 ? 'PM' : 'AM';
    h = h % 12 || 12;
  }
  document.getElementById('clockTime').innerHTML = pad(h)+':'+pad(m) + (ampm ? '<span class="clock-ampm">'+ampm+'</span>' : '');
  document.getElementById('clockSeconds').style.display = showSec ? '' : 'none';
  document.getElementById('clockSeconds').textContent = ':'+pad(s);
  
  if(showDate){
    const days = ['日','一','二','三','四','五','六'];
    const dateStr = now.getFullYear()+'年'+(now.getMonth()+1)+'月'+now.getDate()+'日 星期'+days[now.getDay()];
    document.getElementById('clockDate').textContent = dateStr;
    document.getElementById('clockDate').style.display = '';
  } else {
    document.getElementById('clockDate').style.display = 'none';
  }
}

function toggleFullscreen(){
  if(!document.fullscreenElement){
    document.documentElement.requestFullscreen();
  } else {
    document.exitFullscreen();
  }
}

function swToggle(){
  if(swRunning){
    clearInterval(swInterval);
    swElapsed += Date.now() - swStart;
    swRunning = false;
    document.getElementById('swStart').textContent = '▶ 继续';
    document.getElementById('swStart').className = 'btn btn-success';
  } else {
    swStart = Date.now();
    swRunning = true;
    document.getElementById('swStart').textContent = '⏸ 暂停';
    document.getElementById('swStart').className = 'btn btn-danger';
    swInterval = setInterval(updateSW, 10);
  }
}

function swReset(){
  clearInterval(swInterval);
  swRunning = false;
  swElapsed = 0;
  document.getElementById('swDisplay').textContent = '00:00:00.000';
  document.getElementById('swStart').textContent = '▶ 开始';
  document.getElementById('swStart').className = 'btn btn-success';
}

function updateSW(){
  const total = swElapsed + (Date.now() - swStart);
  const ms = total % 1000;
  const s = Math.floor(total/1000) % 60;
  const m = Math.floor(total/60000) % 60;
  const h = Math.floor(total/3600000);
  document.getElementById('swDisplay').textContent = pad(h)+':'+pad(m)+':'+pad(s)+'.'+('00'+ms).slice(-3);
}

setInterval(updateClock, 1000);
updateClock();
</script>
