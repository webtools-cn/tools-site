        <div class="key action" onclick="calcAction('CE')">CE</div>
        <div class="key op" onclick="calcAction('±')">±</div>
        <div class="key op" onclick="calcOp('÷')">÷</div>
        <div class="key" onclick="calcNum('7')">7</div>
        <div class="key" onclick="calcNum('8')">8</div>
        <div class="key" onclick="calcNum('9')">9</div>
        <div class="key op" onclick="calcOp('×')">×</div>
        <div class="key" onclick="calcNum('4')">4</div>
        <div class="key" onclick="calcNum('5')">5</div>
        <div class="key" onclick="calcNum('6')">6</div>
        <div class="key op" onclick="calcOp('-')">-</div>
        <div class="key" onclick="calcNum('1')">1</div>
        <div class="key" onclick="calcNum('2')">2</div>
        <div class="key" onclick="calcNum('3')">3</div>
        <div class="key op" onclick="calcOp('+')">+</div>
        <div class="key" onclick="calcNum('0')" style="grid-column:span 2">0</div>
        <div class="key" onclick="calcNum('.')">.</div>
        <div class="key equals" onclick="calcAction('=')">=</div>
