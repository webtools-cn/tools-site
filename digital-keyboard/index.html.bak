.tab-bar{display:flex;gap:4px;margin-bottom:16px;background:#1e293b;border-radius:8px;padding:4px;border:1px solid rgba(148,163,184,.1)}
.tab-bar button{flex:1;padding:8px;border:none;border-radius:5px;font-size:.85rem;cursor:pointer;background:transparent;color:#94a3b8;transition:all .2s}
.tab-bar button.active{background:rgba(6,182,212,.2);color:#22d3ee}
.display{background:#0f172a;border-radius:8px;padding:16px;margin-bottom:16px;border:1px solid rgba(148,163,184,.08);font-size:2rem;text-align:right;color:#f1f5f9;min-height:60px;overflow:hidden;word-break:break-all}
.display .expr{font-size:.9rem;color:#64748b;margin-bottom:4px}
.numpad{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;max-width:360px;margin:0 auto}
.numpad .key{padding:16px 8px;border:1px solid rgba(148,163,184,.15);border-radius:8px;background:#1e293b;color:#e2e8f0;font-size:1.2rem;cursor:pointer;transition:all .15s;text-align:center;user-select:none}
.numpad .key:hover{background:rgba(6,182,212,.15);border-color:rgba(6,182,212,.3)}
.numpad .key:active{background:rgba(6,182,212,.25);transform:scale(.95)}
.numpad .key.op{background:rgba(6,182,212,.1);color:#22d3ee;border-color:rgba(6,182,212,.2)}
.numpad .key.op:hover{background:rgba(6,182,212,.2)}
.numpad .key.action{background:rgba(239,68,68,.1);color:#f87171;border-color:rgba(239,68,68,.2)}
.numpad .key.action:hover{background:rgba(239,68,68,.2)}
.numpad .key.equals{background:rgba(34,197,94,.15);color:#4ade80;border-color:rgba(34,197,94,.2)}
.numpad .key.equals:hover{background:rgba(34,197,94,.25)}
.numpad .key.highlight{background:rgba(250,204,21,.2)!important;border-color:rgba(250,204,21,.4)!important;color:#fbbf24!important}
.test-grid{display:grid;grid-template-columns:repeat(14,1fr);gap:4px;max-width:700px;margin:0 auto}
.test-grid .tkey{padding:8px 4px;border:1px solid rgba(148,163,184,.15);border-radius:4px;background:#1e293b;color:#94a3b8;font-size:.65rem;cursor:default;text-align:center;user-select:none;min-height:32px;display:flex;align-items:center;justify-content:center}
.test-grid .tkey.pressed{background:rgba(34,197,94,.2);border-color:rgba(34,197,94,.4);color:#4ade80}
.test-grid .tkey.wide2{grid-column:span 2}
.test-grid .tkey.wide3{grid-column:span 3}
.test-grid .tkey.wide6{grid-column:span 6}
.test-grid .tkey.space{grid-column:span 6}
@media(max-width:600px){.numpad .key{padding:12px 6px;font-size:1rem}.test-grid{grid-template-columns:repeat(10,1fr)}.test-grid .tkey{font-size:.55rem;padding:6px 2px}}
