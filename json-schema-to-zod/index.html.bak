<script>
function toast(m){var t=document.getElementById("toast");t.textContent=m;t.classList.add("show");setTimeout(function(){t.classList.remove("show")},2000)}

function convertSchema() {
  var input = document.getElementById('schemaInput').value.trim();
  if (!input) { toast("请输入JSON Schema"); return; }
  try {
    var schema = JSON.parse(input);
    var zodCode = schemaToZod(schema, 'Schema');
    document.getElementById('resultZod').textContent = "import { z } from 'zod';\n\n" + zodCode;
    document.getElementById('resultArea').style.display = 'block';
  } catch(e) {
    toast("JSON格式错误: " + e.message);
  }
}
function schemaToZod(schema, name) {
  if (!schema) return 'z.unknown()';
  var type = schema.type;
  var result = '';
  if (schema.enum) {
    result = 'z.enum([' + schema.enum.map(function(e) { return JSON.stringify(e); }).join(', ') + '])';
  } else if (type === 'string') {
    result = 'z.string()';
    if (schema.minLength) result += '.min(' + schema.minLength + ')';
    if (schema.maxLength) result += '.max(' + schema.maxLength + ')';
    if (schema.pattern) result += '.regex(/' + schema.pattern.replace(/\\/g, '\\') + '/)';
    if (schema.format === 'email') result += '.email()';
    if (schema.format === 'url') result += '.url()';
    if (schema.format === 'uuid') result += '.uuid()';
  } else if (type === 'number' || type === 'integer') {
    result = type === 'integer' ? 'z.number().int()' : 'z.number()';
    if (schema.minimum !== undefined) result += '.min(' + schema.minimum + ')';
    if (schema.maximum !== undefined) result += '.max(' + schema.maximum + ')';
  } else if (type === 'boolean') {
    result = 'z.boolean()';
  } else if (type === 'array') {
    var itemZod = schema.items ? schemaToZod(schema.items, 'Item') : 'z.unknown()';
    result = 'z.array(' + itemZod + ')';
    if (schema.minItems) result += '.min(' + schema.minItems + ')';
    if (schema.maxItems) result += '.max(' + schema.maxItems + ')';
  } else if (type === 'object') {
    var props = schema.properties || {};
    var required = schema.required || [];
    var fields = [];
    for (var key in props) {
      var fieldZod = schemaToZod(props[key], key.charAt(0).toUpperCase() + key.slice(1));
      if (required.indexOf(key) === -1) fieldZod += '.optional()';
      if (props[key].default !== undefined) fieldZod += '.default(' + JSON.stringify(props[key].default) + ')';
      fields.push('  ' + key + ': ' + fieldZod);
    }
    result = 'z.object({\n' + fields.join(',\n') + '\n})';
  } else if (type === 'null') {
    result = 'z.null()';
  } else {
    result = 'z.unknown()';
  }
  if (schema.description) result += '.describe(' + JSON.stringify(schema.description) + ')';
  if (name && type === 'object') return 'export const ' + name + ' = ' + result + ';\n\nexport type ' + name + 'Type = z.infer<typeof ' + name + '>;';
  return result;
}
function clearAll() {
  document.getElementById('schemaInput').value = '';
  document.getElementById('resultArea').style.display = 'none';
}
function copyResult() {
  var text = document.getElementById('resultZod').textContent;
  navigator.clipboard.writeText(text).then(function() { toast("已复制！"); });
}

</script>
