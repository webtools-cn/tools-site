        "zip": { "type": "string", "pattern": "^\\d{5,6}$" }
      },
      "required": ["city"]
    }
  },
  "required": ["name", "age", "email"]
}</textarea>
    </div>
    <div class="btn-group">
      <button class="btn btn-primary" onclick="convertSchema()">转换为Zod</button>
      <button class="btn btn-secondary" onclick="clearAll()">清空</button>
    </div>
