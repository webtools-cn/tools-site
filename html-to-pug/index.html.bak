<script>
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000)}


(function(){
var app=document.getElementById('app');
app.innerHTML='<div class="input-section"><h2>📝 输入HTML</h2><textarea id="htmlInput" rows="12" placeholder="粘贴或输入HTML代码...\n\n例如：\n<div class="container">\n  <h1>Hello World</h1>\n  <p>This is a paragraph.</p>\n</div>" spellcheck="false"></textarea><div class="options"><label><input type="checkbox" id="keepBody" checked> 保留&lt;body&gt;标签</label></div><div class="btn-row"><button class="btn btn-primary" id="convertBtn">🔄 转换为Pug</button></div></div><div class="input-section"><h2>📋 转换结果（Pug语法）</h2><textarea id="pugOutput" rows="12" readonly placeholder="转换结果将显示在这里..." spellcheck="false"></textarea><div class="btn-row"><button class="btn btn-success" id="copyBtn">📋 复制Pug代码</button></div></div>';
document.getElementById('usageContent').innerHTML='<p>在左侧输入框中粘贴或输入HTML代码，点击"转换为Pug"按钮即可生成对应的Pug（Jade）模板语法。</p><p>支持：标签、属性(class/id)、嵌套层级、文本内容、自闭合标签、多行文本。</p><p>注意：Pug依赖缩进表示嵌套关系，请确保生成的缩进正确。</p>';

function htmlToPug(html, keepBody) {
  html = html.replace(/<!--[\s\S]*?-->/g, '').trim();
  if (!html) return '';
  var lines = [];
  var indent = 0;
  var inPre = false;

  function processNodes(nodes, depth) {
    if (!nodes || nodes.length === 0) return;
    for (var i = 0; i < nodes.length; i++) {
      var node = nodes[i];
      if (node.nodeType === 3) {
        var text = node.textContent.trim();
        if (text) {
          if (!inPre) lines.push('  '.repeat(depth) + '| ' + text);
          else lines.push('  '.repeat(depth) + text);
        }
        continue;
      }
      if (node.nodeType !== 1) continue;
      var tag = node.tagName.toLowerCase();
      if (!keepBody && tag === 'html') { processNodes(node.childNodes, depth); continue; }
      if (!keepBody && tag === 'body') { processNodes(node.childNodes, depth); continue; }
      if (!keepBody && tag === 'head') { processNodes(node.childNodes, depth); continue; }

      // Check if it's a self-closing tag
      var selfClosing = ['br','hr','img','input','meta','link','area','base','col','embed','source','track','wbr'].indexOf(tag) !== -1;

      var line = '  '.repeat(depth) + tag;

      // ID
      if (node.id) { line += '#' + node.id; }

      // Classes
      if (node.className && typeof node.className === 'string') {
        var classes = node.className.trim().split(/\s+/).filter(Boolean);
        if (classes.length > 0) line += '.' + classes.join('.');
      }

      // Attributes (excluding id/class)
      var attrs = [];
      for (var j = 0; j < node.attributes.length; j++) {
        var attr = node.attributes[j];
        if (attr.name === 'id' || attr.name === 'class') continue;
        var val = attr.value;
        if (val === '' || val === attr.name) {
          attrs.push(attr.name);
        } else if (/^[a-zA-Z0-9_\-]+$/.test(val) && attr.name !== 'style') {
          attrs.push(attr.name + '=' + val);
        } else {
          attrs.push(attr.name + '("' + val.replace(/"/g, '&quot;') + '")');
        }
      }
      if (attrs.length > 0) line += '(' + attrs.join(', ') + ')';

      var children = node.childNodes;
      var textChild = null;
      if (children.length === 1 && children[0].nodeType === 3) {
        textChild = children[0].textContent.trim();
      }

      if (selfClosing) {
        lines.push(line);
      } else if (textChild) {
        line += ' ' + textChild;
        lines.push(line);
      } else {
        lines.push(line);
        var prevInPre = inPre;
        if (tag === 'pre' || tag === 'code') inPre = true;
        processNodes(children, depth + 1);
        inPre = prevInPre;
      }
    }
  }

  var parser = new DOMParser();
  var doc = parser.parseFromString(html, 'text/html');
  var body = doc.body;
  processNodes(body.childNodes, 0);
  return lines.join('\n');
}

function convert() {
  var html = document.getElementById('htmlInput').value;
  var keepBody = document.getElementById('keepBody').checked;
  try {
    var pug = htmlToPug(html, keepBody);
    document.getElementById('pugOutput').value = pug || '(空结果)';
  } catch(e) {
    document.getElementById('pugOutput').value = '转换出错: ' + e.message;
  }
}

document.getElementById('convertBtn').addEventListener('click', convert);
document.getElementById('copyBtn').addEventListener('click', function(){
  var text = document.getElementById('pugOutput').value;
  if (text && text !== '(空结果)') {
    navigator.clipboard.writeText(text).then(function(){showToast('Pug代码已复制！');});
  }
});
document.getElementById('htmlInput').addEventListener('keydown', function(e){
  if (e.key === 'Tab') { e.preventDefault(); var start = this.selectionStart; var end = this.selectionEnd; this.value = this.value.substring(0, start) + '  ' + this.value.substring(end); this.selectionStart = this.selectionEnd = start + 2; }
});
})();

</script>
