<script>
let generatedCodes = [];
function applyTemplate(t){
  document.querySelectorAll('.template-btn').forEach(b=>b.classList.remove('active'));
  event.target.closest('.template-btn').classList.add('active');
  const cfg = {
    standard:{prefix:'',suffix:'',codeLength:8,sepEvery:4,separator:'-',useUpper:true,useNumbers:true,useLower:false,excludeAmbiguous:true},
    summer:{prefix:'SUMMER-',suffix:'',codeLength:8,sepEvery:4,separator:'-',useUpper:true,useNumbers:true,useLower:false,excludeAmbiguous:true},
    vip:{prefix:'VIP-',suffix:'',codeLength:6,sepEvery:0,separator:'',useUpper:true,useNumbers:true,useLower:false,excludeAmbiguous:true},
    numeric:{prefix:'',suffix:'',codeLength:8,sepEvery:4,separator:'-',useUpper:false,useNumbers:true,useLower:false,excludeAmbiguous:false},
    alpha:{prefix:'',suffix:'',codeLength:8,sepEvery:4,separator:'-',useUpper:true,useNumbers:false,useLower:false,excludeAmbiguous:true},
    custom:{}
  };
  const c = cfg[t]||{};
  if(c.prefix!==undefined) document.getElementById('prefix').value=c.prefix;
  if(c.suffix!==undefined) document.getElementById('suffix').value=c.suffix;
  if(c.codeLength!==undefined) document.getElementById('codeLength').value=c.codeLength;
  if(c.sepEvery!==undefined) document.getElementById('sepEvery').value=c.sepEvery;
  if(c.separator!==undefined) document.getElementById('separator').value=c.separator;
  if(c.useUpper!==undefined) document.getElementById('useUpper').checked=c.useUpper;
  if(c.useNumbers!==undefined) document.getElementById('useNumbers').checked=c.useNumbers;
  if(c.useLower!==undefined) document.getElementById('useLower').checked=c.useLower;
  if(c.excludeAmbiguous!==undefined) document.getElementById('excludeAmbiguous').checked=c.excludeAmbiguous;
}
function getCharset(){
  let chars = '';
  const exAmb = document.getElementById('excludeAmbiguous').checked;
  if(document.getElementById('useUpper').checked) chars += exAmb ? 'ABCDEFGHJKMNPQRSTUVWXYZ' : 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  if(document.getElementById('useLower').checked) chars += exAmb ? 'abcdefghjkmnpqrstuvwxyz' : 'abcdefghijklmnopqrstuvwxyz';
  if(document.getElementById('useNumbers').checked) chars += exAmb ? '23456789' : '0123456789';
  return chars || 'ABCDEFGHJKMNPQRSTUVWXYZ23456789';
}
function generateCode(){
  const len = parseInt(document.getElementById('codeLength').value)||8;
  const prefix = document.getElementById('prefix').value;
  const suffix = document.getElementById('suffix').value;
  const sep = document.getElementById('separator').value;
  const sepEvery = parseInt(document.getElementById('sepEvery').value)||0;
  const chars = getCharset();
  let code = '';
  for(let i=0;i<len;i++) code += chars[Math.floor(Math.random()*chars.length)];
  if(sepEvery > 0 && sep){
    let parts = [];
    for(let i=0;i<code.length;i+=sepEvery) parts.push(code.substring(i,i+sepEvery));
    code = parts.join(sep);
  }
  return prefix + code + suffix;
}
function generate(){
  const count = Math.min(1000, Math.max(1, parseInt(document.getElementById('count').value)||10));
  const codes = new Set();
  let attempts = 0;
  while(codes.size < count && attempts < count * 10){
    codes.add(generateCode());
    attempts++;
  }
  generatedCodes = Array.from(codes);
  document.getElementById('resultCount').textContent = generatedCodes.length;
  document.getElementById('resultBox').textContent = generatedCodes.join('\n');
  document.getElementById('resultSection').classList.add('show');
}
function loadExample(){
  document.getElementById('prefix').value='SUMMER-';
  document.getElementById('suffix').value='-2026';
  document.getElementById('codeLength').value=8;
  document.getElementById('count').value=10;
  document.getElementById('sepEvery').value=4;
  document.getElementById('separator').value='-';
  document.getElementById('useUpper').checked=true;
  document.getElementById('useNumbers').checked=true;
  document.getElementById('useLower').checked=false;
  document.getElementById('excludeAmbiguous').checked=true;
  generate();
}
function copyResult(){
  navigator.clipboard.writeText(generatedCodes.join('\n')).then(()=>alert('已复制到剪贴板'));
}
function downloadCSV(){
  const csv = 'promo_code\n'+generatedCodes.join('\n');
  const blob = new Blob([csv],{type:'text/csv'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'promo-codes.csv';
  a.click();
}
function downloadTXT(){
  const blob = new Blob([generatedCodes.join('\n')],{type:'text/plain'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'promo-codes.txt';
  a.click();
}
document.addEventListener('keydown',function(e){
  if(e.ctrlKey&&e.key==='Enter'){generate();e.preventDefault();}
  if(e.ctrlKey&&e.shiftKey&&e.key==='C'){copyResult();e.preventDefault();}
});
</script>
