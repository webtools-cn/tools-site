<script>
const MODELS = [
  {id:'gpt4o',name:'GPT-4o',vendor:'OpenAI',ctx:128000,inputPrice:2.5,outputPrice:10,speed:82,mmlu:88.7,humaneval:90.2,mtbench:9.3,type:'闭源',multimodal:true},
  {id:'gpt4omini',name:'GPT-4o-mini',vendor:'OpenAI',ctx:128000,inputPrice:0.15,outputPrice:0.6,speed:95,mmlu:82,humaneval:87.2,mtbench:8.5,type:'闭源',multimodal:true},
  {id:'claude35sonnet',name:'Claude 3.5 Sonnet',vendor:'Anthropic',ctx:200000,inputPrice:3,outputPrice:15,speed:85,mmlu:88.3,humaneval:92,mtbench:9.1,type:'闭源',multimodal:true},
  {id:'claude3haiku',name:'Claude 3 Haiku',vendor:'Anthropic',ctx:200000,inputPrice:0.25,outputPrice:1.25,speed:97,mmlu:75.2,humaneval:81.5,mtbench:7.8,type:'闭源',multimodal:true},
  {id:'gemini15pro',name:'Gemini 1.5 Pro',vendor:'Google',ctx:2000000,inputPrice:1.25,outputPrice:5,speed:78,mmlu:85.9,humaneval:84.1,mtbench:8.9,type:'闭源',multimodal:true},
  {id:'gemini15flash',name:'Gemini 1.5 Flash',vendor:'Google',ctx:1000000,inputPrice:0.075,outputPrice:0.3,speed:98,mmlu:78.5,humaneval:77.5,mtbench:8.0,type:'闭源',multimodal:true},
  {id:'llama31_405b',name:'Llama 3.1 405B',vendor:'Meta',ctx:128000,inputPrice:0,outputPrice:0,speed:70,mmlu:87.3,humaneval:89,mtbench:8.9,type:'开源',multimodal:false},
  {id:'llama31_70b',name:'Llama 3.1 70B',vendor:'Meta',ctx:128000,inputPrice:0,outputPrice:0,speed:80,mmlu:82,humaneval:81.5,mtbench:8.3,type:'开源',multimodal:false},
  {id:'llama31_8b',name:'Llama 3.1 8B',vendor:'Meta',ctx:128000,inputPrice:0,outputPrice:0,speed:95,mmlu:68.4,humaneval:62.5,mtbench:7.0,type:'开源',multimodal:false},
  {id:'mistral_large',name:'Mistral Large',vendor:'Mistral',ctx:128000,inputPrice:2,outputPrice:6,speed:82,mmlu:81.5,humaneval:80,mtbench:8.4,type:'部分开源',multimodal:false},
  {id:'qwen2_72b',name:'Qwen2 72B',vendor:'阿里',ctx:128000,inputPrice:0,outputPrice:0,speed:80,mmlu:82.3,humaneval:82,mtbench:8.2,type:'开源',multimodal:true},
  {id:'deepseekv2',name:'DeepSeek V2.5',vendor:'DeepSeek',ctx:128000,inputPrice:0.14,outputPrice:0.28,speed:85,mmlu:80.5,humaneval:84,mtbench:8.3,type:'开源',multimodal:false}
];

let selectedModels = new Set(['gpt4o','claude35sonnet','gemini15pro']);

function initModelSelect() {
  const container = document.getElementById('model-select');
  container.innerHTML = MODELS.map(m => `
    <label class="model-chip ${selectedModels.has(m.id)?'selected':''}" onclick="toggleModel('${m.id}',this)">
      <input type="checkbox" ${selectedModels.has(m.id)?'checked':''}>
      ${m.name}
    </label>
  `).join('');
}

function toggleModel(id, el) {
  if (selectedModels.has(id)) { selectedModels.delete(id); el.classList.remove('selected'); }
  else { selectedModels.add(id); el.classList.add('selected'); }
}

function selectAll() { MODELS.forEach(m => selectedModels.add(m.id)); initModelSelect(); }
function deselectAll() { selectedModels.clear(); initModelSelect(); }

function compareModels() {
  if (selectedModels.size < 2) { showToast('请至少选择2个模型'); return; }
  const models = MODELS.filter(m => selectedModels.has(m.id));
  const metrics = [
    {key:'vendor',label:'厂商',type:'text'},
    {key:'type',label:'类型',type:'text'},
    {key:'ctx',label:'上下文窗口',type:'ctx',unit:'K'},
    {key:'inputPrice',label:'输入价格',type:'price',unit:'/M token'},
    {key:'outputPrice',label:'输出价格',type:'price',unit:'/M token'},
    {key:'speed',label:'推理速度',type:'bar',max:100},
    {key:'mmlu',label:'MMLU',type:'bar',max:100},
    {key:'humaneval',label:'HumanEval',type:'bar',max:100},
    {key:'mtbench',label:'MT-Bench',type:'bar',max:10},
    {key:'multimodal',label:'多模态',type:'bool'}
  ];

  let html = '<thead><tr><th>指标</th>' + models.map(m => `<th>${m.name}</th>`).join('') + '</tr></thead><tbody>';
  metrics.forEach(metric => {
    html += `<tr><td style="font-weight:600;color:#94a3b8">${metric.label}</td>`;
    let bestVal = null;
    if (metric.type === 'bar' || metric.type === 'price' || metric.type === 'ctx') {
      if (metric.type === 'price') bestVal = Math.min(...models.map(m => m[metric.key]));
      else if (metric.type === 'ctx') bestVal = Math.max(...models.map(m => m[metric.key]));
      else bestVal = Math.max(...models.map(m => m[metric.key]));
    }
    models.forEach(m => {
      const val = m[metric.key];
      let cell = '';
      if (metric.type === 'text') cell = val;
      else if (metric.type === 'bool') cell = val ? '✅ 支持' : '❌ 不支持';
      else if (metric.type === 'ctx') {
        const k = val / 1000;
        cell = `<div class="bar-cell"><div class="bar-fill" style="width:${Math.min(k/2000*100,100)}%;background:rgba(6,182,212,0.6)"></div><span style="font-size:.8rem;margin-left:4px;${val===bestVal?'color:#22c55e;font-weight:600':''}">${k >= 1000 ? (k/1000)+'M' : k+'K'}</span></div>`;
      }
      else if (metric.type === 'price') {
        cell = val === 0 ? '<span style="color:#22c55e;font-weight:600">免费</span>' :
          `<span style="${val===bestVal?'color:#22c55e;font-weight:600':''}">$${val}${metric.unit}</span>`;
      }
      else if (metric.type === 'bar') {
        const pct = (val / metric.max) * 100;
        cell = `<div class="bar-cell"><div class="bar-fill" style="width:${pct}%;background:rgba(6,182,212,0.6)"></div><span style="font-size:.8rem;margin-left:4px;${val===bestVal?'color:#22c55e;font-weight:600':''}">${val}</span></div>`;
      }
      html += `<td>${cell}</td>`;
    });
    html += '</tr>';
  });
  html += '</tbody>';

  document.getElementById('compare-section').style.display = 'block';
  document.getElementById('compare-table').innerHTML = html;
}

function showToast(msg){const t=document.getElementById('toast')||(()=>{const d=document.createElement('div');d.id='toast';d.className='toast';document.body.appendChild(d);return d;})();t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000);}

window.addEventListener('load', initModelSelect);
</script>
