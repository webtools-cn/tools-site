<script>
let audioCtx = null;
let analyser = null;
let source = null;
let animId = null;
let micStream = null;

function getAudioCtx() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  return audioCtx;
}

function createAnalyser() {
  const ctx = getAudioCtx();
  analyser = ctx.createAnalyser();
  analyser.fftSize = parseInt(document.getElementById('fft-size').value);
  analyser.smoothingTimeConstant = parseFloat(document.getElementById('smoothing').value);
  document.getElementById('sample-rate').textContent = ctx.sampleRate;
  return analyser;
}

async function startMic() {
  try {
    stopAnalysis();
    const stream = await navigator.mediaDevices.getUserMedia({audio: true});
    micStream = stream;
    const ctx = getAudioCtx();
    const an = createAnalyser();
    source = ctx.createMediaStreamSource(stream);
    source.connect(an);
    document.getElementById('mic-btn').textContent = '🎤 分析中...';
    startVisualization();
  } catch(e) {
    showToast('❌ 无法访问麦克风: ' + e.message);
  }
}

document.getElementById('audio-file').addEventListener('change', async function(e) {
  if (!e.target.files.length) return;
  stopAnalysis();
  const file = e.target.files[0];
  const ctx = getAudioCtx();
  const an = createAnalyser();
  const arrayBuffer = await file.arrayBuffer();
  const audioBuffer = await ctx.decodeAudioData(arrayBuffer);
  source = ctx.createBufferSource();
  source.buffer = audioBuffer;
  source.connect(an);
  an.connect(ctx.destination);
  source.start(0);
  source.onended = () => { stopAnalysis(); showToast('🎵 播放结束'); };
  startVisualization();
});

function stopAnalysis() {
  if (animId) { cancelAnimationFrame(animId); animId = null; }
  if (source) { try { source.disconnect(); } catch(e){} source = null; }
  if (micStream) { micStream.getTracks().forEach(t => t.stop()); micStream = null; }
  document.getElementById('mic-btn').textContent = '🎤 麦克风输入';
}

function updateFFTSize() {
  if (analyser) analyser.fftSize = parseInt(document.getElementById('fft-size').value);
}

function updateSmoothing() {
  const v = parseFloat(document.getElementById('smoothing').value);
  document.getElementById('smooth-val').textContent = v.toFixed(2);
  if (analyser) analyser.smoothingTimeConstant = v;
}

function startVisualization() {
  const specCanvas = document.getElementById('spectrum-canvas');
  const waveCanvas = document.getElementById('waveform-canvas');
  const specCtx = specCanvas.getContext('2d');
  const waveCtx = waveCanvas.getContext('2d');
  
  function draw() {
    animId = requestAnimationFrame(draw);
    if (!analyser) return;
    
    const bufferLength = analyser.frequencyBinCount;
    const freqData = new Uint8Array(bufferLength);
    const timeData = new Uint8Array(bufferLength);
    analyser.getByteFrequencyData(freqData);
    analyser.getByteTimeDomainData(timeData);
    
    // Find peak frequency
    let peakIdx = 0, peakVal = 0;
    for (let i = 0; i < bufferLength; i++) {
      if (freqData[i] > peakVal) { peakVal = freqData[i]; peakIdx = i; }
    }
    const sampleRate = audioCtx ? audioCtx.sampleRate : 44100;
    const peakFreq = Math.round(peakIdx * sampleRate / analyser.fftSize);
    const peakDb = peakVal > 0 ? (20 * Math.log10(peakVal / 255)).toFixed(1) : '--';
    document.getElementById('peak-freq').textContent = peakFreq;
    document.getElementById('peak-amp').textContent = peakDb;
    
    // Draw spectrum
    if (document.getElementById('show-spectrum').checked) {
      specCanvas.style.display = 'block';
      const w = specCanvas.width = specCanvas.clientWidth;
      const h = specCanvas.height = 200;
      specCtx.fillStyle = '#0f172a';
      specCtx.fillRect(0, 0, w, h);
      
      const barWidth = w / bufferLength;
      for (let i = 0; i < bufferLength; i++) {
        const val = freqData[i] / 255;
        const barH = val * h;
        const hue = 180 + val * 180;
        specCtx.fillStyle = `hsla(${hue}, 80%, 50%, 0.8)`;
        specCtx.fillRect(i * barWidth, h - barH, barWidth + 1, barH);
      }
      
      // Grid lines
      specCtx.strokeStyle = 'rgba(148,163,184,0.1)';
      specCtx.lineWidth = 1;
      for (let i = 0; i < 5; i++) {
        const y = (h / 5) * i;
        specCtx.beginPath(); specCtx.moveTo(0, y); specCtx.lineTo(w, y); specCtx.stroke();
      }
    } else {
      specCanvas.style.display = 'none';
    }
    
    // Draw waveform
    if (document.getElementById('show-waveform').checked) {
      waveCanvas.style.display = 'block';
      const w = waveCanvas.width = waveCanvas.clientWidth;
      const h = waveCanvas.height = 150;
      waveCtx.fillStyle = '#0f172a';
      waveCtx.fillRect(0, 0, w, h);
      
      waveCtx.strokeStyle = '#06b6d4';
      waveCtx.lineWidth = 2;
      waveCtx.beginPath();
      const sliceWidth = w / bufferLength;
      let x = 0;
      for (let i = 0; i < bufferLength; i++) {
        const v = timeData[i] / 128.0;
        const y = (v * h) / 2;
        if (i === 0) waveCtx.moveTo(x, y);
        else waveCtx.lineTo(x, y);
        x += sliceWidth;
      }
      waveCtx.stroke();
      
      // Center line
      waveCtx.strokeStyle = 'rgba(148,163,184,0.15)';
      waveCtx.lineWidth = 1;
      waveCtx.beginPath(); waveCtx.moveTo(0, h/2); waveCtx.lineTo(w, h/2); waveCtx.stroke();
    } else {
      waveCanvas.style.display = 'none';
    }
  }
  draw();
}

function toggleFeedback(){const p=document.getElementById('feedback-panel');p.style.display=p.style.display==='none'?'block':'none';}
document.getElementById('feedback-text')?.addEventListener('input',function(){document.getElementById('feedback-count').textContent=this.value.length+'/1000';});
function submitFeedback(){
const type=document.getElementById('feedback-type').value;
const text=document.getElementById('feedback-text').value.trim();
if(!text){return;}
const title=encodeURIComponent(type+' - '+window.location.pathname);
const body=encodeURIComponent('**Page**: '+window.location.href+'\\n**Type**: '+type+'\\n\\n'+text);
window.open('https://github.com/webtools-cn/tools-site/issues/new?title='+title+'&body='+body,'_blank');
}
function showToast(msg){const t=document.getElementById('toast')||(()=>{const d=document.createElement('div');d.id='toast';d.className='toast';document.body.appendChild(d);return d;})();t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000);}
</script>
