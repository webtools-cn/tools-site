{
  "manifest_version": 3,
  "name": "Hash 哈希生成器",
  "version": "1.0.0",
  "description": "纯前端本地处理的Hash哈希生成器，支持MD5/SHA-1/SHA-256/SHA-384/SHA-512文本哈希、HMAC密钥消息认证、文件哈希拖拽计算，数据不上传服务器。复用 webtools-cn.github.io 工具站逻辑。",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Hash 哈希生成器 - 点击打开",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [],
  "host_permissions": [],
  "offline_enabled": true,
  "homepage_url": "https://webtools-cn.github.io/hash-generator/"
}
